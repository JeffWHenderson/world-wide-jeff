  "cards": [
    { "id": "ar_me_001", "levels": [{ "front": "happy", "back": "سعيد", "romanized": "sa'id" }, { "front": "I'm very happy today.", "back": "أنا سعيد جداً اليوم.", "romanized": "ana sa'id jiddan al-yawm." }] },
    { "id": "ar_me_002", "levels": [{ "front": "sad", "back": "حزين", "romanized": "hazin" }, { "front": "Why are you sad?", "back": "لماذا أنت حزين؟", "romanized": "limatha anta hazin?" }] },
    { "id": "ar_me_003", "levels": [{ "front": "angry", "back": "غاضب", "romanized": "ghadib" }, { "front": "He is angry about the situation.", "back": "هو غاضب من الوضع.", "romanized": "huwa ghadib min al-wad'." }] },
    { "id": "ar_me_004", "levels": [{ "front": "tired", "back": "متعب", "romanized": "muta'ab" }, { "front": "I'm tired after work.", "back": "أنا متعب بعد العمل.", "romanized": "ana muta'ab ba'd al-amal." }] },
    { "id": "ar_me_005", "levels": [{ "front": "excited", "back": "متحمس", "romanized": "mutahammis" }, { "front": "I'm excited about the trip.", "back": "أنا متحمس للرحلة.", "romanized": "ana mutahammis lir-rihla." }] },
    { "id": "ar_me_006", "levels": [{ "front": "worried", "back": "قلق", "romanized": "qaliq" }, { "front": "She is worried about the exam.", "back": "هي قلقة بشأن الامتحان.", "romanized": "hiya qaliqa bi-sha'n al-imtihan." }] },
    { "id": "ar_me_007", "levels": [{ "front": "bored", "back": "مملول / متضجر", "romanized": "mamlul / mutadajjir" }, { "front": "I'm bored at home.", "back": "أنا متضجر في البيت.", "romanized": "ana mutadajjir fi al-bayt." }] },
    { "id": "ar_me_008", "levels": [{ "front": "surprised", "back": "مندهش / متفاجئ", "romanized": "mundahish / mutafaji'" }, { "front": "I was surprised by the news.", "back": "تفاجأت بالخبر.", "romanized": "tafaja'tu bi-l-khabar." }] },
    { "id": "ar_me_009", "levels": [{ "front": "afraid / scared", "back": "خائف", "romanized": "kha'if" }, { "front": "Are you afraid of the dark?", "back": "هل أنت خائف من الظلام؟", "romanized": "hal anta kha'if min adh-dhalam?" }] },
    { "id": "ar_me_010", "levels": [{ "front": "nervous", "back": "متوتر", "romanized": "mutawatir" }, { "front": "I'm nervous before the presentation.", "back": "أنا متوتر قبل العرض.", "romanized": "ana mutawatir qabl al-ard." }] },
    { "id": "ar_me_011", "levels": [{ "front": "calm", "back": "هادئ", "romanized": "hadi'" }, { "front": "Stay calm, everything is fine.", "back": "ابق هادئاً، كل شيء بخير.", "romanized": "ibqa hadi'an, kull shay' bi-khayr." }] },
    { "id": "ar_me_012", "levels": [{ "front": "proud", "back": "فخور", "romanized": "fakhur" }, { "front": "I'm proud of you.", "back": "أنا فخور بك.", "romanized": "ana fakhur bik." }] },
    { "id": "ar_me_013", "levels": [{ "front": "disappointed", "back": "محبط / خائب الأمل", "romanized": "muhbat / kha'ib al-amal" }, { "front": "I'm disappointed with the result.", "back": "أنا محبط من النتيجة.", "romanized": "ana muhbat min an-natija." }] },
    { "id": "ar_me_014", "levels": [{ "front": "lonely", "back": "وحيد", "romanized": "wahid" }, { "front": "I feel lonely in this city.", "back": "أشعر بالوحدة في هذه المدينة.", "romanized": "ash'ur bi-l-wahda fi hadhihi al-madina." }] },
    { "id": "ar_me_015", "levels": [{ "front": "grateful", "back": "ممتن / شاكر", "romanized": "mumtann / shakir" }, { "front": "I'm grateful for your help.", "back": "أنا ممتن لمساعدتك.", "romanized": "ana mumtann li-musa'adatik." }] },
    { "id": "ar_me_016", "levels": [{ "front": "confident", "back": "واثق من نفسه", "romanized": "wathiq min nafsihi" }, { "front": "You should be more confident.", "back": "يجب أن تكون أكثر ثقة بنفسك.", "romanized": "yajibu an takun akthar thiqa bi-nafsik." }] },
    { "id": "ar_me_017", "levels": [{ "front": "love (feeling)", "back": "الحب", "romanized": "al-hubb" }, { "front": "Love is a beautiful feeling.", "back": "الحب شعور جميل.", "romanized": "al-hubb shu'ur jamil." }] },
    { "id": "ar_me_018", "levels": [{ "front": "hope", "back": "أمل", "romanized": "amal" }, { "front": "There is always hope.", "back": "هناك دائماً أمل.", "romanized": "hunak da'iman amal." }] },
    { "id": "ar_me_019", "levels": [{ "front": "joy", "back": "فرح", "romanized": "farah" }, { "front": "Her face is full of joy.", "back": "وجهها ممتلئ بالفرح.", "romanized": "wajhuha mumtali' bi-l-farah." }] },
    { "id": "ar_me_020", "levels": [{ "front": "sadness", "back": "حزن", "romanized": "huzn" }, { "front": "I feel sadness when I hear this song.", "back": "أشعر بالحزن عندما أسمع هذه الأغنية.", "romanized": "ash'ur bi-l-huzn indama asma' hadhihi al-ughniyya." }] },
    { "id": "ar_me_021", "levels": [{ "front": "I feel...", "back": "أشعر بـ...", "romanized": "ash'ur bi-..." }, { "front": "I feel happy today.", "back": "أشعر بالسعادة اليوم.", "romanized": "ash'ur bi-s-sa'ada al-yawm." }] },
    { "id": "ar_me_022", "levels": [{ "front": "stressed", "back": "مضغوط", "romanized": "madghut" }, { "front": "I'm very stressed about work.", "back": "أنا مضغوط جداً بسبب العمل.", "romanized": "ana madghut jiddan bi-sabab al-amal." }] },
    { "id": "ar_me_023", "levels": [{ "front": "relaxed", "back": "مرتاح", "romanized": "murtah" }, { "front": "I feel relaxed after the holiday.", "back": "أشعر بالارتياح بعد الإجازة.", "romanized": "ash'ur bi-l-irtiyah ba'd al-ijaza." }] },
    { "id": "ar_me_024", "levels": [{ "front": "embarrassed", "back": "محرج / خجلان", "romanized": "muharraj / khajlan" }, { "front": "I was embarrassed by my mistake.", "back": "أحرجتني غلطتي.", "romanized": "ahrrajatni ghalatati." }] },
    { "id": "ar_me_025", "levels": [{ "front": "jealous", "back": "غيور", "romanized": "ghayur" }, { "front": "Don't be jealous of others.", "back": "لا تكن غيوراً من الآخرين.", "romanized": "la takun ghayuran min al-akharin." }] }
  ]
