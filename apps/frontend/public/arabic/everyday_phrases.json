{
  "id": "everyday_phrases",
  "name": "Everyday Phrases",
  "language": "arabic",
  "stories": ["meet_jeff", "meet_seth"],
  "pictureLessons": [],
  "cards": [
    { "id": "ar_ep_001", "levels": [{ "front": "I", "back": "أنا", "romanized": "ana" }, { "front": "I am a student.", "back": "أنا طالب.", "romanized": "ana talib." }] },
    { "id": "ar_ep_002", "levels": [{ "front": "You (m.)", "back": "أنتَ", "romanized": "anta" }, { "front": "You speak Arabic well.", "back": "أنتَ تتكلم العربية جيداً.", "romanized": "anta tatakallam al-arabiyya jayyidan." }] },
    { "id": "ar_ep_003", "levels": [{ "front": "You (f.)", "back": "أنتِ", "romanized": "anti" }, { "front": "You are my friend.", "back": "أنتِ صديقتي.", "romanized": "anti sadiqati." }] },
    { "id": "ar_ep_004", "levels": [{ "front": "He", "back": "هو", "romanized": "huwa" }, { "front": "He is my friend.", "back": "هو صديقي.", "romanized": "huwa sadiqi." }] },
    { "id": "ar_ep_005", "levels": [{ "front": "She", "back": "هي", "romanized": "hiya" }, { "front": "She works here.", "back": "هي تعمل هنا.", "romanized": "hiya ta'mal huna." }] },
    { "id": "ar_ep_006", "levels": [{ "front": "We", "back": "نحن", "romanized": "nahnu" }, { "front": "We live in Cairo.", "back": "نحن نعيش في القاهرة.", "romanized": "nahnu na'ish fi al-qahira." }] },
    { "id": "ar_ep_007", "levels": [{ "front": "They", "back": "هم", "romanized": "hum" }, { "front": "They are from Morocco.", "back": "هم من المغرب.", "romanized": "hum min al-maghrib." }] },
    { "id": "ar_ep_008", "levels": [{ "front": "My", "back": "ـي / اسمي", "romanized": "-i / ismi" }, { "front": "My name is Khalid.", "back": "اسمي خالد.", "romanized": "ismi Khalid." }] },
    { "id": "ar_ep_009", "levels": [{ "front": "Your (m.)", "back": "ـكَ", "romanized": "-ka" }, { "front": "What is your name?", "back": "ما اسمُكَ؟", "romanized": "ma ismuka?" }] },
    { "id": "ar_ep_010", "levels": [{ "front": "His / Her", "back": "ـه / ـها", "romanized": "-hu / -ha" }, { "front": "Her house is big.", "back": "بيتها كبير.", "romanized": "baytuha kabir." }] },
    { "id": "ar_ep_011", "levels": [{ "front": "Hello", "back": "مرحباً", "romanized": "marhaban" }, { "front": "Hello! How are you?", "back": "مرحباً! كيف حالك؟", "romanized": "marhaban! kayfa halak?" }] },
    { "id": "ar_ep_012", "levels": [{ "front": "Peace be upon you", "back": "السلام عليكم", "romanized": "as-salamu alaykum", "grammarNote": "The standard Islamic greeting used across the Arabic-speaking world. The response is 'وعليكم السلام' (wa-alaykum as-salam) — 'And upon you peace.'" }, { "front": "Peace be upon you. / And upon you peace.", "back": "السلام عليكم. / وعليكم السلام.", "romanized": "as-salamu alaykum. / wa-alaykum as-salam." }] },
    { "id": "ar_ep_013", "levels": [{ "front": "Good morning", "back": "صباح الخير", "romanized": "sabah al-khayr" }, { "front": "Good morning! (response: Good light!)", "back": "صباح الخير! / صباح النور!", "romanized": "sabah al-khayr! / sabah an-nur!" }] },
    { "id": "ar_ep_014", "levels": [{ "front": "Good evening", "back": "مساء الخير", "romanized": "masa' al-khayr" }, { "front": "Good evening, welcome.", "back": "مساء الخير، أهلاً.", "romanized": "masa' al-khayr, ahlan." }] },
    { "id": "ar_ep_015", "levels": [{ "front": "Good night", "back": "تصبح على خير", "romanized": "tusbih ala khayr" }, { "front": "Good night, see you tomorrow.", "back": "تصبح على خير، إلى اللقاء غداً.", "romanized": "tusbih ala khayr, ila al-liqa' ghadan." }] },
    { "id": "ar_ep_016", "levels": [{ "front": "Welcome", "back": "أهلاً وسهلاً", "romanized": "ahlan wa-sahlan" }, { "front": "Welcome to Cairo!", "back": "أهلاً وسهلاً في القاهرة!", "romanized": "ahlan wa-sahlan fi al-qahira!" }] },
    { "id": "ar_ep_017", "levels": [{ "front": "Goodbye", "back": "مع السلامة", "romanized": "ma' as-salama" }, { "front": "Goodbye, take care.", "back": "مع السلامة، اعتنِ بنفسك.", "romanized": "ma' as-salama, i'tani bi-nafsik." }] },
    { "id": "ar_ep_018", "levels": [{ "front": "See you later", "back": "إلى اللقاء", "romanized": "ila al-liqa'" }, { "front": "See you tomorrow!", "back": "إلى اللقاء غداً!", "romanized": "ila al-liqa' ghadan!" }] },
    { "id": "ar_ep_019", "levels": [{ "front": "How are you? (m.)", "back": "كيف حالك؟", "romanized": "kayfa halak?" }, { "front": "How are you? I'm fine, thank you.", "back": "كيف حالك؟ بخير، شكراً.", "romanized": "kayfa halak? bi-khayr, shukran." }] },
    { "id": "ar_ep_020", "levels": [{ "front": "I'm fine", "back": "بخير", "romanized": "bi-khayr" }, { "front": "I'm fine, praise God.", "back": "بخير، الحمد لله.", "romanized": "bi-khayr, al-hamdulillah." }] },
    { "id": "ar_ep_021", "levels": [{ "front": "Nice to meet you", "back": "يسعدني لقاؤك", "romanized": "yus'iduni liqa'uk" }, { "front": "Nice to meet you, I'm Layla.", "back": "يسعدني لقاؤك، أنا ليلى.", "romanized": "yus'iduni liqa'uk, ana Layla." }] },
    { "id": "ar_ep_022", "levels": [{ "front": "Yes", "back": "نعم", "romanized": "na'am" }, { "front": "Yes, I understand.", "back": "نعم، أفهم.", "romanized": "na'am, afham." }] },
    { "id": "ar_ep_023", "levels": [{ "front": "No", "back": "لا", "romanized": "la" }, { "front": "No, I don't understand.", "back": "لا، لا أفهم.", "romanized": "la, la afham." }] },
    { "id": "ar_ep_024", "levels": [{ "front": "Please (m.)", "back": "من فضلك", "romanized": "min fadlak" }, { "front": "Water, please.", "back": "ماء، من فضلك.", "romanized": "ma', min fadlak." }] },
    { "id": "ar_ep_025", "levels": [{ "front": "Thank you", "back": "شكراً", "romanized": "shukran" }, { "front": "Thank you very much.", "back": "شكراً جزيلاً.", "romanized": "shukran jazilan." }] },
    { "id": "ar_ep_026", "levels": [{ "front": "You're welcome", "back": "عفواً", "romanized": "afwan" }, { "front": "You're welcome, no problem.", "back": "عفواً، لا مشكلة.", "romanized": "afwan, la mushkila." }] },
    { "id": "ar_ep_027", "levels": [{ "front": "Sorry / Excuse me", "back": "آسف / عذراً", "romanized": "asif / adhran" }, { "front": "Sorry, I'm late.", "back": "آسف، أنا متأخر.", "romanized": "asif, ana muta'akhir." }] },
    { "id": "ar_ep_028", "levels": [{ "front": "I don't understand", "back": "لا أفهم", "romanized": "la afham" }, { "front": "I don't understand. Could you repeat?", "back": "لا أفهم. هل يمكنك الإعادة؟", "romanized": "la afham. hal yumkinuka al-i'ada?" }] },
    { "id": "ar_ep_029", "levels": [{ "front": "Please speak slowly", "back": "تكلم ببطء من فضلك", "romanized": "takallam bi-but' min fadlak" }, { "front": "Please speak slowly, I am learning Arabic.", "back": "تكلم ببطء من فضلك، أنا أتعلم العربية.", "romanized": "takallam bi-but' min fadlak, ana ata'allam al-arabiyya." }] },
    { "id": "ar_ep_030", "levels": [{ "front": "What? / What is...?", "back": "ماذا؟ / ما هو؟", "romanized": "matha? / ma huwa?", "grammarNote": "ما (ma) asks about things/definitions: 'ما هذا؟' (What is this?). ماذا (matha) asks about actions: 'ماذا تفعل؟' (What are you doing?)." }, { "front": "What is this? / What are you doing?", "back": "ما هذا؟ / ماذا تفعل؟", "romanized": "ma hadha? / matha taf'al?" }] },
    { "id": "ar_ep_031", "levels": [{ "front": "Who?", "back": "من؟", "romanized": "man?" }, { "front": "Who is that person?", "back": "من هذا الشخص؟", "romanized": "man hadha ash-shakhs?" }] },
    { "id": "ar_ep_032", "levels": [{ "front": "Where?", "back": "أين؟", "romanized": "ayna?" }, { "front": "Where is the bathroom?", "back": "أين الحمام؟", "romanized": "ayna al-hammam?" }] },
    { "id": "ar_ep_033", "levels": [{ "front": "When?", "back": "متى؟", "romanized": "mata?" }, { "front": "When does the store open?", "back": "متى يفتح المتجر؟", "romanized": "mata yaftah al-matjar?" }] },
    { "id": "ar_ep_034", "levels": [{ "front": "Why?", "back": "لماذا؟", "romanized": "limatha?" }, { "front": "Why are you late?", "back": "لماذا أنت متأخر؟", "romanized": "limatha anta muta'akhir?" }] },
    { "id": "ar_ep_035", "levels": [{ "front": "How?", "back": "كيف؟", "romanized": "kayfa?" }, { "front": "How do you say this in Arabic?", "back": "كيف تقول هذا بالعربية؟", "romanized": "kayfa taqul hadha bi-l-arabiyya?" }] },
    { "id": "ar_ep_036", "levels": [{ "front": "How much / How many?", "back": "كم؟", "romanized": "kam?" }, { "front": "How much does this cost?", "back": "كم يكلف هذا؟", "romanized": "kam yukallif hadha?" }] },
    { "id": "ar_ep_037", "levels": [{ "front": "To be (present)", "back": "يكون", "romanized": "yakun", "grammarNote": "Arabic drops the verb 'to be' in present tense. 'The house is big' = البيت كبير (al-bayt kabir) — literally 'the house big'. Past and future use كان (kana) and سيكون (sa-yakun)." }, { "front": "The house is big. (no verb needed in present)", "back": "البيت كبير.", "romanized": "al-bayt kabir." }] },
    { "id": "ar_ep_038", "levels": [{ "front": "To have", "back": "عنده / لديه", "romanized": "indahu / ladayhi", "grammarNote": "Arabic has no verb 'to have'. Use عند (inda) or لدى (lada) + pronoun suffix: عندي (indi) = I have, عندك (indak) = you have, عنده (indahu) = he has." }, { "front": "I have a book. Do you have water?", "back": "عندي كتاب. هل عندك ماء؟", "romanized": "indi kitab. hal indaka ma'?" }] },
    { "id": "ar_ep_039", "levels": [{ "front": "To go", "back": "يذهب", "romanized": "yadhab" }, { "front": "I go to school every day.", "back": "أذهب إلى المدرسة كل يوم.", "romanized": "adhabu ila al-madrasa kull yawm." }] },
    { "id": "ar_ep_040", "levels": [{ "front": "To come", "back": "يأتي", "romanized": "ya'ti" }, { "front": "Where are you coming from?", "back": "من أين تأتي؟", "romanized": "min ayna ta'ti?" }] },
    { "id": "ar_ep_041", "levels": [{ "front": "To want", "back": "يريد", "romanized": "yurid" }, { "front": "I want a coffee, please.", "back": "أريد قهوة، من فضلك.", "romanized": "urid qahwa, min fadlak." }] },
    { "id": "ar_ep_042", "levels": [{ "front": "To need", "back": "يحتاج", "romanized": "yahtaj" }, { "front": "I need help.", "back": "أحتاج إلى مساعدة.", "romanized": "ahtaju ila musa'ada." }] },
    { "id": "ar_ep_043", "levels": [{ "front": "Can / To be able to", "back": "يستطيع", "romanized": "yastati'" }, { "front": "Can you help me?", "back": "هل تستطيع مساعدتي؟", "romanized": "hal tastati' musa'adati?" }] },
    { "id": "ar_ep_044", "levels": [{ "front": "To know (a fact)", "back": "يعرف", "romanized": "ya'rif" }, { "front": "I don't know.", "back": "لا أعرف.", "romanized": "la a'rif." }] },
    { "id": "ar_ep_045", "levels": [{ "front": "To understand", "back": "يفهم", "romanized": "yafham" }, { "front": "Do you understand?", "back": "هل تفهم؟", "romanized": "hal tafham?" }] },
    { "id": "ar_ep_046", "levels": [{ "front": "To think", "back": "يفكر", "romanized": "yufakkir" }, { "front": "I think it's a good idea.", "back": "أعتقد أنه فكرة جيدة.", "romanized": "a'taqidu annahu fikra jayyida." }] },
    { "id": "ar_ep_047", "levels": [{ "front": "To like / to love", "back": "يحب", "romanized": "yuhibb" }, { "front": "I like Arabic. I love Egypt.", "back": "أحب العربية. أحب مصر.", "romanized": "uhibb al-arabiyya. uhibb misr." }] },
    { "id": "ar_ep_048", "levels": [{ "front": "To eat", "back": "يأكل", "romanized": "ya'kul" }, { "front": "I eat rice every day.", "back": "آكل الأرز كل يوم.", "romanized": "akul al-aruzz kull yawm." }] },
    { "id": "ar_ep_049", "levels": [{ "front": "To drink", "back": "يشرب", "romanized": "yashrab" }, { "front": "I drink water every morning.", "back": "أشرب الماء كل صباح.", "romanized": "ashrab al-ma' kull sabah." }] },
    { "id": "ar_ep_050", "levels": [{ "front": "To speak", "back": "يتكلم", "romanized": "yatakallam" }, { "front": "Do you speak Arabic?", "back": "هل تتكلم العربية؟", "romanized": "hal tatakallam al-arabiyya?" }] },
    { "id": "ar_ep_051", "levels": [{ "front": "To see", "back": "يرى", "romanized": "yara" }, { "front": "I can't see anything.", "back": "لا أرى شيئاً.", "romanized": "la ara shay'an." }] },
    { "id": "ar_ep_052", "levels": [{ "front": "To hear", "back": "يسمع", "romanized": "yasma'" }, { "front": "I can't hear you.", "back": "لا أسمعك.", "romanized": "la asma'uk." }] },
    { "id": "ar_ep_053", "levels": [{ "front": "To give", "back": "يعطي", "romanized": "yu'ti" }, { "front": "Give me the menu, please.", "back": "أعطني قائمة الطعام، من فضلك.", "romanized": "a'tini qa'imat at-ta'am, min fadlak." }] },
    { "id": "ar_ep_054", "levels": [{ "front": "To take", "back": "يأخذ", "romanized": "ya'khudh" }, { "front": "Take the bus to the station.", "back": "خذ الحافلة إلى المحطة.", "romanized": "khudh al-hafila ila al-mahatta." }] },
    { "id": "ar_ep_055", "levels": [{ "front": "In / at", "back": "في", "romanized": "fi" }, { "front": "The book is in the bag.", "back": "الكتاب في الحقيبة.", "romanized": "al-kitab fi al-haqiba." }] },
    { "id": "ar_ep_056", "levels": [{ "front": "On", "back": "على", "romanized": "ala" }, { "front": "The keys are on the table.", "back": "المفاتيح على الطاولة.", "romanized": "al-mafatih ala at-tawila." }] },
    { "id": "ar_ep_057", "levels": [{ "front": "To (toward)", "back": "إلى", "romanized": "ila" }, { "front": "I'm going to the market.", "back": "أذهب إلى السوق.", "romanized": "adhabu ila as-suq." }] },
    { "id": "ar_ep_058", "levels": [{ "front": "From", "back": "من", "romanized": "min" }, { "front": "I'm from Jordan.", "back": "أنا من الأردن.", "romanized": "ana min al-urdunn." }] },
    { "id": "ar_ep_059", "levels": [{ "front": "With", "back": "مع", "romanized": "ma'a" }, { "front": "I came with my friend.", "back": "جئت مع صديقي.", "romanized": "ji'tu ma'a sadiqi." }] },
    { "id": "ar_ep_060", "levels": [{ "front": "Without", "back": "بدون", "romanized": "bidun" }, { "front": "Coffee without sugar, please.", "back": "قهوة بدون سكر، من فضلك.", "romanized": "qahwa bidun sukkar, min fadlak." }] },
    { "id": "ar_ep_061", "levels": [{ "front": "For", "back": "ل", "romanized": "li" }, { "front": "This is for you.", "back": "هذا لك.", "romanized": "hadha lak." }] },
    { "id": "ar_ep_062", "levels": [{ "front": "Here", "back": "هنا", "romanized": "huna" }, { "front": "Come here!", "back": "تعال هنا!", "romanized": "ta'al huna!" }] },
    { "id": "ar_ep_063", "levels": [{ "front": "There", "back": "هناك", "romanized": "hunak" }, { "front": "She is over there.", "back": "هي هناك.", "romanized": "hiya hunak." }] },
    { "id": "ar_ep_064", "levels": [{ "front": "And", "back": "و", "romanized": "wa" }, { "front": "Rice and bread.", "back": "أرز وخبز.", "romanized": "aruzz wa khubz." }] },
    { "id": "ar_ep_065", "levels": [{ "front": "Or", "back": "أو", "romanized": "aw" }, { "front": "Tea or coffee?", "back": "شاي أو قهوة؟", "romanized": "shay aw qahwa?" }] },
    { "id": "ar_ep_066", "levels": [{ "front": "But", "back": "لكن", "romanized": "lakin" }, { "front": "I want to go, but I can't.", "back": "أريد الذهاب، لكن لا أستطيع.", "romanized": "urid adh-dhahab, lakin la astati'." }] },
    { "id": "ar_ep_067", "levels": [{ "front": "Because", "back": "لأن", "romanized": "li'anna" }, { "front": "I can't come because I'm tired.", "back": "لا أستطيع المجيء لأنني متعب.", "romanized": "la astati' al-maji' li'annani muta'ab." }] },
    { "id": "ar_ep_068", "levels": [{ "front": "If", "back": "إذا", "romanized": "idha" }, { "front": "If you want, let's go.", "back": "إذا أردت، فلنذهب.", "romanized": "idha aradta, falnadhhab." }] },
    { "id": "ar_ep_069", "levels": [{ "front": "This (m.)", "back": "هذا", "romanized": "hadha", "grammarNote": "هذا (hadha) = this (masculine). هذه (hadhihi) = this (feminine). Arabic nouns are either masculine or feminine, so the demonstrative must agree: 'هذا الكتاب' (this book, m.) vs 'هذه المدرسة' (this school, f.)." }, { "front": "This book is interesting.", "back": "هذا الكتاب مثير للاهتمام.", "romanized": "hadha al-kitab muthir lil-ihtimam." }] },
    { "id": "ar_ep_070", "levels": [{ "front": "That (m.)", "back": "ذلك", "romanized": "dhalika" }, { "front": "That is my house.", "back": "ذلك بيتي.", "romanized": "dhalika bayti." }] },
    { "id": "ar_ep_071", "levels": [{ "front": "Much / many", "back": "كثير", "romanized": "kathir" }, { "front": "I have a lot of work.", "back": "عندي عمل كثير.", "romanized": "indi amal kathir." }] },
    { "id": "ar_ep_072", "levels": [{ "front": "A little", "back": "قليل", "romanized": "qalil" }, { "front": "A little water, please.", "back": "قليل من الماء، من فضلك.", "romanized": "qalil min al-ma', min fadlak." }] },
    { "id": "ar_ep_073", "levels": [{ "front": "More", "back": "أكثر", "romanized": "akthar" }, { "front": "More water, please.", "back": "المزيد من الماء، من فضلك.", "romanized": "al-mazid min al-ma', min fadlak." }] },
    { "id": "ar_ep_074", "levels": [{ "front": "Less", "back": "أقل", "romanized": "aqall" }, { "front": "Less sugar, please.", "back": "سكر أقل، من فضلك.", "romanized": "sukkar aqall, min fadlak." }] },
    { "id": "ar_ep_075", "levels": [{ "front": "Very", "back": "جداً", "romanized": "jiddan" }, { "front": "It's very good.", "back": "إنه جيد جداً.", "romanized": "innahu jayyid jiddan." }] },
    { "id": "ar_ep_076", "levels": [{ "front": "Also / too", "back": "أيضاً", "romanized": "aydan" }, { "front": "I also want one.", "back": "أريد واحداً أيضاً.", "romanized": "urid wahidan aydan." }] },
    { "id": "ar_ep_077", "levels": [{ "front": "Now", "back": "الآن", "romanized": "al-an" }, { "front": "Come now, please.", "back": "تعال الآن، من فضلك.", "romanized": "ta'al al-an, min fadlak." }] },
    { "id": "ar_ep_078", "levels": [{ "front": "Later", "back": "لاحقاً", "romanized": "lahiqan" }, { "front": "See you later.", "back": "أراك لاحقاً.", "romanized": "araka lahiqan." }] },
    { "id": "ar_ep_079", "levels": [{ "front": "Always", "back": "دائماً", "romanized": "da'iman" }, { "front": "I always drink coffee in the morning.", "back": "دائماً أشرب القهوة في الصباح.", "romanized": "da'iman ashrab al-qahwa fi as-sabah." }] },
    { "id": "ar_ep_080", "levels": [{ "front": "Never", "back": "أبداً", "romanized": "abadan" }, { "front": "I never eat meat.", "back": "لا آكل اللحم أبداً.", "romanized": "la akul al-lahm abadan." }] },
    { "id": "ar_ep_081", "levels": [{ "front": "Today", "back": "اليوم", "romanized": "al-yawm" }, { "front": "What are you doing today?", "back": "ماذا ستفعل اليوم؟", "romanized": "matha sataf'al al-yawm?" }] },
