{
  "id": "everyday_phrases",
  "name": "Everyday Phrases",
  "language": "japanese",
  "cards": [
    { "id": "ja_ep_001", "levels": [{ "front": "I", "back": "私", "romanized": "watashi" }, { "front": "I am a student", "back": "私は学生です", "romanized": "watashi wa gakusei desu" }] },
    { "id": "ja_ep_002", "levels": [{ "front": "you", "back": "あなた", "romanized": "anata" }, { "front": "What is your name?", "back": "あなたの名前は何ですか？", "romanized": "anata no namae wa nan desu ka?" }] },
    { "id": "ja_ep_003", "levels": [{ "front": "he", "back": "彼", "romanized": "kare" }, { "front": "He is my friend", "back": "彼は私の友達です", "romanized": "kare wa watashi no tomodachi desu" }] },
    { "id": "ja_ep_004", "levels": [{ "front": "she", "back": "彼女", "romanized": "kanojo" }, { "front": "She speaks Japanese well", "back": "彼女は日本語が上手です", "romanized": "kanojo wa nihongo ga jōzu desu" }] },
    { "id": "ja_ep_005", "levels": [{ "front": "we", "back": "私たち", "romanized": "watashitachi" }, { "front": "We are going to Japan", "back": "私たちは日本に行きます", "romanized": "watashitachi wa nihon ni ikimasu" }] },
    { "id": "ja_ep_006", "levels": [{ "front": "they", "back": "彼ら", "romanized": "karera" }, { "front": "They are from Japan", "back": "彼らは日本人です", "romanized": "karera wa nihonjin desu" }] },
    { "id": "ja_ep_007", "levels": [{ "front": "this", "back": "これ", "romanized": "kore" }, { "front": "What is this?", "back": "これは何ですか？", "romanized": "kore wa nan desu ka?" }] },
    { "id": "ja_ep_008", "levels": [{ "front": "that", "back": "それ", "romanized": "sore" }, { "front": "That is mine", "back": "それは私のです", "romanized": "sore wa watashi no desu" }] },
    { "id": "ja_ep_009", "levels": [{ "front": "here", "back": "ここ", "romanized": "koko" }, { "front": "Please come here", "back": "ここに来てください", "romanized": "koko ni kite kudasai" }] },
    { "id": "ja_ep_010", "levels": [{ "front": "there", "back": "そこ", "romanized": "soko" }, { "front": "The station is over there", "back": "駅はそこにあります", "romanized": "eki wa soko ni arimasu" }] },
    { "id": "ja_ep_011", "levels": [{ "front": "yes", "back": "はい", "romanized": "hai" }, { "front": "Yes, I understand", "back": "はい、わかりました", "romanized": "hai, wakarimashita" }] },
    { "id": "ja_ep_012", "levels": [{ "front": "no", "back": "いいえ", "romanized": "iie" }, { "front": "No, that is not right", "back": "いいえ、それは違います", "romanized": "iie, sore wa chigaimasu" }] },
    { "id": "ja_ep_013", "levels": [{ "front": "please", "back": "お願いします", "romanized": "onegaishimasu" }, { "front": "Water please", "back": "水をお願いします", "romanized": "mizu wo onegaishimasu" }] },
    { "id": "ja_ep_014", "levels": [{ "front": "thank you", "back": "ありがとう", "romanized": "arigatō" }, { "front": "Thank you very much", "back": "どうもありがとうございます", "romanized": "dōmo arigatō gozaimasu" }] },
    { "id": "ja_ep_015", "levels": [{ "front": "you're welcome", "back": "どういたしまして", "romanized": "dōitashimashite" }, { "front": "You're welcome, no problem", "back": "どういたしまして、大丈夫ですよ", "romanized": "dōitashimashite, daijōbu desu yo" }] },
    { "id": "ja_ep_016", "levels": [{ "front": "sorry / excuse me", "back": "すみません", "romanized": "sumimasen" }, { "front": "Excuse me, where is the station?", "back": "すみません、駅はどこですか？", "romanized": "sumimasen, eki wa doko desu ka?" }] },
    { "id": "ja_ep_017", "levels": [{ "front": "hello", "back": "こんにちは", "romanized": "konnichiwa" }, { "front": "Hello, nice to meet you", "back": "こんにちは、はじめまして", "romanized": "konnichiwa, hajimemashite" }] },
    { "id": "ja_ep_018", "levels": [{ "front": "good morning", "back": "おはようございます", "romanized": "ohayō gozaimasu" }, { "front": "Good morning, how are you?", "back": "おはようございます、お元気ですか？", "romanized": "ohayō gozaimasu, ogenki desu ka?" }] },
    { "id": "ja_ep_019", "levels": [{ "front": "good evening", "back": "こんばんは", "romanized": "konbanwa" }, { "front": "Good evening, welcome", "back": "こんばんは、いらっしゃいませ", "romanized": "konbanwa, irasshaimase" }] },
    { "id": "ja_ep_020", "levels": [{ "front": "good night", "back": "おやすみなさい", "romanized": "oyasumi nasai" }, { "front": "Good night, see you tomorrow", "back": "おやすみなさい、また明日", "romanized": "oyasumi nasai, mata ashita" }] },
    { "id": "ja_ep_021", "levels": [{ "front": "goodbye", "back": "さようなら", "romanized": "sayōnara" }, { "front": "Goodbye, take care", "back": "さようなら、気をつけて", "romanized": "sayōnara, ki wo tsukete" }] },
    { "id": "ja_ep_022", "levels": [{ "front": "see you later", "back": "またね", "romanized": "mata ne" }, { "front": "See you tomorrow!", "back": "また明日！", "romanized": "mata ashita!" }] },
    { "id": "ja_ep_023", "levels": [{ "front": "how are you", "back": "お元気ですか", "romanized": "ogenki desu ka" }, { "front": "How are you? I'm fine", "back": "お元気ですか？元気です", "romanized": "ogenki desu ka? genki desu" }] },
    { "id": "ja_ep_024", "levels": [{ "front": "I'm fine", "back": "元気です", "romanized": "genki desu" }, { "front": "I'm fine, thank you", "back": "元気です、ありがとう", "romanized": "genki desu, arigatō" }] },
    { "id": "ja_ep_025", "levels": [{ "front": "my name is", "back": "私の名前は〜です", "romanized": "watashi no namae wa ~ desu" }, { "front": "My name is Jeff", "back": "私の名前はジェフです", "romanized": "watashi no namae wa Jefu desu" }] },
    { "id": "ja_ep_026", "levels": [{ "front": "nice to meet you", "back": "はじめまして", "romanized": "hajimemashite" }, { "front": "Nice to meet you, I'm Jeff", "back": "はじめまして、ジェフです", "romanized": "hajimemashite, Jefu desu" }] },
    { "id": "ja_ep_027", "levels": [{ "front": "what", "back": "何", "romanized": "nani" }, { "front": "What did you say?", "back": "何と言いましたか？", "romanized": "nani to iimashita ka?" }] },
    { "id": "ja_ep_028", "levels": [{ "front": "when", "back": "いつ", "romanized": "itsu" }, { "front": "When does it start?", "back": "いつ始まりますか？", "romanized": "itsu hajimarimasu ka?" }] },
    { "id": "ja_ep_029", "levels": [{ "front": "where", "back": "どこ", "romanized": "doko" }, { "front": "Where is the bathroom?", "back": "トイレはどこですか？", "romanized": "toire wa doko desu ka?" }] },
    { "id": "ja_ep_030", "levels": [{ "front": "who", "back": "誰", "romanized": "dare" }, { "front": "Who is that person?", "back": "あの人は誰ですか？", "romanized": "ano hito wa dare desu ka?" }] },
    { "id": "ja_ep_031", "levels": [{ "front": "why", "back": "なぜ", "romanized": "naze" }, { "front": "Why are you late?", "back": "なぜ遅れたのですか？", "romanized": "naze okureta no desu ka?" }] },
    { "id": "ja_ep_032", "levels": [{ "front": "how", "back": "どう", "romanized": "dō" }, { "front": "How do you say this in Japanese?", "back": "これは日本語でどう言いますか？", "romanized": "kore wa nihongo de dō iimasu ka?" }] },
    { "id": "ja_ep_033", "levels": [{ "front": "how much", "back": "いくら", "romanized": "ikura" }, { "front": "How much does this cost?", "back": "これはいくらですか？", "romanized": "kore wa ikura desu ka?" }] },
    { "id": "ja_ep_034", "levels": [{ "front": "how many", "back": "いくつ", "romanized": "ikutsu" }, { "front": "How many people are coming?", "back": "何人来ますか？", "romanized": "nannin kimasu ka?" }] },
    { "id": "ja_ep_035", "levels": [{ "front": "big", "back": "大きい", "romanized": "ōkii" }, { "front": "Tokyo is a very big city", "back": "東京はとても大きい都市です", "romanized": "Tōkyō wa totemo ōkii toshi desu" }] },
    { "id": "ja_ep_036", "levels": [{ "front": "small", "back": "小さい", "romanized": "chiisai" }, { "front": "This room is small", "back": "この部屋は小さいです", "romanized": "kono heya wa chiisai desu" }] },
