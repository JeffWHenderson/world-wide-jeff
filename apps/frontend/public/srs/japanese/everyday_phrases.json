    { "id": "ja_ep_038", "levels": [{ "front": "a little", "back": "少し", "romanized": "sukoshi" }, { "front": "I speak a little Japanese", "back": "少し日本語が話せます", "romanized": "sukoshi nihongo ga hanasemasu" }] },
    { "id": "ja_ep_039", "levels": [{ "front": "good", "back": "いい", "romanized": "ii" }, { "front": "That's a good idea", "back": "それはいいアイデアです", "romanized": "sore wa ii aidea desu" }] },
    { "id": "ja_ep_040", "levels": [{ "front": "bad", "back": "悪い", "romanized": "warui" }, { "front": "The weather is bad today", "back": "今日は天気が悪いです", "romanized": "kyō wa tenki ga warui desu" }] },
    { "id": "ja_ep_041", "levels": [{ "front": "fast", "back": "速い", "romanized": "hayai" }, { "front": "The train is very fast", "back": "電車はとても速いです", "romanized": "densha wa totemo hayai desu" }] },
    { "id": "ja_ep_042", "levels": [{ "front": "slow", "back": "遅い", "romanized": "osoi" }, { "front": "Please speak more slowly", "back": "もっとゆっくり話してください", "romanized": "motto yukkuri hanashite kudasai" }] },
