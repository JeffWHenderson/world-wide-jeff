    { "id": "es_hb_045", "levels": [{ "front": "palm", "back": "la palma (de la mano)" }, { "front": "She read his palm.", "back": "Ella le leyó la palma de la mano." }] },
    { "id": "es_hb_046", "levels": [{ "front": "knuckle", "back": "el nudillo" }, { "front": "He hurt his knuckle.", "back": "Se lastimó el nudillo." }] },
    { "id": "es_hb_047", "levels": [{ "front": "eyelash", "back": "la pestaña" }, { "front": "She has long eyelashes.", "back": "Ella tiene las pestañas largas." }] },
    { "id": "es_hb_048", "levels": [{ "front": "eyebrow", "back": "la ceja" }, { "front": "He raised his eyebrow.", "back": "Levantó una ceja." }] },
