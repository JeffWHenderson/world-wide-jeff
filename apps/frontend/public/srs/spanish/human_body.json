    { "id": "es_hb_054", "levels": [{ "front": "skeleton", "back": "el esqueleto" }, { "front": "The skeleton has 206 bones.", "back": "El esqueleto tiene 206 huesos." }] },
    { "id": "es_hb_055", "levels": [{ "front": "pulse", "back": "el pulso" }, { "front": "The doctor checked his pulse.", "back": "El médico le tomó el pulso." }] },
    { "id": "es_hb_056", "levels": [{ "front": "breath", "back": "el aliento / la respiración" }, { "front": "Hold your breath.", "back": "Aguanta la respiración." }] },
    { "id": "es_hb_057", "levels": [{ "front": "see", "back": "ver" }, { "front": "I can see clearly.", "back": "Puedo ver con claridad." }] },
    { "id": "es_hb_058", "levels": [{ "front": "hear", "back": "oír / escuchar" }, { "front": "I can't hear you.", "back": "No te escucho." }] },
    { "id": "es_hb_059", "levels": [{ "front": "smell", "back": "oler" }, { "front": "I can smell the flowers.", "back": "Puedo oler las flores." }] },
    { "id": "es_hb_060", "levels": [{ "front": "taste", "back": "saborear / probar" }, { "front": "Taste this soup.", "back": "Prueba esta sopa." }] },
    { "id": "es_hb_061", "levels": [{ "front": "touch", "back": "tocar" }, { "front": "Don't touch that!", "back": "¡No toques eso!" }] },
