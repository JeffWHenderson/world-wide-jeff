    { "id": "es_hb_078", "levels": [{ "front": "bony", "back": "huesudo" }, { "front": "His hands are bony.", "back": "Tiene las manos huesudas." }] },
    { "id": "es_hb_079", "levels": [{ "front": "hairy", "back": "peludo" }, { "front": "He has hairy arms.", "back": "Él tiene los brazos peludos." }] },
    { "id": "es_hb_080", "levels": [{ "front": "smooth", "back": "suave / liso" }, { "front": "Her skin is smooth.", "back": "Ella tiene la piel suave." }] },
    { "id": "es_hb_081", "levels": [{ "front": "rough", "back": "áspero" }, { "front": "His hands are rough.", "back": "Tiene las manos ásperas." }] },
    { "id": "es_hb_082", "levels": [{ "front": "soft", "back": "suave / blando" }, { "front": "The tissue is soft.", "back": "El tejido es suave." }] },
    { "id": "es_hb_083", "levels": [{ "front": "firm", "back": "firme" }, { "front": "The muscles are firm.", "back": "Los músculos están firmes." }] },
    { "id": "es_hb_084", "levels": [{ "front": "tender", "back": "tierno / sensible" }, { "front": "The area is tender.", "back": "La zona está sensible." }] },
    { "id": "es_hb_085", "levels": [{ "front": "sore", "back": "dolorido" }, { "front": "My muscles are sore.", "back": "Tengo los músculos doloridos." }] },
    { "id": "es_hb_086", "levels": [{ "front": "numb", "back": "entumecido" }, { "front": "My foot is numb.", "back": "Tengo el pie entumecido." }] },
    { "id": "es_hb_087", "levels": [{ "front": "internal", "back": "interno" }, { "front": "It's an internal injury.", "back": "Es una lesión interna." }] },
