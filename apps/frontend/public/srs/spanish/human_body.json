    { "id": "es_hb_092", "levels": [{ "front": "lower", "back": "inferior" }, { "front": "He has lower back pain.", "back": "Él tiene dolor en la parte inferior de la espalda." }] },
    { "id": "es_hb_093", "levels": [{ "front": "my (my arm)", "back": "mi" }, { "front": "This is my arm.", "back": "Este es mi brazo." }] },
