    { "id": "es_hb_065", "levels": [{ "front": "digest", "back": "digerir" }, { "front": "This food is easy to digest.", "back": "Esta comida es fácil de digerir." }] },
    { "id": "es_hb_066", "levels": [{ "front": "pump (heart pumps blood)", "back": "bombear" }, { "front": "The heart pumps blood.", "back": "El corazón bombea sangre." }] },
    { "id": "es_hb_067", "levels": [{ "front": "bend", "back": "doblar" }, { "front": "Bend your knees.", "back": "Dobla las rodillas." }] },
    { "id": "es_hb_068", "levels": [{ "front": "stretch", "back": "estirar" }, { "front": "Stretch your arms.", "back": "Estira los brazos." }] },
    { "id": "es_hb_069", "levels": [{ "front": "flex", "back": "flexionar" }, { "front": "Flex your muscles.", "back": "Flexiona los músculos." }] },
    { "id": "es_hb_070", "levels": [{ "front": "blink", "back": "parpadear" }, { "front": "Don't blink.", "back": "No parpadees." }] },
    { "id": "es_hb_071", "levels": [{ "front": "sweat", "back": "sudar" }, { "front": "I sweat when I run.", "back": "Sudo cuando corro." }] },
    { "id": "es_hb_072", "levels": [{ "front": "bleed", "back": "sangrar" }, { "front": "The wound is bleeding.", "back": "La herida está sangrando." }] },
    { "id": "es_hb_073", "levels": [{ "front": "heal", "back": "curar / sanar" }, { "front": "The wound is healing.", "back": "La herida está sanando." }] },
    { "id": "es_hb_074", "levels": [{ "front": "feel", "back": "sentir" }, { "front": "How do you feel?", "back": "¿Cómo te sientes?" }] },
    { "id": "es_hb_075", "levels": [{ "front": "think", "back": "pensar", "grammarNote": "Pensar is an e→ie stem-changing verb: pienso, piensas, piensa, pensamos, pensáis, piensan. The stem changes in all forms except nosotros/vosotros. Other common e→ie verbs: querer (quiero), entender (entiendo), empezar (empiezo), perder (pierdo)." }, { "front": "What are you thinking about?", "back": "¿En qué piensas?" }] },
    { "id": "es_hb_076", "levels": [{ "front": "move", "back": "mover / moverse" }, { "front": "I can't move my arm.", "back": "No puedo mover el brazo." }] },
