{
  "id": "everyday_phrases",
  "name": "Everyday Phrases",
  "language": "spanish",
  "stories": ["morning_routine", "meeting_a_friend", "making_plans", "meet_jeff", "meet_seth", "bad_bunny"],
  "cards": [
    { "id": "es_ep_001", "levels": [{ "front": "I", "back": "yo" }, { "front": "I am a student.", "back": "Yo soy estudiante." }] },
    { "id": "es_ep_002", "levels": [{ "front": "You (singular)", "back": "tú" }, { "front": "You speak Spanish well.", "back": "Tú hablas bien el español." }] },
    { "id": "es_ep_003", "levels": [{ "front": "He", "back": "él" }, { "front": "He is my friend.", "back": "Él es mi amigo." }] },
    { "id": "es_ep_004", "levels": [{ "front": "She", "back": "ella" }, { "front": "She works here.", "back": "Ella trabaja aquí." }] },
    { "id": "es_ep_005", "levels": [{ "front": "It", "back": "ello / lo" }] },
    { "id": "es_ep_006", "levels": [{ "front": "We", "back": "nosotros" }, { "front": "We live here.", "back": "Nosotros vivimos aquí." }] },
    { "id": "es_ep_007", "levels": [{ "front": "They", "back": "ellos" }, { "front": "They eat together.", "back": "Ellos comen juntos." }] },
    { "id": "es_ep_008", "levels": [{ "front": "My", "back": "mi" }, { "front": "My name is Carlos.", "back": "Mi nombre es Carlos." }] },
    { "id": "es_ep_009", "levels": [{ "front": "Your", "back": "tu" }, { "front": "What is your name?", "back": "¿Cuál es tu nombre?" }] },
    { "id": "es_ep_010", "levels": [{ "front": "His / Her", "back": "su" }, { "front": "Her house is big.", "back": "Su casa es grande." }] },
    { "id": "es_ep_011", "levels": [{ "front": "Our", "back": "nuestro" }, { "front": "Our teacher is kind.", "back": "Nuestro profesor es amable." }] },
    { "id": "es_ep_012", "levels": [{ "front": "Their", "back": "su" }, { "front": "Their dog is friendly.", "back": "Su perro es amigable." }] },
    { "id": "es_ep_013", "levels": [{ "front": "Who", "back": "quién" }, { "front": "Who is that person?", "back": "¿Quién es esa persona?" }] },
    { "id": "es_ep_014", "levels": [{ "front": "What", "back": "qué" }, { "front": "What do you want?", "back": "¿Qué quieres?" }] },
    { "id": "es_ep_015", "levels": [{ "front": "To be", "back": "ser / estar", "grammarNote": "Ser: permanent traits, identity, profession, origin. Estar: temporary states, location, feelings. E.g., 'Soy médico' (I am a doctor) vs 'Estoy cansado' (I am tired)." }, { "front": "I am a teacher. I am tired today.", "back": "Soy profesora. Estoy cansada hoy." }] },
    { "id": "es_ep_016", "levels": [{ "front": "To have", "back": "tener", "grammarNote": "Tener is also used for physical states: tener hambre (to be hungry), tener sed (to be thirsty), tener frío/calor (to be cold/hot), tener miedo (to be afraid)." }, { "front": "I'm hungry. Do you have water?", "back": "Tengo hambre. ¿Tienes agua?" }] },
    { "id": "es_ep_017", "levels": [{ "front": "To do / make", "back": "hacer" }, { "front": "What are you doing?", "back": "¿Qué haces?" }] },
    { "id": "es_ep_018", "levels": [{ "front": "To go", "back": "ir", "grammarNote": "Ir a + infinitive = going to do something. Also: a + el contracts to al. 'Voy al mercado' (not 'a el mercado'). 'Voy a comer' = I'm going to eat." }, { "front": "I'm going to the store.", "back": "Voy a la tienda." }] },
    { "id": "es_ep_019", "levels": [{ "front": "To come", "back": "venir" }, { "front": "Where are you coming from?", "back": "¿De dónde vienes?" }] },
    { "id": "es_ep_020", "levels": [{ "front": "To want", "back": "querer", "grammarNote": "Querer stem-changes e→ie: yo quiero, tú quieres, él quiere." }, { "front": "I want a coffee, please.", "back": "Quiero un café, por favor." }] },
    { "id": "es_ep_021", "levels": [{ "front": "To need", "back": "necesitar" }, { "front": "I need help.", "back": "Necesito ayuda." }] },
    { "id": "es_ep_022", "levels": [{ "front": "Can (to be able to)", "back": "poder", "grammarNote": "Poder stem-changes o→ue: yo puedo, tú puedes, él puede." }, { "front": "Can you help me?", "back": "¿Puedes ayudarme?" }] },
    { "id": "es_ep_023", "levels": [{ "front": "To know (a fact)", "back": "saber", "grammarNote": "Saber = to know a fact or skill. Irregular first person: yo sé. 'Sé hablar inglés' = I know how to speak English." }, { "front": "I don't know.", "back": "No sé." }] },
    { "id": "es_ep_024", "levels": [{ "front": "To know (a person)", "back": "conocer", "grammarNote": "Conocer = to know a person or be familiar with a place. Irregular first person: yo conozco. Requires personal 'a' before a person: 'Conozco a María'." }, { "front": "Do you know this city?", "back": "¿Conoces esta ciudad?" }] },
    { "id": "es_ep_025", "levels": [{ "front": "To think", "back": "pensar", "grammarNote": "Pensar stem-changes e→ie: yo pienso, tú piensas, él piensa." }, { "front": "I think it's a good idea.", "back": "Pienso que es una buena idea." }] },
    { "id": "es_ep_026", "levels": [{ "front": "To like", "back": "gustar", "grammarNote": "Gustar works in reverse: the thing liked is the subject. 'Me gusta el café' = coffee pleases me = I like coffee. Singular: me gusta. Plural: me gustan ('Me gustan las frutas')." }, { "front": "I like coffee. I like books.", "back": "Me gusta el café. Me gustan los libros." }] },
    { "id": "es_ep_027", "levels": [{ "front": "To love", "back": "amar" }, { "front": "I love you.", "back": "Te amo." }] },
    { "id": "es_ep_028", "levels": [{ "front": "To eat", "back": "comer" }, { "front": "I eat rice every day.", "back": "Como arroz todos los días." }] },
    { "id": "es_ep_029", "levels": [{ "front": "To drink", "back": "beber" }, { "front": "I drink water every morning.", "back": "Bebo agua cada mañana." }] },
    { "id": "es_ep_030", "levels": [{ "front": "To sleep", "back": "dormir", "grammarNote": "Dormir stem-changes o→ue: yo duermo, tú duermes, él duerme." }, { "front": "I sleep eight hours a night.", "back": "Duermo ocho horas por noche." }] },
    { "id": "es_ep_031", "levels": [{ "front": "To see", "back": "ver" }, { "front": "I can't see anything.", "back": "No puedo ver nada." }] },
    { "id": "es_ep_032", "levels": [{ "front": "To hear", "back": "oír" }, { "front": "I can't hear you.", "back": "No te puedo oír." }] },
    { "id": "es_ep_033", "levels": [{ "front": "To listen", "back": "escuchar" }, { "front": "Listen to me, please.", "back": "Escúchame, por favor." }] },
    { "id": "es_ep_034", "levels": [{ "front": "To speak (to talk)", "back": "hablar" }, { "front": "Do you speak Spanish?", "back": "¿Hablas español?" }] },
    { "id": "es_ep_035", "levels": [{ "front": "To give", "back": "dar" }, { "front": "Give me the menu, please.", "back": "Dame el menú, por favor." }] },
    { "id": "es_ep_036", "levels": [{ "front": "To take", "back": "tomar / llevar" }, { "front": "Take the bus to the station.", "back": "Toma el autobús hasta la estación." }] },
    { "id": "es_ep_037", "levels": [{ "front": "In / on / at", "back": "en" }, { "front": "The book is on the table.", "back": "El libro está en la mesa." }] },
    { "id": "es_ep_038", "levels": [{ "front": "Inside", "back": "dentro" }, { "front": "The cat is inside the house.", "back": "El gato está dentro de la casa." }] },
    { "id": "es_ep_039", "levels": [{ "front": "On top of", "back": "en / sobre" }, { "front": "The keys are on the table.", "back": "Las llaves están sobre la mesa." }] },
    { "id": "es_ep_040", "levels": [{ "front": "To (towards)", "back": "a" }, { "front": "I'm going to the park.", "back": "Voy al parque." }] },
    { "id": "es_ep_041", "levels": [{ "front": "From", "back": "de / desde" }, { "front": "I'm from Mexico.", "back": "Soy de México." }] },
    { "id": "es_ep_042", "levels": [{ "front": "With", "back": "con" }, { "front": "I came with my friend.", "back": "Vine con mi amigo." }] },
    { "id": "es_ep_043", "levels": [{ "front": "Without", "back": "sin" }, { "front": "Coffee without sugar, please.", "back": "Café sin azúcar, por favor." }] },
    { "id": "es_ep_044", "levels": [{ "front": "For", "back": "para / por", "grammarNote": "Para = purpose or destination ('un regalo para ti' = a gift for you). Por = cause, exchange, or duration ('gracias por tu ayuda' = thanks for your help)." }, { "front": "This is for you. Thank you for everything.", "back": "Esto es para ti. Gracias por todo." }] },
    { "id": "es_ep_045", "levels": [{ "front": "Of", "back": "de" }, { "front": "A glass of water.", "back": "Un vaso de agua." }] },
    { "id": "es_ep_046", "levels": [{ "front": "Here", "back": "aquí" }, { "front": "Come here!", "back": "¡Ven aquí!" }] },
    { "id": "es_ep_047", "levels": [{ "front": "There", "back": "allí / allá" }, { "front": "She's over there.", "back": "Ella está allá." }] },
    { "id": "es_ep_049", "levels": [{ "front": "Over", "back": "sobre" }] },
    { "id": "es_ep_050", "levels": [{ "front": "Below", "back": "debajo" }] },
    { "id": "es_ep_051", "levels": [{ "front": "Under", "back": "bajo" }] },
    { "id": "es_ep_052", "levels": [{ "front": "Near / close to", "back": "cerca" }, { "front": "The bank is nearby.", "back": "El banco está cerca." }] },
    { "id": "es_ep_053", "levels": [{ "front": "Far", "back": "lejos" }, { "front": "Is it far from here?", "back": "¿Está lejos de aquí?" }] },
    { "id": "es_ep_054", "levels": [{ "front": "Where", "back": "dónde" }, { "front": "Where is the bathroom?", "back": "¿Dónde está el baño?" }] },
    { "id": "es_ep_055", "levels": [{ "front": "When", "back": "cuándo" }, { "front": "When does the store open?", "back": "¿Cuándo abre la tienda?" }] },
    { "id": "es_ep_056", "levels": [{ "front": "Why", "back": "por qué" }, { "front": "Why are you late?", "back": "¿Por qué llegas tarde?" }] },
    { "id": "es_ep_057", "levels": [{ "front": "How", "back": "cómo" }, { "front": "How are you?", "back": "¿Cómo estás?" }] },
    { "id": "es_ep_058", "levels": [{ "front": "Which", "back": "cuál / que" }, { "front": "Which do you prefer?", "back": "¿Cuál prefieres?" }] },
    { "id": "es_ep_059", "levels": [{ "front": "And", "back": "y" }, { "front": "Rice and beans.", "back": "Arroz y frijoles." }] },
    { "id": "es_ep_060", "levels": [{ "front": "Or", "back": "o" }, { "front": "Tea or coffee?", "back": "¿Té o café?" }] },
    { "id": "es_ep_061", "levels": [{ "front": "But", "back": "pero" }, { "front": "I want to go, but I can't.", "back": "Quiero ir, pero no puedo." }] },
    { "id": "es_ep_062", "levels": [{ "front": "Because", "back": "porque" }, { "front": "I can't come because I'm tired.", "back": "No puedo venir porque estoy cansado." }] },
    { "id": "es_ep_063", "levels": [{ "front": "If", "back": "si" }, { "front": "If you want, let's go.", "back": "Si quieres, vamos." }] },
    { "id": "es_ep_064", "levels": [{ "front": "That / which", "back": "que" }, { "front": "I think that it's good.", "back": "Pienso que es bueno." }] },
    { "id": "es_ep_065", "levels": [{ "front": "This", "back": "este / esta", "grammarNote": "Este (masc.) / esta (fem.) for 'this'. Neutral form: esto (for unknown/abstract). E.g., 'este libro' vs 'esta mesa' vs '¿Qué es esto?'" }, { "front": "This book is interesting.", "back": "Este libro es interesante." }] },
    { "id": "es_ep_066", "levels": [{ "front": "That (over there)", "back": "ese / esa / aquel" }] },
    { "id": "es_ep_067", "levels": [{ "front": "All", "back": "todo" }, { "front": "I ate everything.", "back": "Comí todo." }] },
    { "id": "es_ep_068", "levels": [{ "front": "Nothing / none", "back": "nada / ninguno" }, { "front": "I have nothing.", "back": "No tengo nada." }] },
    { "id": "es_ep_069", "levels": [{ "front": "The good (one)", "back": "el bueno / lo bueno" }, { "front": "The good news is...", "back": "Lo bueno es que..." }] },
    { "id": "es_ep_070", "levels": [{ "front": "The bad (one)", "back": "el malo / lo malo" }, { "front": "The bad thing is the price.", "back": "Lo malo es el precio." }] },
    { "id": "es_ep_071", "levels": [{ "front": "The big one", "back": "el grande / la grande" }, { "front": "Give me the big one.", "back": "Dame el grande." }] },
    { "id": "es_ep_072", "levels": [{ "front": "The small one", "back": "el pequeño / la pequeña" }, { "front": "I prefer the small one.", "back": "Prefiero el pequeño." }] },
    { "id": "es_ep_073", "levels": [{ "front": "The hot (thing)", "back": "el caliente / la caliente" }] },
    { "id": "es_ep_074", "levels": [{ "front": "The cold (thing)", "back": "el frío / la fría" }] },
    { "id": "es_ep_075", "levels": [{ "front": "The new one", "back": "el nuevo / la nueva" }, { "front": "I bought the new one.", "back": "Compré el nuevo." }] },
    { "id": "es_ep_076", "levels": [{ "front": "The old one", "back": "el viejo / la vieja" }] },
    { "id": "es_ep_077", "levels": [{ "front": "The open one", "back": "el abierto / la abierta" }] },
    { "id": "es_ep_078", "levels": [{ "front": "The closed one", "back": "el cerrado / la cerrada" }] },
    { "id": "es_ep_079", "levels": [{ "front": "Much (many)", "back": "mucho" }, { "front": "I have a lot of work.", "back": "Tengo mucho trabajo." }] },
    { "id": "es_ep_080", "levels": [{ "front": "A little", "back": "un poco" }, { "front": "A little water, please.", "back": "Un poco de agua, por favor." }] },
    { "id": "es_ep_081", "levels": [{ "front": "A few", "back": "unos pocos" }, { "front": "Wait a few minutes.", "back": "Espera unos pocos minutos." }] },
    { "id": "es_ep_082", "levels": [{ "front": "More", "back": "más" }, { "front": "More water, please.", "back": "Más agua, por favor." }] },
    { "id": "es_ep_083", "levels": [{ "front": "Less", "back": "menos" }, { "front": "Less salt, please.", "back": "Menos sal, por favor." }] },
    { "id": "es_ep_084", "levels": [{ "front": "Very", "back": "muy" }, { "front": "It's very good.", "back": "Está muy bien." }] },
    { "id": "es_ep_085", "levels": [{ "front": "Also (too)", "back": "también" }, { "front": "I also want one.", "back": "Yo también quiero uno." }] },
    { "id": "es_ep_086", "levels": [{ "front": "Now", "back": "ahora" }, { "front": "Come now, please.", "back": "Ven ahora, por favor." }] },
    { "id": "es_ep_087", "levels": [{ "front": "Then", "back": "entonces" }, { "front": "Then, what do we do?", "back": "Entonces, ¿qué hacemos?" }] },
    { "id": "es_ep_088", "levels": [{ "front": "Later", "back": "luego" }, { "front": "See you later.", "back": "Hasta luego." }] },
    { "id": "es_ep_089", "levels": [{ "front": "Always", "back": "siempre" }, { "front": "I always drink coffee in the morning.", "back": "Siempre tomo café por la mañana." }] },
    { "id": "es_ep_090", "levels": [{ "front": "Never", "back": "nunca" }, { "front": "I never eat meat.", "back": "Nunca como carne." }] },
    { "id": "es_ep_091", "levels": [{ "front": "The person", "back": "la persona" }, { "front": "That person is my teacher.", "back": "Esa persona es mi profesora." }] },
    { "id": "es_ep_092", "levels": [{ "front": "The people", "back": "la gente" }, { "front": "The people here are very friendly.", "back": "La gente aquí es muy amable." }] },
    { "id": "es_ep_093", "levels": [{ "front": "The thing", "back": "la cosa" }, { "front": "What is that thing?", "back": "¿Qué es esa cosa?" }] },
    { "id": "es_ep_094", "levels": [{ "front": "The time", "back": "el tiempo / la vez" }, { "front": "What time is it?", "back": "¿Qué hora es?" }] },
    { "id": "es_ep_095", "levels": [{ "front": "The day", "back": "el día" }, { "front": "Good morning!", "back": "¡Buenos días!" }] },
    { "id": "es_ep_096", "levels": [{ "front": "The night", "back": "la noche" }, { "front": "Good night!", "back": "¡Buenas noches!" }] },
    { "id": "es_ep_097", "levels": [{ "front": "The water", "back": "el agua", "grammarNote": "Agua is feminine but uses 'el' in singular because it begins with a stressed 'a'. Adjectives still agree feminine: 'el agua fría'. Plural: las aguas." }, { "front": "The water is cold.", "back": "El agua está fría." }] },
    { "id": "es_ep_098", "levels": [{ "front": "The food", "back": "la comida" }, { "front": "The food is delicious.", "back": "La comida está deliciosa." }] },
    { "id": "es_ep_099", "levels": [{ "front": "The house (home)", "back": "la casa / el hogar" }, { "front": "My house is nearby.", "back": "Mi casa está cerca." }] },
    { "id": "es_ep_100", "levels": [{ "front": "The store (shop)", "back": "la tienda" }, { "front": "The store is closed.", "back": "La tienda está cerrada." }] },
    { "id": "es_ep_101", "levels": [{ "front": "The money", "back": "el dinero" }, { "front": "I don't have money.", "back": "No tengo dinero." }] },
    { "id": "es_ep_102", "levels": [{ "front": "The name", "back": "el nombre" }, { "front": "My name is Ana.", "back": "Mi nombre es Ana." }] },
    { "id": "es_ep_103", "levels": [{ "front": "The language", "back": "el idioma (el lenguaje)" }, { "front": "What language do you speak?", "back": "¿Qué idioma hablas?" }] },
    { "id": "es_ep_104", "levels": [{ "front": "The help", "back": "la ayuda" }, { "front": "I need your help.", "back": "Necesito tu ayuda." }] },
    { "id": "es_ep_105", "levels": [{ "front": "The problem", "back": "el problema" }, { "front": "There's no problem.", "back": "No hay problema." }] },
    { "id": "es_ep_106", "levels": [{ "front": "The bathroom", "back": "el baño" }, { "front": "Where is the bathroom?", "back": "¿Dónde está el baño?" }] },
    { "id": "es_ep_107", "levels": [{ "front": "The toilet", "back": "el inodoro" }] }
  ]
}
