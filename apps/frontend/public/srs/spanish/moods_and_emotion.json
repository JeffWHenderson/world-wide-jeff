    { "id": "es_me_111", "levels": [{ "front": "tense", "back": "tenso" }, { "front": "The atmosphere was tense.", "back": "El ambiente estaba tenso." }] },
    { "id": "es_me_112", "levels": [{ "front": "stressed", "back": "estresado" }, { "front": "I'm very stressed this week.", "back": "Estoy muy estresado esta semana." }] },
    { "id": "es_me_113", "levels": [{ "front": "overwhelmed", "back": "abrumado" }, { "front": "I feel overwhelmed by the work.", "back": "Me siento abrumado por el trabajo." }] },
    { "id": "es_me_114", "levels": [{ "front": "energetic", "back": "energético" }, { "front": "She is very energetic.", "back": "Ella es muy energética." }] },
    { "id": "es_me_115", "levels": [{ "front": "tired", "back": "cansado", "grammarNote": "Adverb form: cansadamente (tiredly / wearily). Feminine: cansada + mente → cansadamente. E.g., 'Arrastró los pies cansadamente.' (He dragged his feet wearily.)" }, { "front": "I'm very tired today.", "back": "Estoy muy cansado hoy." }] },
    { "id": "es_me_116", "levels": [{ "front": "exhausted", "back": "agotado" }, { "front": "I'm exhausted after the run.", "back": "Estoy agotado después de correr." }] },
    { "id": "es_me_117", "levels": [{ "front": "bored", "back": "aburrido" }, { "front": "I'm bored, let's do something.", "back": "Estoy aburrido, hagamos algo." }] },
