    { "id": "es_me_119", "levels": [{ "front": "curious", "back": "curioso" }, { "front": "I'm curious about that.", "back": "Estoy curioso por eso." }] },
    { "id": "es_me_120", "levels": [{ "front": "surprised", "back": "sorprendido" }, { "front": "I was surprised by the result.", "back": "Estaba sorprendido por el resultado." }] },
    { "id": "es_me_121", "levels": [{ "front": "shocked", "back": "conmocionado" }, { "front": "Everyone was shocked by the news.", "back": "Todos estaban conmocionados por la noticia." }] },
