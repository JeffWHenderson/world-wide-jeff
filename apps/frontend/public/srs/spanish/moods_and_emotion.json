    { "id": "es_me_109", "levels": [{ "front": "calm", "back": "tranquilo", "grammarNote": "Adverb form: tranquilamente (calmly). Feminine: tranquila + mente → tranquilamente. E.g., 'Respondió tranquilamente.' (She answered calmly.)" }, { "front": "Stay calm, everything is fine.", "back": "Mantente tranquilo, todo está bien." }] },
