    { "id": "es_me_086", "levels": [{ "front": "sad (afflicted)", "back": "afligido" }, { "front": "He looked very sad.", "back": "Él parecía muy afligido." }] },
    { "id": "es_me_087", "levels": [{ "front": "angry", "back": "enojado", "grammarNote": "Adverb form: enojadamente (angrily). Use the feminine: enojada + mente → enojadamente. E.g., 'Respondió enojadamente.' (She answered angrily.)" }, { "front": "I'm angry with you.", "back": "Estoy enojado contigo." }] },
    { "id": "es_me_088", "levels": [{ "front": "mad", "back": "enfadado" }, { "front": "Why are you so mad?", "back": "¿Por qué estás tan enfadado?" }] },
    { "id": "es_me_089", "levels": [{ "front": "afraid / scared", "back": "asustado" }, { "front": "The child was scared.", "back": "El niño estaba asustado." }] },
    { "id": "es_me_091", "levels": [{ "front": "fearful", "back": "temeroso" }, { "front": "He is fearful of change.", "back": "Él es temeroso del cambio." }] },
    { "id": "es_me_092", "levels": [{ "front": "anxious", "back": "ansioso", "grammarNote": "Adverb form: ansiosamente (anxiously). Feminine: ansiosa + mente → ansiosamente. E.g., 'Esperaba ansiosamente.' (She was waiting anxiously.)" }, { "front": "I'm anxious about the exam.", "back": "Estoy ansioso por el examen." }] },
    { "id": "es_me_093", "levels": [{ "front": "nervous", "back": "nervioso", "grammarNote": "Adverb form: nerviosamente (nervously). Feminine: nerviosa + mente → nerviosamente. E.g., 'Habló nerviosamente.' (He spoke nervously.)" }, { "front": "I'm nervous today.", "back": "Estoy nervioso hoy." }] },
    { "id": "es_me_094", "levels": [{ "front": "excited", "back": "emocionado", "grammarNote": "Adverb form: emocionadamente (excitedly). Feminine: emocionada + mente → emocionadamente. E.g., 'Gritó emocionadamente.' (She shouted excitedly.)" }, { "front": "I'm excited about the trip.", "back": "Estoy emocionado por el viaje." }] },
    { "id": "es_me_095", "levels": [{ "front": "joyful / cheerful", "back": "alegre" }, { "front": "She is always cheerful.", "back": "Ella siempre está alegre." }] },
    { "id": "es_me_097", "levels": [{ "front": "depressed", "back": "deprimido" }, { "front": "I've been feeling depressed lately.", "back": "Me he sentido deprimido últimamente." }] },
    { "id": "es_me_098", "levels": [{ "front": "gloomy", "back": "sombrío" }, { "front": "He has a gloomy outlook.", "back": "Él tiene una perspectiva sombría." }] },
    { "id": "es_me_099", "levels": [{ "front": "miserable", "back": "miserable" }, { "front": "I felt miserable all day.", "back": "Me sentí miserable todo el día." }] },
    { "id": "es_me_100", "levels": [{ "front": "ecstatic", "back": "extático" }, { "front": "She was ecstatic when she passed.", "back": "Estaba extática cuando aprobó." }] },
    { "id": "es_me_102", "levels": [{ "front": "proud", "back": "orgulloso", "grammarNote": "Adverb form: orgullosamente (proudly). Feminine: orgullosa + mente → orgullosamente. E.g., 'Sonrió orgullosamente.' (She smiled proudly.)" }, { "front": "I'm proud of you.", "back": "Estoy orgulloso de ti." }] },
    { "id": "es_me_103", "levels": [{ "front": "ashamed", "back": "avergonzado" }, { "front": "I felt ashamed of my mistake.", "back": "Me sentí avergonzado de mi error." }] },
    { "id": "es_me_104", "levels": [{ "front": "guilty", "back": "culpable" }, { "front": "He felt guilty.", "back": "Él se sentía culpable." }] },
    { "id": "es_me_105", "levels": [{ "front": "jealous", "back": "celoso" }, { "front": "He gets jealous easily.", "back": "Él se pone celoso fácilmente." }] },
    { "id": "es_me_106", "levels": [{ "front": "envious", "back": "envidioso" }, { "front": "Don't be envious of others.", "back": "No seas envidioso de los demás." }] },
    { "id": "es_me_107", "levels": [{ "front": "content / contented", "back": "contento" }, { "front": "I'm content with my life.", "back": "Estoy contento con mi vida." }] },
