{
  "id": "moods_and_emotion",
  "name": "Moods & Emotion",
  "language": "spanish",
  "cards": [
    { "id": "es_me_001", "levels": [{ "front": "happy", "back": "feliz", "grammarNote": "Adverb form: felizmente (happily). Spanish adverbs are made by adding -mente to the feminine adjective. Feliz has no gender change: feliz + mente → felizmente. E.g., 'Ella sonrió felizmente.' (She smiled happily.)" }, { "front": "I'm very happy today.", "back": "Estoy muy feliz hoy." }] },
    { "id": "es_me_002", "levels": [{ "front": "sad", "back": "triste", "grammarNote": "Adverb form: tristemente (sadly). Triste has no gender change: triste + mente → tristemente. E.g., 'Habló tristemente.' (He spoke sadly.)" }, { "front": "Why are you sad?", "back": "¿Por qué estás triste?" }] },
    { "id": "es_me_003", "levels": [{ "front": "love", "back": "amor" }, { "front": "I feel a lot of love for my family.", "back": "Siento mucho amor por mi familia." }] },
    { "id": "es_me_004", "levels": [{ "front": "joy", "back": "alegría" }, { "front": "Her news filled me with joy.", "back": "Su noticia me llenó de alegría." }] },
    { "id": "es_me_005", "levels": [{ "front": "anger", "back": "ira" }, { "front": "I felt anger when they lied to me.", "back": "Sentí ira cuando me mintieron." }] },
    { "id": "es_me_006", "levels": [{ "front": "fear", "back": "miedo" }, { "front": "I'm afraid of the dark.", "back": "Tengo miedo de la oscuridad." }] },
    { "id": "es_me_007", "levels": [{ "front": "hope", "back": "esperanza" }, { "front": "I have hope for the future.", "back": "Tengo esperanza en el futuro." }] },
    { "id": "es_me_008", "levels": [{ "front": "stress", "back": "estrés" }, { "front": "I have a lot of stress at work.", "back": "Tengo mucho estrés en el trabajo." }] },
    { "id": "es_me_009", "levels": [{ "front": "mood", "back": "estado de ánimo" }, { "front": "I'm in a good mood today.", "back": "Hoy estoy de buen estado de ánimo." }] },
    { "id": "es_me_010", "levels": [{ "front": "feeling", "back": "sentimiento" }, { "front": "That feeling is normal.", "back": "Ese sentimiento es normal." }] },
    { "id": "es_me_011", "levels": [{ "front": "emotion / excitement", "back": "emoción" }, { "front": "I couldn't hide my emotion.", "back": "No pude ocultar mi emoción." }] },
    { "id": "es_me_013", "levels": [{ "front": "pride", "back": "orgullo" }, { "front": "He finished with pride.", "back": "Terminó con orgullo." }] },
    { "id": "es_me_014", "levels": [{ "front": "shame", "back": "vergüenza" }, { "front": "I felt shame for what I did.", "back": "Sentí vergüenza por lo que hice." }] },
    { "id": "es_me_015", "levels": [{ "front": "guilt", "back": "culpa" }, { "front": "I feel guilt about that.", "back": "Siento culpa por eso." }] },
    { "id": "es_me_016", "levels": [{ "front": "envy", "back": "envidia" }, { "front": "I feel envy when I see his success.", "back": "Siento envidia cuando veo su éxito." }] },
    { "id": "es_me_017", "levels": [{ "front": "jealousy", "back": "celos" }, { "front": "He felt jealousy.", "back": "Él sintió celos." }] },
    { "id": "es_me_018", "levels": [{ "front": "calm", "back": "calma" }, { "front": "Try to maintain your calm.", "back": "Intenta mantener la calma." }] },
    { "id": "es_me_019", "levels": [{ "front": "peace", "back": "paz" }, { "front": "I need peace and quiet.", "back": "Necesito paz y tranquilidad." }] },
    { "id": "es_me_020", "levels": [{ "front": "anxiety", "back": "ansiedad" }, { "front": "I struggle with anxiety.", "back": "Lucho contra la ansiedad." }] },
    { "id": "es_me_021", "levels": [{ "front": "worry", "back": "preocupación" }, { "front": "Don't let worry stop you.", "back": "No dejes que la preocupación te detenga." }] },
    { "id": "es_me_022", "levels": [{ "front": "panic", "back": "pánico" }, { "front": "Don't panic.", "back": "No entres en pánico." }] },
    { "id": "es_me_023", "levels": [{ "front": "disgust", "back": "asco" }, { "front": "That smell is disgusting.", "back": "Ese olor me da asco." }] },
    { "id": "es_me_024", "levels": [{ "front": "surprise", "back": "sorpresa" }, { "front": "What a surprise!", "back": "¡Qué sorpresa!" }] },
    { "id": "es_me_025", "levels": [{ "front": "shock", "back": "choque" }, { "front": "The news was a shock.", "back": "La noticia fue un choque." }] },
    { "id": "es_me_026", "levels": [{ "front": "passion", "back": "pasión" }, { "front": "She teaches with passion.", "back": "Ella enseña con pasión." }] },
    { "id": "es_me_027", "levels": [{ "front": "desire", "back": "deseo" }, { "front": "I have a strong desire to travel.", "back": "Tengo un gran deseo de viajar." }] },
    { "id": "es_me_028", "levels": [{ "front": "hate", "back": "odio" }, { "front": "Hate is a strong feeling.", "back": "El odio es un sentimiento fuerte." }] },
    { "id": "es_me_029", "levels": [{ "front": "rage", "back": "rabia" }, { "front": "He was filled with rage.", "back": "Estaba lleno de rabia." }] },
    { "id": "es_me_030", "levels": [{ "front": "fury", "back": "furia" }, { "front": "She screamed with fury.", "back": "Gritó con furia." }] },
    { "id": "es_me_031", "levels": [{ "front": "sorrow", "back": "pesar" }, { "front": "I feel sorrow for his loss.", "back": "Siento pesar por su pérdida." }] },
    { "id": "es_me_032", "levels": [{ "front": "grief", "back": "duelo" }, { "front": "She's going through grief.", "back": "Ella está pasando por un duelo." }] },
    { "id": "es_me_033", "levels": [{ "front": "loneliness", "back": "soledad" }, { "front": "Loneliness is hard.", "back": "La soledad es difícil." }] },
    { "id": "es_me_034", "levels": [{ "front": "confidence", "back": "confianza" }, { "front": "She speaks with great confidence.", "back": "Ella habla con mucha confianza." }] },
    { "id": "es_me_035", "levels": [{ "front": "courage", "back": "coraje" }, { "front": "It takes courage to do that.", "back": "Hace falta coraje para hacer eso." }] },
    { "id": "es_me_036", "levels": [{ "front": "terror", "back": "terror" }, { "front": "The film was full of terror.", "back": "La película estaba llena de terror." }] },
    { "id": "es_me_037", "levels": [{ "front": "horror", "back": "horror" }, { "front": "I watched a horror film.", "back": "Vi una película de horror." }] },
    { "id": "es_me_038", "levels": [{ "front": "pleasure", "back": "placer" }, { "front": "It's a pleasure to meet you.", "back": "Es un placer conocerte." }] },
    { "id": "es_me_039", "levels": [{ "front": "pain", "back": "dolor" }, { "front": "I feel pain in my leg.", "back": "Siento dolor en la pierna." }] },
    { "id": "es_me_040", "levels": [{ "front": "heart (as in 'heavy heart')", "back": "corazón" }, { "front": "She left with a heavy heart.", "back": "Ella se fue con el corazón apesadumbrado." }] },
    { "id": "es_me_041", "levels": [{ "front": "spirit", "back": "espíritu" }, { "front": "She has a free spirit.", "back": "Ella tiene un espíritu libre." }] },
    { "id": "es_me_042", "levels": [{ "front": "empathy", "back": "empatía" }, { "front": "She shows a lot of empathy.", "back": "Ella muestra mucha empatía." }] },
    { "id": "es_me_043", "levels": [{ "front": "sympathy", "back": "compasión" }, { "front": "I have sympathy for you.", "back": "Tengo compasión por ti." }] },
    { "id": "es_me_044", "levels": [{ "front": "apathy", "back": "apatía" }, { "front": "Total apathy is dangerous.", "back": "La apatía total es peligrosa." }] },
    { "id": "es_me_045", "levels": [{ "front": "energy", "back": "energía" }, { "front": "I have a lot of energy today.", "back": "Hoy tengo mucha energía." }] },
    { "id": "es_me_046", "levels": [{ "front": "fatigue", "back": "fatiga" }, { "front": "I feel fatigue after work.", "back": "Siento fatiga después del trabajo." }] },
    { "id": "es_me_047", "levels": [{ "front": "tension", "back": "tensión" }, { "front": "There is a lot of tension in the room.", "back": "Hay mucha tensión en la sala." }] },
    { "id": "es_me_048", "levels": [{ "front": "relief", "back": "alivio" }, { "front": "What a relief!", "back": "¡Qué alivio!" }] },
    { "id": "es_me_049", "levels": [{ "front": "comfort", "back": "consuelo" }, { "front": "Her words were a comfort.", "back": "Sus palabras fueron un consuelo." }] },
    { "id": "es_me_050", "levels": [{ "front": "feel (to feel)", "back": "sentir", "grammarNote": "Sentir = to feel/perceive something. Sentirse (reflexive) = to feel a certain way. 'Me siento bien' (I feel good) vs 'Siento dolor' (I feel pain)." }, { "front": "I feel good today.", "back": "Me siento bien hoy." }] },
    { "id": "es_me_051", "levels": [{ "front": "love (to love)", "back": "amar" }, { "front": "I love you very much.", "back": "Te amo mucho." }] },
    { "id": "es_me_052", "levels": [{ "front": "hate (to hate)", "back": "odiar" }, { "front": "I hate waiting.", "back": "Odio esperar." }] },
    { "id": "es_me_053", "levels": [{ "front": "like (to like)", "back": "gustar" }, { "front": "I like music.", "back": "Me gusta la música." }] },
    { "id": "es_me_054", "levels": [{ "front": "enjoy", "back": "disfrutar" }, { "front": "I enjoy the weekend.", "back": "Disfruto el fin de semana." }] },
    { "id": "es_me_055", "levels": [{ "front": "fear / dread (to fear)", "back": "temer" }, { "front": "I fear the worst.", "back": "Temo lo peor." }] },
    { "id": "es_me_057", "levels": [{ "front": "hope (to hope)", "back": "esperar" }, { "front": "I hope everything goes well.", "back": "Espero que todo salga bien." }] },
    { "id": "es_me_058", "levels": [{ "front": "wish", "back": "desear" }, { "front": "I wish you luck.", "back": "Te deseo suerte." }] },
    { "id": "es_me_059", "levels": [{ "front": "worry (to worry)", "back": "preocuparse" }, { "front": "Don't worry about it.", "back": "No te preocupes por eso." }] },
    { "id": "es_me_060", "levels": [{ "front": "panic (to panic)", "back": "entrar en pánico" }, { "front": "Don't panic!", "back": "¡No entres en pánico!" }] },
    { "id": "es_me_061", "levels": [{ "front": "calm / soothe (to calm)", "back": "calmar" }, { "front": "Calm down, please.", "back": "Cálmate, por favor." }] },
    { "id": "es_me_063", "levels": [{ "front": "comfort (to comfort)", "back": "consolar" }, { "front": "She comforted her friend.", "back": "Ella consoló a su amiga." }] },
    { "id": "es_me_064", "levels": [{ "front": "excite / thrill", "back": "emocionar" }, { "front": "The trip excites me.", "back": "El viaje me emociona." }] },
    { "id": "es_me_066", "levels": [{ "front": "annoy", "back": "molestar" }, { "front": "That noise annoys me.", "back": "Ese ruido me molesta." }] },
    { "id": "es_me_067", "levels": [{ "front": "irritate", "back": "irritar" }, { "front": "Waiting irritates me.", "back": "Esperar me irrita." }] },
    { "id": "es_me_068", "levels": [{ "front": "anger (to anger)", "back": "enojar" }, { "front": "That comment angered me.", "back": "Ese comentario me enojó." }] },
    { "id": "es_me_069", "levels": [{ "front": "enrage", "back": "enfurecer" }, { "front": "The injustice enraged him.", "back": "La injusticia lo enfureció." }] },
    { "id": "es_me_070", "levels": [{ "front": "sadden", "back": "entristecer" }, { "front": "The news saddened me.", "back": "La noticia me entristeció." }] },
    { "id": "es_me_071", "levels": [{ "front": "grieve", "back": "afligirse" }, { "front": "She grieved for months.", "back": "Ella se afligió durante meses." }] },
    { "id": "es_me_073", "levels": [{ "front": "cheer (to cheer up)", "back": "animar" }, { "front": "Cheer up! It'll be okay.", "back": "¡Anímate! Todo estará bien." }] },
    { "id": "es_me_074", "levels": [{ "front": "delight", "back": "deleitar" }, { "front": "The music delighted everyone.", "back": "La música deleitó a todos." }] },
    { "id": "es_me_075", "levels": [{ "front": "smile", "back": "sonreír" }, { "front": "She always smiles.", "back": "Ella siempre sonríe." }] },
    { "id": "es_me_076", "levels": [{ "front": "laugh", "back": "reír" }, { "front": "We laughed a lot.", "back": "Nos reímos mucho." }] },
    { "id": "es_me_077", "levels": [{ "front": "cry / weep / mourn", "back": "llorar" }, { "front": "The baby is crying.", "back": "El bebé está llorando." }] },
    { "id": "es_me_079", "levels": [{ "front": "sigh", "back": "suspirar" }, { "front": "She sighed with relief.", "back": "Ella suspiró de alivio." }] },
    { "id": "es_me_080", "levels": [{ "front": "frown", "back": "fruncir el ceño" }, { "front": "He frowned when he heard the news.", "back": "Frunció el ceño cuando escuchó la noticia." }] },
    { "id": "es_me_081", "levels": [{ "front": "scowl", "back": "poner mala cara" }, { "front": "Don't scowl like that.", "back": "No pongas mala cara así." }] },
