    { "id": "ar_jh_025", "levels": [{ "front": "Jogging", "back": "الهرولة", "romanized": "al-harwala" }, { "front": "He jogs in the park.", "back": "هو يهرول في الحديقة.", "romanized": "huwa yharwil fi al-hadiqa." }] },
