    { "id": "ar_jh_027", "levels": [{ "front": "Swimming", "back": "السباحة", "romanized": "as-sibaha" }, { "front": "I like swimming.", "back": "أحب السباحة.", "romanized": "uhibb as-sibaha." }] },
    { "id": "ar_jh_028", "levels": [{ "front": "Yoga", "back": "اليوغا", "romanized": "al-yuga" }, { "front": "She does yoga every morning.", "back": "هي تمارس اليوغا كل صباح.", "romanized": "hiya tumaris al-yuga kull sabah." }] },
    { "id": "ar_jh_029", "levels": [{ "front": "Exercise", "back": "التمرين / الرياضة", "romanized": "at-tamrin / ar-riyada" }, { "front": "I go to the gym for exercise.", "back": "أذهب إلى الصالة الرياضية للتمرين.", "romanized": "adhhab ila as-sala ar-riyadiyya lit-tamrin." }] },
    { "id": "ar_jh_030", "levels": [{ "front": "Traveling", "back": "السفر", "romanized": "as-safar" }, { "front": "I love traveling.", "back": "أحب السفر.", "romanized": "uhibb as-safar." }] },
    { "id": "ar_jh_031", "levels": [{ "front": "Camping", "back": "التخييم", "romanized": "at-takhyim" }, { "front": "We go camping in the summer.", "back": "نذهب للتخييم في الصيف.", "romanized": "nadhhab lit-takhyim fi as-sayf." }] },
    { "id": "ar_jh_032", "levels": [{ "front": "Gaming (Video games)", "back": "ألعاب الفيديو", "romanized": "al'ab al-vidyu" }, { "front": "He plays video games at night.", "back": "هو يلعب ألعاب الفيديو في الليل.", "romanized": "huwa yal'ab al'ab al-vidyu fi al-layl." }] },
