    { "id": "ar_jh_038", "levels": [{ "front": "To work (in/for/as)", "back": "يعمل (في/لـ/كـ)", "romanized": "ya'mal (fi/li/ka)" }, { "front": "I work in a hospital.", "back": "أعمل في مستشفى.", "romanized": "a'mal fi mustashfa." }] },
    { "id": "ar_jh_039", "levels": [{ "front": "To earn (a salary)", "back": "يتقاضى / يكسب", "romanized": "yataqada / yaksib" }, { "front": "He earns a good salary.", "back": "هو يتقاضى راتباً جيداً.", "romanized": "huwa yataqada ratiban jayyidan." }] },
    { "id": "ar_jh_040", "levels": [{ "front": "To retire", "back": "يتقاعد", "romanized": "yataqa'ad" }, { "front": "She retired last year.", "back": "هي تقاعدت العام الماضي.", "romanized": "hiya taqa'adat al-'am al-madi." }] },
    { "id": "ar_jh_041", "levels": [{ "front": "To have a job", "back": "لديه وظيفة", "romanized": "ladayhi wazifa" }, { "front": "I have a good job.", "back": "لدي وظيفة جيدة.", "romanized": "ladayya wazifa jayyida." }] },
    { "id": "ar_jh_042", "levels": [{ "front": "To be unemployed", "back": "عاطل عن العمل", "romanized": "'atil 'an al-'amal" }, { "front": "He is currently unemployed.", "back": "هو عاطل عن العمل حالياً.", "romanized": "huwa 'atil 'an al-'amal haliyan." }] },
    { "id": "ar_jh_043", "levels": [{ "front": "To study", "back": "يدرس", "romanized": "yadrus" }, { "front": "I study every day.", "back": "أدرس كل يوم.", "romanized": "adrus kull yawm." }] },
    { "id": "ar_jh_044", "levels": [{ "front": "To learn", "back": "يتعلّم", "romanized": "yata'allam" }, { "front": "I'm learning Arabic.", "back": "أنا أتعلم العربية.", "romanized": "ana ata'allam al-arabiyya." }] },
    { "id": "ar_jh_045", "levels": [{ "front": "To practice", "back": "يتدرّب / يمارس", "romanized": "yatadarrab / yumaris" }, { "front": "I practice every day.", "back": "أتدرّب كل يوم.", "romanized": "atadarrab kull yawm." }] },
    { "id": "ar_jh_046", "levels": [{ "front": "To teach", "back": "يدرّس", "romanized": "yudarris" }, { "front": "She teaches Arabic.", "back": "هي تدرّس العربية.", "romanized": "hiya tudarris al-arabiyya." }] },
    { "id": "ar_jh_047", "levels": [{ "front": "To build", "back": "يبني", "romanized": "yabni" }, { "front": "They are building a new school.", "back": "هم يبنون مدرسة جديدة.", "romanized": "hum yabnun madrasa jadida." }] },
    { "id": "ar_jh_048", "levels": [{ "front": "To fix", "back": "يصلح", "romanized": "yusallih" }, { "front": "Can you fix this?", "back": "هل يمكنك إصلاح هذا؟", "romanized": "hal yumkinuka islah hadha?" }] },
    { "id": "ar_jh_049", "levels": [{ "front": "To make", "back": "يصنع", "romanized": "yasna'" }, { "front": "I make coffee every morning.", "back": "أصنع القهوة كل صباح.", "romanized": "asna' al-qahwa kull sabah." }] },
    { "id": "ar_jh_050", "levels": [{ "front": "To design", "back": "يصمّم", "romanized": "yusammim" }, { "front": "He designs websites.", "back": "هو يصمّم مواقع الويب.", "romanized": "huwa yusammim mawaqia' al-wayb." }] },
    { "id": "ar_jh_051", "levels": [{ "front": "To sell", "back": "يبيع", "romanized": "yabi'" }, { "front": "He sells cars.", "back": "هو يبيع السيارات.", "romanized": "huwa yabi' as-sayyarat." }] },
    { "id": "ar_jh_052", "levels": [{ "front": "To buy", "back": "يشتري", "romanized": "yashtari" }, { "front": "I need to buy a new computer.", "back": "أحتاج إلى شراء حاسوب جديد.", "romanized": "ahtaj ila shira' hasub jadid." }] },
    { "id": "ar_jh_053", "levels": [{ "front": "To help", "back": "يساعد", "romanized": "yusa'id" }, { "front": "Can I help you?", "back": "هل يمكنني مساعدتك؟", "romanized": "hal yumkinuni musa'adatuk?" }] },
    { "id": "ar_jh_054", "levels": [{ "front": "To manage", "back": "يدير", "romanized": "yudir" }, { "front": "She manages the team.", "back": "هي تدير الفريق.", "romanized": "hiya tudir al-fariq." }] },
    { "id": "ar_jh_055", "levels": [{ "front": "To meet", "back": "يجتمع / يلتقي", "romanized": "yajtami' / yaltaqi" }, { "front": "We meet every Monday.", "back": "نجتمع كل يوم الاثنين.", "romanized": "najtami' kull yawm al-ithnayn." }] },
