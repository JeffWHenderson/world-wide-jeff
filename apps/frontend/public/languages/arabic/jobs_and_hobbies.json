    { "id": "ar_jh_034", "levels": [{ "front": "Listening to music", "back": "الاستماع إلى الموسيقى", "romanized": "al-istima' ila al-musiqa" }, { "front": "She likes listening to music.", "back": "هي تحب الاستماع إلى الموسيقى.", "romanized": "hiya tuhibb al-istima' ila al-musiqa." }] },
    { "id": "ar_jh_035", "levels": [{ "front": "Crafts", "back": "الحرف اليدوية", "romanized": "al-hiraf al-yadawiyya" }, { "front": "The children are making crafts.", "back": "الأطفال يصنعون الحرف اليدوية.", "romanized": "al-atfal yasna'un al-hiraf al-yadawiyya." }] },
