    { "id": "ar_jh_057", "levels": [{ "front": "To finish", "back": "ينهي / ينتهي", "romanized": "yunhi / yantahi" }, { "front": "I finish work at five.", "back": "أنهي العمل في الخامسة.", "romanized": "anhi al-'amal fi al-khamisa." }] },
    { "id": "ar_jh_058", "levels": [{ "front": "To like / To enjoy", "back": "يحب / يستمتع", "romanized": "yuhibb / yastamti'", "grammarNote": "Arabic 'يحب' (yuhibb = to love/like) is used where Spanish uses 'gustar'. The structure is direct: أحب القراءة (uhibb al-qira'a = I like reading), هي تحب الغناء (hiya tuhibb al-ghina' = she likes singing). Unlike Spanish gustar, the subject of the Arabic sentence is the person, not the thing liked." }, { "front": "I like reading. She likes singing.", "back": "أحب القراءة. هي تحب الغناء.", "romanized": "uhibb al-qira'a. hiya tuhibb al-ghina'." }] },
    { "id": "ar_jh_059", "levels": [{ "front": "To relax", "back": "يسترخي", "romanized": "yastarkhi" }, { "front": "I relax on weekends.", "back": "أسترخي في عطلة نهاية الأسبوع.", "romanized": "astarkhi fi 'utlat nihayat al-usbu'." }] },
    { "id": "ar_jh_060", "levels": [{ "front": "To spend time (on)", "back": "يقضي وقتاً (في)", "romanized": "yaqdi waqtan (fi)" }, { "front": "I spend a lot of time reading.", "back": "أقضي وقتاً كثيراً في القراءة.", "romanized": "aqdi waqtan kathiran fi al-qira'a." }] },
    { "id": "ar_jh_061", "levels": [{ "front": "Creative", "back": "مبدع", "romanized": "mubdi'" }, { "front": "She is very creative.", "back": "هي مبدعة جداً.", "romanized": "hiya mubdi'a jiddan." }] },
    { "id": "ar_jh_062", "levels": [{ "front": "Interesting", "back": "مثير للاهتمام", "romanized": "muthir lil-ihtimam" }, { "front": "My job is interesting.", "back": "عملي مثير للاهتمام.", "romanized": "'amali muthir lil-ihtimam." }] },
    { "id": "ar_jh_063", "levels": [{ "front": "Stressful", "back": "مُجهِد", "romanized": "mujhid" }, { "front": "My job is stressful.", "back": "عملي مُجهِد.", "romanized": "'amali mujhid." }] },
    { "id": "ar_jh_064", "levels": [{ "front": "Boring", "back": "ممل", "romanized": "mumill" }, { "front": "The meeting was boring.", "back": "الاجتماع كان مملاً.", "romanized": "al-ijtima' kan mumillan." }] },
