    { "id": "ar_jh_018", "levels": [{ "front": "Singing", "back": "الغناء", "romanized": "al-ghina'" }, { "front": "She loves singing.", "back": "هي تحب الغناء.", "romanized": "hiya tuhibb al-ghina'." }] },
    { "id": "ar_jh_019", "levels": [{ "front": "Playing an instrument (e.g., Guitar)", "back": "العزف على آلة موسيقية (مثل الغيتار)", "romanized": "al-'azf 'ala ala musiqiyya (mithl al-ghitar)" }, { "front": "I play the guitar.", "back": "أعزف على الغيتار.", "romanized": "a'zif 'ala al-ghitar." }] },
    { "id": "ar_jh_020", "levels": [{ "front": "Dancing", "back": "الرقص", "romanized": "ar-raqs" }, { "front": "We love dancing.", "back": "نحن نحب الرقص.", "romanized": "nahnu nuhibb ar-raqs." }] },
    { "id": "ar_jh_021", "levels": [{ "front": "Cooking", "back": "الطبخ", "romanized": "at-tabkh" }, { "front": "I enjoy cooking.", "back": "أستمتع بالطبخ.", "romanized": "astamti' bit-tabkh." }] },
    { "id": "ar_jh_022", "levels": [{ "front": "Gardening", "back": "البستنة", "romanized": "al-bustana" }, { "front": "Gardening is relaxing.", "back": "البستنة مريحة.", "romanized": "al-bustana muriha." }] },
    { "id": "ar_jh_023", "levels": [{ "front": "Hiking", "back": "المشي لمسافات طويلة", "romanized": "al-mashy li-masafat tawila" }, { "front": "I like hiking in the mountains.", "back": "أحب المشي في الجبال.", "romanized": "uhibb al-mashy fi al-jibal." }] },
