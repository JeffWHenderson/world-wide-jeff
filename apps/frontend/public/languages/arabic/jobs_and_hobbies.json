    { "id": "ar_jh_068", "levels": [{ "front": "Break", "back": "استراحة", "romanized": "istiraha" }, { "front": "Let's take a break.", "back": "لنأخذ استراحة.", "romanized": "lna'khudh istiraha." }] },
    { "id": "ar_jh_069", "levels": [{ "front": "Office", "back": "مكتب", "romanized": "maktab" }, { "front": "I work in an office.", "back": "أعمل في مكتب.", "romanized": "a'mal fi maktab." }] },
    { "id": "ar_jh_070", "levels": [{ "front": "Outdoors", "back": "في الهواء الطلق", "romanized": "fi al-hawa' at-taliq" }, { "front": "She works outdoors.", "back": "هي تعمل في الهواء الطلق.", "romanized": "hiya ta'mal fi al-hawa' at-taliq." }] },
