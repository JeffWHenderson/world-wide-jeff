  "cards": [
    { "id": "ar_jh_001", "levels": [{ "front": "Doctor", "back": "طبيب", "romanized": "tabib", "grammarNote": "Arabic profession nouns are masculine by default. Feminine is formed by adding ة (ta marbuta): طبيب → طبيبة (tabib → tabiba = female doctor), مهندس → مهندسة (muhandis → muhandisa = female engineer). Unlike Spanish, Arabic doesn't drop the article when saying 'I am a doctor': أنا طبيب (ana tabib = I am a doctor)." }, { "front": "He is a doctor.", "back": "هو طبيب.", "romanized": "huwa tabib." }] },
    { "id": "ar_jh_002", "levels": [{ "front": "Nurse", "back": "ممرض / ممرضة", "romanized": "mumarrida / mumarrid" }, { "front": "She is a nurse.", "back": "هي ممرضة.", "romanized": "hiya mumarrida." }] },
    { "id": "ar_jh_003", "levels": [{ "front": "Engineer", "back": "مهندس", "romanized": "muhandis" }, { "front": "My brother is an engineer.", "back": "أخي مهندس.", "romanized": "akhi muhandis." }] },
    { "id": "ar_jh_004", "levels": [{ "front": "Programmer", "back": "مبرمج", "romanized": "mubarammij" }, { "front": "I work as a programmer.", "back": "أعمل كمبرمج.", "romanized": "a'mal ka-mubarammij." }] },
    { "id": "ar_jh_005", "levels": [{ "front": "Cook", "back": "طاهٍ", "romanized": "tahi" }, { "front": "The cook works in the kitchen.", "back": "الطاهي يعمل في المطبخ.", "romanized": "at-tahi ya'mal fi al-matbakh." }] },
    { "id": "ar_jh_006", "levels": [{ "front": "Waiter (Waitress)", "back": "نادل (نادلة)", "romanized": "nadil (nadila)" }, { "front": "The waiter brought the menu.", "back": "النادل أحضر قائمة الطعام.", "romanized": "an-nadil ahdara qa'imat at-ta'am." }] },
    { "id": "ar_jh_007", "levels": [{ "front": "Manager", "back": "مدير", "romanized": "mudir" }, { "front": "She is a manager.", "back": "هي مديرة.", "romanized": "hiya mudira." }] },
    { "id": "ar_jh_008", "levels": [{ "front": "Student", "back": "طالب / طالبة", "romanized": "talib / taliba" }, { "front": "I am a student.", "back": "أنا طالب.", "romanized": "ana talib." }] },
    { "id": "ar_jh_009", "levels": [{ "front": "Architect", "back": "مهندس معماري", "romanized": "muhandis mi'mari" }, { "front": "He is an architect.", "back": "هو مهندس معماري.", "romanized": "huwa muhandis mi'mari." }] },
    { "id": "ar_jh_010", "levels": [{ "front": "Lawyer", "back": "محامٍ / محامية", "romanized": "muhami / muhamiya" }, { "front": "My sister is a lawyer.", "back": "أختي محامية.", "romanized": "ukhti muhamiya." }] },
    { "id": "ar_jh_011", "levels": [{ "front": "Retired Person", "back": "متقاعد", "romanized": "mutaqa'id" }, { "front": "My father is retired.", "back": "أبي متقاعد.", "romanized": "abi mutaqa'id." }] },
    { "id": "ar_jh_012", "levels": [{ "front": "Reading", "back": "القراءة", "romanized": "al-qira'a" }, { "front": "I like reading.", "back": "أحب القراءة.", "romanized": "uhibb al-qira'a." }] },
    { "id": "ar_jh_013", "levels": [{ "front": "Writing", "back": "الكتابة", "romanized": "al-kitaba" }, { "front": "She likes writing stories.", "back": "هي تحب كتابة القصص.", "romanized": "hiya tuhibb kitabat al-qisas." }] },
    { "id": "ar_jh_014", "levels": [{ "front": "Painting", "back": "الرسم / التلوين", "romanized": "ar-rasm / at-talwin" }, { "front": "He loves painting.", "back": "هو يحب الرسم.", "romanized": "huwa yuhibb ar-rasm." }] },
    { "id": "ar_jh_015", "levels": [{ "front": "Drawing", "back": "الرسم", "romanized": "ar-rasm" }, { "front": "I like drawing.", "back": "أحب الرسم.", "romanized": "uhibb ar-rasm." }] },
    { "id": "ar_jh_016", "levels": [{ "front": "Photography", "back": "التصوير", "romanized": "at-taswir" }, { "front": "Photography is my hobby.", "back": "التصوير هوايتي.", "romanized": "at-taswir hiwayati." }] },
