    { "id": "ar_fd_020", "levels": [{ "front": "sugar", "back": "سكر", "romanized": "sukkar" }, { "front": "Coffee without sugar, please.", "back": "قهوة بدون سكر، من فضلك.", "romanized": "qahwa bidun sukkar, min fadlak." }] },
    { "id": "ar_fd_021", "levels": [{ "front": "oil", "back": "زيت", "romanized": "zayt" }, { "front": "Olive oil is healthy.", "back": "زيت الزيتون صحي.", "romanized": "zayt az-zaytun sihhi." }] },
    { "id": "ar_fd_022", "levels": [{ "front": "coffee", "back": "قهوة", "romanized": "qahwa" }, { "front": "I always drink coffee in the morning.", "back": "دائماً أشرب القهوة في الصباح.", "romanized": "da'iman ashrab al-qahwa fi as-sabah." }] },
    { "id": "ar_fd_023", "levels": [{ "front": "tea", "back": "شاي", "romanized": "shay" }, { "front": "Tea with mint, please.", "back": "شاي بالنعناع، من فضلك.", "romanized": "shay bi-n-na'na', min fadlak." }] },
