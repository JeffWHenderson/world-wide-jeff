    { "id": "ar_fd_032", "levels": [{ "front": "hungry", "back": "جائع", "romanized": "ja'i'" }, { "front": "I'm very hungry.", "back": "أنا جائع جداً.", "romanized": "ana ja'i' jiddan." }] },
    { "id": "ar_fd_033", "levels": [{ "front": "thirsty", "back": "عطشان", "romanized": "atshan" }, { "front": "Are you thirsty?", "back": "هل أنت عطشان؟", "romanized": "hal anta atshan?" }] },
    { "id": "ar_fd_034", "levels": [{ "front": "spicy", "back": "حار", "romanized": "harr" }, { "front": "Is this dish spicy?", "back": "هل هذا الطبق حار؟", "romanized": "hal hadha at-tabaq harr?" }] },
    { "id": "ar_fd_035", "levels": [{ "front": "sweet", "back": "حلو", "romanized": "hulw" }, { "front": "This dessert is very sweet.", "back": "هذا الحلوى حلوة جداً.", "romanized": "hadhihi al-halwa hulwa jiddan." }] },
