  "id": "food_and_drink",
  "name": "Food & Drink",
  "language": "arabic",
  "stories": [],
  "pictureLessons": [],
  "cards": [
    { "id": "ar_fd_001", "levels": [{ "front": "water", "back": "ماء", "romanized": "ma'", "grammarNote": "Arabic has no copula (verb 'to be') in the present tense. 'الماء بارد' (al-ma' barid) literally means 'the-water cold' with no verb. This nominal sentence structure is standard: subject + predicate adjective, no linking verb needed." }, { "front": "The water is cold.", "back": "الماء بارد.", "romanized": "al-ma' barid." }] },
    { "id": "ar_fd_002", "levels": [{ "front": "bread", "back": "خبز", "romanized": "khubz" }, { "front": "I'd like some bread.", "back": "أريد بعض الخبز.", "romanized": "urid ba'd al-khubz." }] },
    { "id": "ar_fd_003", "levels": [{ "front": "rice", "back": "أرز", "romanized": "aruzz" }, { "front": "I like rice with vegetables.", "back": "أحب الأرز مع الخضروات.", "romanized": "uhibb al-aruzz ma'a al-khadrawat." }] },
    { "id": "ar_fd_004", "levels": [{ "front": "milk", "back": "حليب", "romanized": "halib" }, { "front": "Do you want milk?", "back": "هل تريد حليباً؟", "romanized": "hal turid haliban?" }] },
    { "id": "ar_fd_005", "levels": [{ "front": "egg", "back": "بيضة", "romanized": "bayda" }, { "front": "I eat two eggs for breakfast.", "back": "آكل بيضتين في الفطور.", "romanized": "akul baydatayn fi al-futur." }] },
    { "id": "ar_fd_006", "levels": [{ "front": "cheese", "back": "جبن", "romanized": "jubn" }, { "front": "The sandwich has cheese.", "back": "الشطيرة فيها جبن.", "romanized": "ash-shatira fiha jubn." }] },
    { "id": "ar_fd_007", "levels": [{ "front": "chicken", "back": "دجاج", "romanized": "dajaj" }, { "front": "The chicken is delicious.", "back": "الدجاج لذيذ.", "romanized": "ad-dajaj ladhidh." }] },
    { "id": "ar_fd_008", "levels": [{ "front": "meat", "back": "لحم", "romanized": "lahm" }, { "front": "He doesn't eat meat.", "back": "هو لا يأكل اللحم.", "romanized": "huwa la ya'kul al-lahm." }] },
    { "id": "ar_fd_009", "levels": [{ "front": "fish", "back": "سمك", "romanized": "samak" }, { "front": "I like fish.", "back": "أحب السمك.", "romanized": "uhibb as-samak." }] },
    { "id": "ar_fd_011", "levels": [{ "front": "pork", "back": "لحم خنزير", "romanized": "lahm khinzir", "grammarNote": "Pork (لحم خنزير, lahm khinzir) is forbidden (حرام, haram) in Islam and is generally unavailable in most Arab countries. When eating in Arab cultural contexts, knowing this phrase is practical: لا آكل لحم الخنزير (la akul lahm al-khinzir) = I don't eat pork." }, { "front": "I don't eat pork.", "back": "لا آكل لحم الخنزير.", "romanized": "la akul lahm al-khinzir." }] },
    { "id": "ar_fd_012", "levels": [{ "front": "fruit", "back": "فاكهة", "romanized": "fakiha" }, { "front": "I eat fruit every day.", "back": "آكل الفاكهة كل يوم.", "romanized": "akul al-fakiha kull yawm." }] },
    { "id": "ar_fd_013", "levels": [{ "front": "apple", "back": "تفاحة", "romanized": "tuffaha" }, { "front": "An apple a day is healthy.", "back": "تفاحة في اليوم مفيدة للصحة.", "romanized": "tuffaha fi al-yawm mufida lis-sihha." }] },
    { "id": "ar_fd_014", "levels": [{ "front": "banana", "back": "موز", "romanized": "mawz" }, { "front": "The bananas are ripe.", "back": "الموز ناضج.", "romanized": "al-mawz nadij." }] },
    { "id": "ar_fd_015", "levels": [{ "front": "orange", "back": "برتقال", "romanized": "burtuqal" }, { "front": "I want an orange juice.", "back": "أريد عصير برتقال.", "romanized": "urid asir burtuqal." }] },
    { "id": "ar_fd_016", "levels": [{ "front": "vegetable", "back": "خضروات", "romanized": "khadrawat" }, { "front": "Eat your vegetables!", "back": "كُل خضرواتك!", "romanized": "kul khadrawatak!" }] },
    { "id": "ar_fd_017", "levels": [{ "front": "potato", "back": "بطاطس", "romanized": "batatais" }, { "front": "I want mashed potatoes.", "back": "أريد بطاطس مهروسة.", "romanized": "urid batatais mahrusa." }] },
    { "id": "ar_fd_018", "levels": [{ "front": "tomato", "back": "طماطم", "romanized": "tamatim" }, { "front": "The salad has tomatoes.", "back": "السلطة فيها طماطم.", "romanized": "as-salata fiha tamatim." }] },
    { "id": "ar_fd_019", "levels": [{ "front": "onion", "back": "بصل", "romanized": "basal" }, { "front": "I don't like onions.", "back": "لا أحب البصل.", "romanized": "la uhibb al-basal." }] },
    { "id": "ar_fd_020", "levels": [{ "front": "salad", "back": "سلطة", "romanized": "salata" }, { "front": "I'll have a salad.", "back": "سآخذ سلطة.", "romanized": "sa-akhudh salata." }] },
    { "id": "ar_fd_021", "levels": [{ "front": "soup", "back": "حساء / شوربة", "romanized": "hisa' / shurba" }, { "front": "The soup is hot.", "back": "الحساء ساخن.", "romanized": "al-hisa' sakhin." }] },
    { "id": "ar_fd_024", "levels": [{ "front": "sandwich", "back": "شطيرة / سندوتش", "romanized": "shatira / sandawich" }, { "front": "I made a sandwich for lunch.", "back": "صنعت شطيرة للغداء.", "romanized": "sana'tu shatira lil-ghada'." }] },
    { "id": "ar_fd_025", "levels": [{ "front": "cake", "back": "كعكة", "romanized": "ka'ka" }, { "front": "Do you want cake?", "back": "هل تريد كعكة؟", "romanized": "hal turid ka'ka?" }] },
    { "id": "ar_fd_026", "levels": [{ "front": "cookie", "back": "بسكويت", "romanized": "biskwit" }, { "front": "These cookies are delicious.", "back": "هذا البسكويت لذيذ.", "romanized": "hadha al-biskwit ladhidh." }] },
    { "id": "ar_fd_027", "levels": [{ "front": "chocolate", "back": "شوكولاتة", "romanized": "shukulata" }, { "front": "I love chocolate.", "back": "أحب الشوكولاتة.", "romanized": "uhibb ash-shukulata." }] },
    { "id": "ar_fd_028", "levels": [{ "front": "sugar", "back": "سكر", "romanized": "sukkar" }, { "front": "No sugar, please.", "back": "بدون سكر، من فضلك.", "romanized": "bidun sukkar, min fadlak." }] },
    { "id": "ar_fd_029", "levels": [{ "front": "salt", "back": "ملح", "romanized": "milh" }, { "front": "Can you pass the salt?", "back": "هل يمكنك تناولي الملح؟", "romanized": "hal yumkinuka tanawuli al-milh?" }] },
    { "id": "ar_fd_030", "levels": [{ "front": "pepper", "back": "فلفل", "romanized": "filfil" }, { "front": "Can you pass the pepper?", "back": "هل يمكنك تناولي الفلفل؟", "romanized": "hal yumkinuka tanawuli al-filfil?" }] },
    { "id": "ar_fd_031", "levels": [{ "front": "butter", "back": "زبدة", "romanized": "zubda" }, { "front": "I put butter on my bread.", "back": "أضع الزبدة على الخبز.", "romanized": "ada' az-zubda 'ala al-khubz." }] },
    { "id": "ar_fd_032", "levels": [{ "front": "oil", "back": "زيت", "romanized": "zayt" }, { "front": "Cook with olive oil.", "back": "اطبخ بزيت الزيتون.", "romanized": "utbukh bi-zayt az-zaytun." }] },
    { "id": "ar_fd_033", "levels": [{ "front": "coffee", "back": "قهوة", "romanized": "qahwa" }, { "front": "I like coffee in the morning.", "back": "أحب القهوة في الصباح.", "romanized": "uhibb al-qahwa fi as-sabah." }] },
    { "id": "ar_fd_034", "levels": [{ "front": "tea", "back": "شاي", "romanized": "shay" }, { "front": "Would you like some tea?", "back": "هل تريد شاياً؟", "romanized": "hal turid shayan?" }] },
    { "id": "ar_fd_035", "levels": [{ "front": "wine", "back": "نبيذ", "romanized": "nabidh" }, { "front": "A glass of red wine, please.", "back": "كوب نبيذ أحمر، من فضلك.", "romanized": "kub nabidh ahmar, min fadlak." }] },
    { "id": "ar_fd_036", "levels": [{ "front": "beer", "back": "بيرة", "romanized": "bira" }, { "front": "Two beers, please.", "back": "بيرتان، من فضلك.", "romanized": "birratan, min fadlak." }] },
    { "id": "ar_fd_037", "levels": [{ "front": "juice", "back": "عصير", "romanized": "asir" }, { "front": "I want orange juice.", "back": "أريد عصير برتقال.", "romanized": "urid asir burtuqal." }] },
    { "id": "ar_fd_038", "levels": [{ "front": "breakfast", "back": "فطور", "romanized": "futur" }, { "front": "I have breakfast at seven.", "back": "آكل الفطور في السابعة.", "romanized": "akul al-futur fi as-sabi'a." }] },
    { "id": "ar_fd_039", "levels": [{ "front": "lunch", "back": "غداء", "romanized": "ghada'" }, { "front": "We have lunch at two.", "back": "نتناول الغداء في الثانية.", "romanized": "natarawal al-ghada' fi ath-thaniya." }] },
    { "id": "ar_fd_040", "levels": [{ "front": "dinner", "back": "عشاء", "romanized": "asha'" }, { "front": "Dinner is ready.", "back": "العشاء جاهز.", "romanized": "al-asha' jahiz." }] },
    { "id": "ar_fd_041", "levels": [{ "front": "snack", "back": "وجبة خفيفة", "romanized": "wajba khafifa" }, { "front": "I have a snack in the afternoon.", "back": "آكل وجبة خفيفة في بعد الظهر.", "romanized": "akul wajba khafifa fi ba'd adh-dhuhr." }] },
    { "id": "ar_fd_042", "levels": [{ "front": "meal", "back": "وجبة", "romanized": "wajba" }, { "front": "This is a delicious meal.", "back": "هذه وجبة لذيذة.", "romanized": "hadhihi wajba ladhidha." }] },
    { "id": "ar_fd_043", "levels": [{ "front": "recipe", "back": "وصفة", "romanized": "wasfa" }, { "front": "Do you have a good recipe?", "back": "هل عندك وصفة جيدة؟", "romanized": "hal indaka wasfa jayyida?" }] },
    { "id": "ar_fd_044", "levels": [{ "front": "flavor", "back": "نكهة / طعم", "romanized": "nakha / ta'm" }, { "front": "What flavor do you want?", "back": "أي نكهة تريد؟", "romanized": "ayy nakha turid?" }] },
    { "id": "ar_fd_046", "levels": [{ "front": "ingredient", "back": "مكون", "romanized": "mukawwin" }, { "front": "What ingredients do you need?", "back": "ما هي المكونات التي تحتاجها؟", "romanized": "ma hiya al-mukawwinat allati tahtajuha?" }] },
    { "id": "ar_fd_047", "levels": [{ "front": "menu", "back": "قائمة الطعام", "romanized": "qa'imat at-ta'am" }, { "front": "Can I see the menu?", "back": "هل يمكنني رؤية قائمة الطعام؟", "romanized": "hal yumkinuni ru'yat qa'imat at-ta'am?" }] },
    { "id": "ar_fd_048", "levels": [{ "front": "restaurant", "back": "مطعم", "romanized": "mat'am" }, { "front": "This restaurant is good.", "back": "هذا المطعم جيد.", "romanized": "hadha al-mat'am jayyid." }] },
    { "id": "ar_fd_049", "levels": [{ "front": "kitchen", "back": "مطبخ", "romanized": "matbakh" }, { "front": "The kitchen is clean.", "back": "المطبخ نظيف.", "romanized": "al-matbakh nadhif." }] },
    { "id": "ar_fd_050", "levels": [{ "front": "oven", "back": "فرن", "romanized": "furn" }, { "front": "The oven is hot.", "back": "الفرن ساخن.", "romanized": "al-furn sakhin." }] },
    { "id": "ar_fd_051", "levels": [{ "front": "stove", "back": "موقد", "romanized": "mawqid" }, { "front": "Cook it on the stove.", "back": "اطبخه على الموقد.", "romanized": "utbukhhu 'ala al-mawqid." }] },
    { "id": "ar_fd_052", "levels": [{ "front": "knife", "back": "سكين", "romanized": "sikkin" }, { "front": "I need a sharp knife.", "back": "أحتاج سكيناً حاداً.", "romanized": "ahtaj sikkinen haddan." }] },
    { "id": "ar_fd_053", "levels": [{ "front": "fork", "back": "شوكة", "romanized": "shawka" }, { "front": "Can I have a fork?", "back": "هل يمكنني الحصول على شوكة؟", "romanized": "hal yumkinuni al-husul 'ala shawka?" }] },
    { "id": "ar_fd_054", "levels": [{ "front": "spoon", "back": "ملعقة", "romanized": "mil'aqa" }, { "front": "I need a spoon.", "back": "أحتاج ملعقة.", "romanized": "ahtaj mil'aqa." }] },
    { "id": "ar_fd_055", "levels": [{ "front": "plate", "back": "طبق", "romanized": "tabaq" }, { "front": "The plate is dirty.", "back": "الطبق متسخ.", "romanized": "at-tabaq mutassikh." }] },
    { "id": "ar_fd_056", "levels": [{ "front": "bowl", "back": "وعاء / صحن", "romanized": "wi'a' / sahn" }, { "front": "Fill the bowl with soup.", "back": "امل الوعاء بالحساء.", "romanized": "amla' al-wi'a' bil-hisa'." }] },
    { "id": "ar_fd_058", "levels": [{ "front": "glass", "back": "كوب", "romanized": "kub" }, { "front": "A glass of water, please.", "back": "كوب ماء، من فضلك.", "romanized": "kub ma', min fadlak." }] },
    { "id": "ar_fd_059", "levels": [{ "front": "bottle", "back": "زجاجة", "romanized": "zujaja" }, { "front": "A bottle of wine, please.", "back": "زجاجة نبيذ، من فضلك.", "romanized": "zujajat nabidh, min fadlak." }] },
    { "id": "ar_fd_060", "levels": [{ "front": "table", "back": "طاولة", "romanized": "tawila" }, { "front": "Our table is ready.", "back": "طاولتنا جاهزة.", "romanized": "tawilantuna jahiza." }] },
    { "id": "ar_fd_061", "levels": [{ "front": "waiter", "back": "نادل", "romanized": "nadil" }, { "front": "Waiter, the bill please.", "back": "يا نادل، الفاتورة من فضلك.", "romanized": "ya nadil, al-fatura min fadlak." }] },
    { "id": "ar_fd_062", "levels": [{ "front": "hungry", "back": "جائع", "romanized": "ja'i'", "grammarNote": "Arabic expresses hunger and thirst with adjectives directly: أنا جائع (ana ja'i' = I am hungry), أنا عطشان (ana atshan = I am thirsty). Unlike Spanish which uses 'tener' (to have hunger), Arabic simply places the adjective as a predicate with no verb. Feminine forms: جائعة (ja'i'a), عطشانة (atshanah)." }, { "front": "I'm hungry. Are you thirsty?", "back": "أنا جائع. هل أنت عطشان؟", "romanized": "ana ja'i'. hal anta atshan?" }] },
    { "id": "ar_fd_063", "levels": [{ "front": "thirsty", "back": "عطشان", "romanized": "atshan" }, { "front": "I'm thirsty.", "back": "أنا عطشان.", "romanized": "ana atshan." }] },
    { "id": "ar_fd_064", "levels": [{ "front": "eat", "back": "يأكل", "romanized": "ya'kul" }, { "front": "Let's eat!", "back": "لنأكل!", "romanized": "lna'kul!" }] },
    { "id": "ar_fd_065", "levels": [{ "front": "drink", "back": "يشرب", "romanized": "yashrab" }, { "front": "Would you like something to drink?", "back": "هل تريد شيئاً للشرب؟", "romanized": "hal turid shay'an lish-shurb?" }] },
    { "id": "ar_fd_066", "levels": [{ "front": "cook", "back": "يطبخ", "romanized": "yatbukh" }, { "front": "She cooks very well.", "back": "هي تطبخ جيداً جداً.", "romanized": "hiya tatbukh jayyidan jiddan." }] },
    { "id": "ar_fd_067", "levels": [{ "front": "bake", "back": "يخبز", "romanized": "yakhbuz" }, { "front": "I bake bread on Sundays.", "back": "أخبز الخبز يوم الأحد.", "romanized": "akhbuz al-khubz yawm al-ahad." }] },
    { "id": "ar_fd_069", "levels": [{ "front": "fry", "back": "يقلي", "romanized": "yaqli" }, { "front": "Fry the onions in oil.", "back": "اقلِ البصل في الزيت.", "romanized": "iqli al-basal fi az-zayt." }] },
    { "id": "ar_fd_070", "levels": [{ "front": "roast", "back": "يشوي", "romanized": "yashwi" }, { "front": "Roast the chicken for one hour.", "back": "اشوِ الدجاج لمدة ساعة.", "romanized": "ishwi ad-dajaj li-mudat sa'a." }] },
    { "id": "ar_fd_072", "levels": [{ "front": "chop", "back": "يقطع", "romanized": "yaqta'" }, { "front": "Chop the onions.", "back": "اقطع البصل.", "romanized": "iqta' al-basal." }] },
    { "id": "ar_fd_073", "levels": [{ "front": "slice", "back": "يشرّح", "romanized": "yusharrah" }, { "front": "Slice the bread.", "back": "شرّح الخبز.", "romanized": "sharrah al-khubz." }] },
    { "id": "ar_fd_074", "levels": [{ "front": "mix", "back": "يمزج", "romanized": "yamzuj" }, { "front": "Mix all the ingredients.", "back": "امزج جميع المكونات.", "romanized": "imzuj jami' al-mukawwinat." }] },
    { "id": "ar_fd_075", "levels": [{ "front": "stir", "back": "يحرّك", "romanized": "yuharrik" }, { "front": "Stir the soup.", "back": "حرّك الحساء.", "romanized": "harrik al-hisa'." }] },
    { "id": "ar_fd_076", "levels": [{ "front": "whisk", "back": "يخفق", "romanized": "yakhfuq" }, { "front": "Whisk the eggs.", "back": "اخفق البيض.", "romanized": "ikhfuq al-bayd." }] },
    { "id": "ar_fd_077", "levels": [{ "front": "pour", "back": "يسكب", "romanized": "yaskub" }, { "front": "Pour the water into the glass.", "back": "اسكب الماء في الكوب.", "romanized": "uskub al-ma' fi al-kub." }] },
    { "id": "ar_fd_078", "levels": [{ "front": "serve", "back": "يقدّم", "romanized": "yuqaddim" }, { "front": "The waiter served the food.", "back": "النادل قدّم الطعام.", "romanized": "an-nadil qaddama at-ta'am." }] },
    { "id": "ar_fd_080", "levels": [{ "front": "feed", "back": "يطعم", "romanized": "yut'im" }, { "front": "She feeds the baby.", "back": "هي تطعم الطفل.", "romanized": "hiya tut'im at-tifl." }] },
    { "id": "ar_fd_081", "levels": [{ "front": "dine", "back": "يتناول العشاء", "romanized": "yatanawal al-asha'" }, { "front": "We dined at a nice restaurant.", "back": "تناولنا العشاء في مطعم جيد.", "romanized": "tanawalna al-asha' fi mat'am jayyid." }] },
    { "id": "ar_fd_082", "levels": [{ "front": "chew", "back": "يمضغ", "romanized": "yamdag" }, { "front": "Chew your food slowly.", "back": "امضغ طعامك ببطء.", "romanized": "umdug ta'amak bi-but'." }] },
    { "id": "ar_fd_083", "levels": [{ "front": "swallow", "back": "يبتلع", "romanized": "yabtali'" }, { "front": "Swallow the pill with water.", "back": "ابتلع الحبة بالماء.", "romanized": "ibtali' al-habba bil-ma'." }] },
    { "id": "ar_fd_084", "levels": [{ "front": "season", "back": "يتبّل", "romanized": "yutabbil" }, { "front": "Season with salt and pepper.", "back": "تبّل بالملح والفلفل.", "romanized": "tabbil bil-milh wal-filfil." }] },
    { "id": "ar_fd_086", "levels": [{ "front": "fresh", "back": "طازج", "romanized": "tazij" }, { "front": "The bread is fresh.", "back": "الخبز طازج.", "romanized": "al-khubz tazij." }] },
    { "id": "ar_fd_087", "levels": [{ "front": "ripe", "back": "ناضج", "romanized": "nadij" }, { "front": "The tomatoes are ripe.", "back": "الطماطم ناضجة.", "romanized": "at-tamatim nadija." }] },
    { "id": "ar_fd_089", "levels": [{ "front": "cooked", "back": "مطبوخ", "romanized": "matbukh" }, { "front": "Is the chicken cooked?", "back": "هل الدجاج مطبوخ؟", "romanized": "hal ad-dajaj matbukh?" }] },
    { "id": "ar_fd_090", "levels": [{ "front": "hot", "back": "ساخن", "romanized": "sakhin" }, { "front": "Be careful, the soup is hot.", "back": "انتبه، الحساء ساخن.", "romanized": "intabih, al-hisa' sakhin." }] },
    { "id": "ar_fd_091", "levels": [{ "front": "cold", "back": "بارد", "romanized": "barid" }, { "front": "My coffee is cold.", "back": "قهوتي باردة.", "romanized": "qahwati barida." }] },
