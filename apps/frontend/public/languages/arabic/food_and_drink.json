    { "id": "ar_fd_002", "levels": [{ "front": "bread", "back": "خبز", "romanized": "khubz" }, { "front": "I'd like some bread.", "back": "أريد بعض الخبز.", "romanized": "urid ba'd al-khubz." }] },
    { "id": "ar_fd_003", "levels": [{ "front": "rice", "back": "أرز", "romanized": "aruzz" }, { "front": "I like rice with vegetables.", "back": "أحب الأرز مع الخضروات.", "romanized": "uhibb al-aruzz ma'a al-khadrawat." }] },
    { "id": "ar_fd_004", "levels": [{ "front": "milk", "back": "حليب", "romanized": "halib" }, { "front": "Do you want milk?", "back": "هل تريد حليباً؟", "romanized": "hal turid haliban?" }] },
    { "id": "ar_fd_005", "levels": [{ "front": "egg", "back": "بيضة", "romanized": "bayda" }, { "front": "I eat two eggs for breakfast.", "back": "آكل بيضتين في الفطور.", "romanized": "akul baydatayn fi al-futur." }] },
