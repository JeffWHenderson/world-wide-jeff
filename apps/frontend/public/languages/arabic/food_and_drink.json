    { "id": "ar_fd_027", "levels": [{ "front": "breakfast", "back": "فطور", "romanized": "futur" }, { "front": "I eat breakfast at seven.", "back": "آكل الفطور في السابعة.", "romanized": "akul al-futur fi as-sabi'a." }] },
    { "id": "ar_fd_028", "levels": [{ "front": "lunch", "back": "غداء", "romanized": "ghada'" }, { "front": "Let's have lunch together.", "back": "لنتناول الغداء معاً.", "romanized": "lnatarawal al-ghada' ma'an." }] },
    { "id": "ar_fd_029", "levels": [{ "front": "dinner", "back": "عشاء", "romanized": "asha'" }, { "front": "Dinner is ready.", "back": "العشاء جاهز.", "romanized": "al-asha' jahiz." }] },
    { "id": "ar_fd_030", "levels": [{ "front": "to cook", "back": "يطبخ", "romanized": "yatbukh" }, { "front": "My mother cooks very well.", "back": "أمي تطبخ جيداً جداً.", "romanized": "ummi tatbukh jayyidan jiddan." }] },
