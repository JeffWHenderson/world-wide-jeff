{
  "id": "human_body",
  "name": "Human Body",
  "language": "arabic",
  "stories": [],
  "pictureLessons": [],
  "cards": [
    { "id": "ar_hb_001", "levels": [{ "front": "head", "back": "رأس", "romanized": "ra's", "grammarNote": "Pain in Arabic: '[body part] يؤلمني / تؤلمني' (yu'limuni / tu'limuni) = '[body part] hurts me'. يؤلم is for masculine nouns, تؤلم for feminine. Alternatively: 'عندي ألم في [body part]' (indi alam fi...) = I have pain in [body part]." }, { "front": "My head hurts.", "back": "رأسي يؤلمني.", "romanized": "ra'si yu'limuni." }] },
    { "id": "ar_hb_002", "levels": [{ "front": "hair", "back": "شعر", "romanized": "sha'r" }, { "front": "She has long hair.", "back": "لديها شعر طويل.", "romanized": "ladayha sha'r tawil." }] },
    { "id": "ar_hb_003", "levels": [{ "front": "face", "back": "وجه", "romanized": "wajh" }, { "front": "Wash your face.", "back": "اغسل وجهك.", "romanized": "ighsil wajhak." }] },
    { "id": "ar_hb_004", "levels": [{ "front": "eye", "back": "عين", "romanized": "ayn" }, { "front": "He has blue eyes.", "back": "عيناه زرقاوان.", "romanized": "aynahu zarqawan." }] },
    { "id": "ar_hb_005", "levels": [{ "front": "ear", "back": "أذن", "romanized": "udhn" }, { "front": "My ear hurts.", "back": "أذني تؤلمني.", "romanized": "udhni tu'limuni." }] },
    { "id": "ar_hb_006", "levels": [{ "front": "nose", "back": "أنف", "romanized": "anf" }, { "front": "My nose is cold.", "back": "أنفي بارد.", "romanized": "anfi barid." }] },
    { "id": "ar_hb_007", "levels": [{ "front": "mouth", "back": "فم", "romanized": "fam" }, { "front": "Open your mouth.", "back": "افتح فمك.", "romanized": "iftah famak." }] },
    { "id": "ar_hb_008", "levels": [{ "front": "lip", "back": "شفة", "romanized": "shafa" }, { "front": "She has red lips.", "back": "شفتاها حمراوان.", "romanized": "shafataha hamrawan." }] },
    { "id": "ar_hb_009", "levels": [{ "front": "tooth (teeth)", "back": "سن / أسنان", "romanized": "sinn / asnan" }, { "front": "I have a toothache.", "back": "سني تؤلمني.", "romanized": "sinni tu'limuni." }] },
    { "id": "ar_hb_010", "levels": [{ "front": "tongue", "back": "لسان", "romanized": "lisan" }, { "front": "Stick out your tongue.", "back": "أخرج لسانك.", "romanized": "akhrij lisanak." }] },
    { "id": "ar_hb_011", "levels": [{ "front": "neck", "back": "رقبة", "romanized": "raqaba" }, { "front": "My neck is stiff.", "back": "رقبتي متصلبة.", "romanized": "raqabati mutasallaba." }] },
    { "id": "ar_hb_012", "levels": [{ "front": "arm", "back": "ذراع", "romanized": "dhira'" }, { "front": "I broke my arm.", "back": "كسرت ذراعي.", "romanized": "kasartu dhira'i." }] },
    { "id": "ar_hb_013", "levels": [{ "front": "hand", "back": "يد", "romanized": "yad", "grammarNote": "Arabic has a dual form for pairs. يد (yad = hand) becomes يدان (yadan = two hands). In 'اغسل يديك' (ighsil yadayk), يديك is the dual possessive. Arabic uses dual forms for body parts that come in pairs: عينان (aynان = two eyes), رجلان (rijlan = two legs)." }, { "front": "Wash your hands.", "back": "اغسل يديك.", "romanized": "ighsil yadayk." }] },
    { "id": "ar_hb_014", "levels": [{ "front": "finger", "back": "إصبع", "romanized": "isba'" }, { "front": "He cut his finger.", "back": "قطع إصبعه.", "romanized": "qata'a isba'ahu." }] },
    { "id": "ar_hb_015", "levels": [{ "front": "chest", "back": "صدر", "romanized": "sadr" }, { "front": "He has chest pain.", "back": "عنده ألم في الصدر.", "romanized": "indahu alam fi as-sadr." }] },
    { "id": "ar_hb_016", "levels": [{ "front": "back", "back": "ظهر", "romanized": "dahr" }, { "front": "My back hurts.", "back": "ظهري يؤلمني.", "romanized": "dahri yu'limuni." }] },
    { "id": "ar_hb_017", "levels": [{ "front": "heart", "back": "قلب", "romanized": "qalb" }, { "front": "My heart is beating fast.", "back": "قلبي يدق بسرعة.", "romanized": "qalbi yaduqq bi-sur'a." }] },
    { "id": "ar_hb_018", "levels": [{ "front": "stomach", "back": "بطن / معدة", "romanized": "batn / mi'da" }, { "front": "My stomach hurts.", "back": "بطني يؤلمني.", "romanized": "batni yu'limuni." }] },
    { "id": "ar_hb_019", "levels": [{ "front": "muscle", "back": "عضلة", "romanized": "'adala" }, { "front": "I pulled a muscle.", "back": "شددت عضلة.", "romanized": "shadadtu 'adala." }] },
    { "id": "ar_hb_020", "levels": [{ "front": "waist", "back": "خصر", "romanized": "khasr" }, { "front": "She has a slim waist.", "back": "لديها خصر رفيع.", "romanized": "ladayha khasr rafi'." }] },
    { "id": "ar_hb_021", "levels": [{ "front": "skin", "back": "جلد", "romanized": "jild" }, { "front": "Her skin is soft.", "back": "جلدها ناعم.", "romanized": "jilduha na'im." }] },
    { "id": "ar_hb_022", "levels": [{ "front": "blood", "back": "دم", "romanized": "dam" }, { "front": "He donated blood.", "back": "تبرّع بالدم.", "romanized": "tabarra'a bil-dam." }] },
    { "id": "ar_hb_023", "levels": [{ "front": "brain", "back": "دماغ", "romanized": "dimagh" }, { "front": "The brain is complex.", "back": "الدماغ معقد.", "romanized": "ad-dimagh mu'aqqad." }] },
    { "id": "ar_hb_024", "levels": [{ "front": "skull", "back": "جمجمة", "romanized": "jumjuma" }, { "front": "The skull protects the brain.", "back": "الجمجمة تحمي الدماغ.", "romanized": "al-jumjuma tahmi ad-dimagh." }] },
    { "id": "ar_hb_025", "levels": [{ "front": "breast", "back": "صدر / ثدي", "romanized": "sadr / thady" }, { "front": "She felt pain in her chest.", "back": "شعرت بألم في صدرها.", "romanized": "sha'arat bi-alam fi sadriha." }] },
    { "id": "ar_hb_026", "levels": [{ "front": "leg", "back": "ساق", "romanized": "saq" }, { "front": "My leg is tired.", "back": "ساقي متعبة.", "romanized": "saqi muta'aba." }] },
    { "id": "ar_hb_027", "levels": [{ "front": "foot (feet)", "back": "قدم / أقدام", "romanized": "qadam / aqdام" }, { "front": "My feet hurt.", "back": "قدماي تؤلمانني.", "romanized": "qadamay tu'limanini." }] },
    { "id": "ar_hb_028", "levels": [{ "front": "toe", "back": "إصبع القدم", "romanized": "isba' al-qadam" }, { "front": "He stubbed his toe.", "back": "اصطدم بإصبع قدمه.", "romanized": "istadama bi-isba' qadamihi." }] },
    { "id": "ar_hb_029", "levels": [{ "front": "joint", "back": "مفصل", "romanized": "mifsal" }, { "front": "My joints are stiff.", "back": "مفاصلي متصلبة.", "romanized": "mafasili mutasallaba." }] },
    { "id": "ar_hb_030", "levels": [{ "front": "breath", "back": "نَفَس / تنفس", "romanized": "nafas / tanaffus" }, { "front": "Hold your breath.", "back": "احبس نَفَسك.", "romanized": "ihbis nafasak." }] },
    { "id": "ar_hb_031", "levels": [{ "front": "see", "back": "يرى", "romanized": "yara" }, { "front": "I can see clearly.", "back": "أستطيع الرؤية بوضوح.", "romanized": "astati' ar-ru'ya bi-wuduh." }] },
    { "id": "ar_hb_032", "levels": [{ "front": "hear", "back": "يسمع", "romanized": "yasma'" }, { "front": "I can't hear you.", "back": "لا أسمعك.", "romanized": "la asma'uk." }] },
    { "id": "ar_hb_033", "levels": [{ "front": "smell", "back": "يشمّ", "romanized": "yashamm" }, { "front": "I can smell the flowers.", "back": "أشمّ رائحة الزهور.", "romanized": "ashamm ra'ihat az-zuhur." }] },
    { "id": "ar_hb_034", "levels": [{ "front": "taste", "back": "يتذوّق", "romanized": "yadhadhawwaq" }, { "front": "Taste this soup.", "back": "تذوّق هذا الحساء.", "romanized": "tadhawwaq hadha al-hisa'." }] },
    { "id": "ar_hb_035", "levels": [{ "front": "touch", "back": "يلمس", "romanized": "yalmas" }, { "front": "Don't touch that!", "back": "لا تلمس ذلك!", "romanized": "la talmas dhalika!" }] },
    { "id": "ar_hb_036", "levels": [{ "front": "breathe", "back": "يتنفس", "romanized": "yatanaffas" }, { "front": "Breathe slowly.", "back": "تنفّس ببطء.", "romanized": "tanaffas bi-but'." }] },
    { "id": "ar_hb_037", "levels": [{ "front": "bend", "back": "ينحني", "romanized": "yankhani" }, { "front": "Bend your knees.", "back": "انحنِ ركبتيك.", "romanized": "inkhani rukbatayk." }] },
    { "id": "ar_hb_038", "levels": [{ "front": "stretch", "back": "يمدّ / يتمدّد", "romanized": "yamudd / yatamaddad" }, { "front": "Stretch your arms.", "back": "مدّ ذراعيك.", "romanized": "mudd dhira'ayk." }] },
    { "id": "ar_hb_039", "levels": [{ "front": "flex", "back": "يثني", "romanized": "yathni" }, { "front": "Flex your muscles.", "back": "اثنِ عضلاتك.", "romanized": "ithni 'adalatik." }] },
    { "id": "ar_hb_040", "levels": [{ "front": "blink", "back": "يرمش", "romanized": "yarmish" }, { "front": "Don't blink.", "back": "لا ترمش.", "romanized": "la tarmish." }] },
    { "id": "ar_hb_041", "levels": [{ "front": "sweat", "back": "يتعرّق", "romanized": "yata'arraq" }, { "front": "I sweat when I run.", "back": "أتعرّق عندما أركض.", "romanized": "ata'arraq indama arkud." }] },
    { "id": "ar_hb_042", "levels": [{ "front": "bleed", "back": "ينزف", "romanized": "yanzif" }, { "front": "The wound is bleeding.", "back": "الجرح ينزف.", "romanized": "al-jurh yanzif." }] },
    { "id": "ar_hb_043", "levels": [{ "front": "feel", "back": "يشعر", "romanized": "yash'ur" }, { "front": "How do you feel?", "back": "كيف تشعر؟", "romanized": "kayfa tash'ur?" }] },
    { "id": "ar_hb_044", "levels": [{ "front": "think", "back": "يفكّر", "romanized": "yufakkir" }, { "front": "What are you thinking about?", "back": "بمَ تفكّر؟", "romanized": "bi-ma tufakkir?" }] },
    { "id": "ar_hb_045", "levels": [{ "front": "move", "back": "يتحرّك", "romanized": "yataharrak" }, { "front": "I can't move my arm.", "back": "لا أستطيع تحريك ذراعي.", "romanized": "la astati' tahrik dhira'i." }] },
    { "id": "ar_hb_046", "levels": [{ "front": "bony", "back": "ذو عظام بارزة", "romanized": "dhu 'izam bariza" }, { "front": "His hands are bony.", "back": "يداه ذواتا عظام بارزة.", "romanized": "yadahu dhawata 'izam bariza." }] },
    { "id": "ar_hb_047", "levels": [{ "front": "hairy", "back": "كثيف الشعر", "romanized": "kathif ash-sha'r" }, { "front": "He has hairy arms.", "back": "لديه ذراعان كثيفا الشعر.", "romanized": "ladayhi dhira'an kathifa ash-sha'r." }] },
    { "id": "ar_hb_048", "levels": [{ "front": "soft", "back": "ناعم / طريّ", "romanized": "na'im / tariyy" }, { "front": "The tissue is soft.", "back": "النسيج ناعم.", "romanized": "an-nasij na'im." }] },
    { "id": "ar_hb_049", "levels": [{ "front": "sore", "back": "مؤلم", "romanized": "mu'lim" }, { "front": "My muscles are sore.", "back": "عضلاتي مؤلمة.", "romanized": "'adalati mu'lima." }] },
    { "id": "ar_hb_050", "levels": [{ "front": "left", "back": "أيسر", "romanized": "aysar" }, { "front": "I hurt my left knee.", "back": "ركبتي اليسرى تؤلمني.", "romanized": "rukbati al-yusra tu'limuni." }] },
    { "id": "ar_hb_051", "levels": [{ "front": "right", "back": "أيمن", "romanized": "ayman" }, { "front": "I broke my right arm.", "back": "كسرت ذراعي اليمنى.", "romanized": "kasartu dhira'i al-yumna." }] },
    { "id": "ar_hb_052", "levels": [{ "front": "upper", "back": "علوي", "romanized": "ulwi" }, { "front": "The upper body is strong.", "back": "الجزء العلوي من الجسم قوي.", "romanized": "al-juz' al-ulwi min al-jism qawi." }] },
    { "id": "ar_hb_053", "levels": [{ "front": "lower", "back": "سفلي", "romanized": "sufli" }, { "front": "He has lower back pain.", "back": "عنده ألم في أسفل الظهر.", "romanized": "indahu alam fi asfal adh-dahr." }] },
    { "id": "ar_hb_054", "levels": [{ "front": "body", "back": "جسم / جسد", "romanized": "jism / jasad" }, { "front": "The human body is amazing.", "back": "الجسم البشري رائع.", "romanized": "al-jism al-bashari ra'i'." }] },
    { "id": "ar_hb_055", "levels": [{ "front": "human (adjective)", "back": "بشري", "romanized": "bashari" }, { "front": "It's part of human biology.", "back": "إنه جزء من علم الأحياء البشري.", "romanized": "innahu juz' min 'ilm al-ahya' al-bashari." }] }
  ]
}
