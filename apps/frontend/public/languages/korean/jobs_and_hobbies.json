  "cards": [
    { "id": "ko_jh_001", "levels": [{ "front": "Doctor", "back": "의사", "romanized": "uisa", "grammarNote": "In Korean, professions are stated directly without an article: '저는 의사예요' (jeoneun uisayeyo, I am a doctor). The copula '이에요/예요' (ieyo/yeyo) attaches to the noun. No equivalent of 'a/an' is needed." }, { "front": "He is a doctor.", "back": "그는 의사예요.", "romanized": "geuneun uisayeyo" }] },
    { "id": "ko_jh_002", "levels": [{ "front": "Nurse", "back": "간호사", "romanized": "ganhosa" }, { "front": "She is a nurse.", "back": "그녀는 간호사예요.", "romanized": "geunyeoneun ganhosayeyo" }] },
    { "id": "ko_jh_003", "levels": [{ "front": "Engineer", "back": "엔지니어 / 기술자", "romanized": "enjinieo / gisulcha" }, { "front": "My brother is an engineer.", "back": "오빠는 엔지니어예요.", "romanized": "oppaneun enjinieoyeyo" }] },
    { "id": "ko_jh_004", "levels": [{ "front": "Programmer", "back": "프로그래머", "romanized": "peurogeuraeмео" }, { "front": "I work as a programmer.", "back": "저는 프로그래머로 일해요.", "romanized": "jeoneun peuroguraemerо ilhaeyo" }] },
