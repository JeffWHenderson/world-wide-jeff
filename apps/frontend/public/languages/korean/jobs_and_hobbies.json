    { "id": "ko_jh_019", "levels": [{ "front": "Playing an instrument (e.g., Guitar)", "back": "악기 연주 / 기타 치기", "romanized": "akgi yeonju / gita chigi", "grammarNote": "For string/keyboard instruments, use '치다' (chida): '기타를 쳐요' (gitareul chyeoyo, I play guitar). For wind instruments, '불다' (bulda): '플루트를 불어요'. For drums, '치다' is also used: '드럼을 쳐요'." }, { "front": "I play the guitar.", "back": "기타를 쳐요.", "romanized": "gitareul chyeoyo" }] },
