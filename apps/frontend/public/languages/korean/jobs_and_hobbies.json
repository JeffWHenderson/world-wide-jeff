  "cards": [
    { "id": "ko_jh_001", "levels": [{ "front": "Work / job", "back": "일 / 직업", "romanized": "il / jigeop" }, { "front": "What do you do for work?", "back": "무슨 일을 해요?", "romanized": "Museun ireul haeyo?" }] },
    { "id": "ko_jh_002", "levels": [{ "front": "To work", "back": "일하다", "romanized": "ilhada" }, { "front": "I work at a company.", "back": "회사에서 일해요.", "romanized": "Hoesaeseo ilhaeyo." }] },
    { "id": "ko_jh_003", "levels": [{ "front": "Company / office", "back": "회사", "romanized": "hoesa" }, { "front": "I go to work at nine.", "back": "아홉 시에 회사에 가요.", "romanized": "Ahop sie hoesa-e gayo." }] },
    { "id": "ko_jh_004", "levels": [{ "front": "Meeting", "back": "회의", "romanized": "hoeui" }, { "front": "I have a meeting at two.", "back": "두 시에 회의가 있어요.", "romanized": "Du sie hoeui-ga isseoyo." }] },
    { "id": "ko_jh_005", "levels": [{ "front": "Colleague", "back": "동료", "romanized": "dongnyeo" }, { "front": "My colleagues are kind.", "back": "동료들이 친절해요.", "romanized": "Dongnyodeuri chinjeolhaeyo." }] },
    { "id": "ko_jh_006", "levels": [{ "front": "Boss", "back": "상사 / 사장님", "romanized": "sangsa / sajangnim", "grammarNote": "님 (nim) is an honorific suffix added to titles. 사장님 (company director/owner), 선생님 (teacher), 의사 선생님 (doctor). Using 님 shows respect. Calling your boss by their first name alone would be very rude in Korean workplace culture." }, { "front": "My boss is strict.", "back": "사장님이 엄격해요.", "romanized": "Sajangnemi eomgyeokhaeyo." }] },
    { "id": "ko_jh_007", "levels": [{ "front": "Salary", "back": "월급", "romanized": "wolgup" }, { "front": "The salary isn't that high.", "back": "월급이 그렇게 높지 않아요.", "romanized": "Wolgubi geureoke nopji anayo." }] },
    { "id": "ko_jh_008", "levels": [{ "front": "Doctor", "back": "의사", "romanized": "uisa" }, { "front": "I want to become a doctor.", "back": "의사가 되고 싶어요.", "romanized": "Uisaga doego sipeoyo." }] },
    { "id": "ko_jh_009", "levels": [{ "front": "Teacher", "back": "선생님", "romanized": "seonsaengnim" }, { "front": "She's an English teacher.", "back": "그녀는 영어 선생님이에요.", "romanized": "Geunyeoneun yeongeo seonsaengnim-ieyo." }] },
    { "id": "ko_jh_010", "levels": [{ "front": "Student", "back": "학생", "romanized": "haksaeng" }, { "front": "I'm a university student.", "back": "저는 대학생이에요.", "romanized": "Jeoneun daehaksaengieyo." }] },
    { "id": "ko_jh_011", "levels": [{ "front": "Chef / cook", "back": "요리사", "romanized": "yorisa" }, { "front": "He's a famous chef.", "back": "그는 유명한 요리사예요.", "romanized": "Geuneun yumyeonghan yorisayeyo." }] },
    { "id": "ko_jh_012", "levels": [{ "front": "Hobby / free time activity", "back": "취미", "romanized": "chwimi" }, { "front": "What are your hobbies?", "back": "취미가 뭐예요?", "romanized": "Chwimiga mwoyeyo?" }] },
    { "id": "ko_jh_013", "levels": [{ "front": "To read", "back": "읽다", "romanized": "ikda" }, { "front": "I like reading books.", "back": "책 읽는 걸 좋아해요.", "romanized": "Chaek ingneun geol joahaeyo." }] },
    { "id": "ko_jh_014", "levels": [{ "front": "To watch TV / dramas", "back": "드라마를 보다", "romanized": "deuramaReul boda", "grammarNote": "Korean dramas (드라마, K-드라마) are a huge part of Korean culture. Talking about which drama you're watching is a very natural conversation topic. '요즘 무슨 드라마 봐요?' (What drama are you watching these days?) is a common small-talk opener." }, { "front": "I'm watching a Korean drama.", "back": "한국 드라마를 봐요.", "romanized": "Hanguk deuramaReul bwayo." }] },
    { "id": "ko_jh_015", "levels": [{ "front": "To listen to music", "back": "음악을 듣다", "romanized": "eumageul deutda" }, { "front": "I listen to K-pop.", "back": "케이팝을 들어요.", "romanized": "Keipapeul deuleoyo." }] },
    { "id": "ko_jh_016", "levels": [{ "front": "To exercise / work out", "back": "운동하다", "romanized": "undonghada" }, { "front": "I exercise every morning.", "back": "매일 아침 운동해요.", "romanized": "Maeil achim undonghaeyo." }] },
    { "id": "ko_jh_017", "levels": [{ "front": "To play games", "back": "게임하다", "romanized": "geimhada" }, { "front": "I play games on weekends.", "back": "주말에 게임을 해요.", "romanized": "Jumale geimeul haeyo." }] },
    { "id": "ko_jh_018", "levels": [{ "front": "To travel", "back": "여행하다", "romanized": "yeohaenghada" }, { "front": "I love to travel.", "back": "여행을 너무 좋아해요.", "romanized": "Yeohaengeul neomu joahaeyo." }] },
    { "id": "ko_jh_019", "levels": [{ "front": "To cook", "back": "요리하다", "romanized": "yorihada" }, { "front": "I cook Korean food at home.", "back": "집에서 한국 요리를 해요.", "romanized": "Jibeseo hanguk yorireul haeyo." }] },
