    { "id": "ko_jh_010", "levels": [{ "front": "Lawyer", "back": "변호사", "romanized": "byeonhosa" }, { "front": "My sister is a lawyer.", "back": "언니는 변호사예요.", "romanized": "eonnineun byeonhosayeyo" }] },
