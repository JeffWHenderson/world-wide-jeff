  "stories": ["at_the_restaurant", "at_the_market"],
  "cards": [
    { "id": "ko_fd_001", "levels": [{ "front": "Rice (cooked)", "back": "밥", "romanized": "bap" }, { "front": "I eat rice every day.", "back": "매일 밥을 먹어요.", "romanized": "Maeil babeul meogeoyo." }] },
    { "id": "ko_fd_002", "levels": [{ "front": "Kimchi", "back": "김치", "romanized": "gimchi" }, { "front": "I love kimchi.", "back": "김치를 너무 좋아해요.", "romanized": "Gimchireul neomu joahaeyo." }] },
    { "id": "ko_fd_003", "levels": [{ "front": "Noodles / ramen", "back": "면 / 라면", "romanized": "myeon / ramyeon" }, { "front": "I want to eat ramen.", "back": "라면 먹고 싶어요.", "romanized": "Ramyeon meokgo sipeoyo." }] },
    { "id": "ko_fd_004", "levels": [{ "front": "Meat", "back": "고기", "romanized": "gogi" }, { "front": "I like Korean BBQ.", "back": "한국 바비큐를 좋아해요.", "romanized": "Hanguk babikyu-reul joahaeyo." }] },
    { "id": "ko_fd_005", "levels": [{ "front": "Fish", "back": "생선", "romanized": "saengseon" }, { "front": "The fish is fresh.", "back": "생선이 신선해요.", "romanized": "Saengseoni sinseonhaeyo." }] },
    { "id": "ko_fd_006", "levels": [{ "front": "Vegetables", "back": "채소 / 야채", "romanized": "chaeso / yachae" }, { "front": "I eat a lot of vegetables.", "back": "채소를 많이 먹어요.", "romanized": "Chaesoreul mani meogeoyo." }] },
    { "id": "ko_fd_007", "levels": [{ "front": "Egg", "back": "계란 / 달걀", "romanized": "gyeran / dalgyal" }, { "front": "I'd like two fried eggs.", "back": "계란 프라이 두 개 주세요.", "romanized": "Gyeran peurei du gae juseyo." }] },
    { "id": "ko_fd_008", "levels": [{ "front": "Tofu", "back": "두부", "romanized": "dubu" }, { "front": "Tofu soup is warm and delicious.", "back": "순두부찌개가 따뜻하고 맛있어요.", "romanized": "Sundubujjigaega ttatteutago masisseoyo." }] },
    { "id": "ko_fd_009", "levels": [{ "front": "Coffee", "back": "커피", "romanized": "keopi" }, { "front": "Two iced coffees, please.", "back": "아이스 아메리카노 두 잔 주세요.", "romanized": "Aiseu amerikano du jan juseyo." }] },
    { "id": "ko_fd_010", "levels": [{ "front": "Tea", "back": "차", "romanized": "cha" }, { "front": "I'd like barley tea.", "back": "보리차 주세요.", "romanized": "Boricha juseyo." }] },
    { "id": "ko_fd_011", "levels": [{ "front": "Water", "back": "물", "romanized": "mul" }, { "front": "Cold water, please.", "back": "차가운 물 주세요.", "romanized": "Chagaun mul juseyo." }] },
    { "id": "ko_fd_012", "levels": [{ "front": "Beer", "back": "맥주", "romanized": "maekju" }, { "front": "Two beers, please.", "back": "맥주 두 병 주세요.", "romanized": "Maekju du byeong juseyo." }] },
    { "id": "ko_fd_013", "levels": [{ "front": "Soju", "back": "소주", "romanized": "soju", "grammarNote": "소주 (soju) is Korea's most popular alcoholic drink — a clear distilled spirit. Typically 16–25% alcohol. Often drunk with food (안주, anju = drinking snacks). Sharing bottles and pouring for others is an important social custom." }, { "front": "Shall we drink soju?", "back": "소주 마실까요?", "romanized": "Soju masilkkayo?" }] },
    { "id": "ko_fd_014", "levels": [{ "front": "Spicy", "back": "맵다", "romanized": "maepda" }, { "front": "Is this spicy?", "back": "이거 매워요?", "romanized": "Igeo maewayo?" }] },
    { "id": "ko_fd_015", "levels": [{ "front": "Delicious", "back": "맛있다", "romanized": "masitda" }, { "front": "So delicious!", "back": "너무 맛있어요!", "romanized": "Neomu masisseoyo!" }] },
    { "id": "ko_fd_016", "levels": [{ "front": "Not spicy", "back": "안 맵다", "romanized": "an maepda" }, { "front": "Is there a non-spicy option?", "back": "안 매운 것도 있어요?", "romanized": "An maeun geotdo isseoyo?" }] },
    { "id": "ko_fd_017", "levels": [{ "front": "The menu", "back": "메뉴", "romanized": "menyu" }, { "front": "Can I see the menu?", "back": "메뉴 볼 수 있어요?", "romanized": "Menyu bol su isseoyo?" }] },
    { "id": "ko_fd_018", "levels": [{ "front": "The bill", "back": "계산", "romanized": "gyesan", "grammarNote": "To ask for the bill in Korea, say '계산해 주세요' (gyesanhae juseyo) or simply '계산이요' (gyesaniyo). In many Korean restaurants, you pay at the counter rather than at the table." }, { "front": "Bill, please.", "back": "계산해 주세요.", "romanized": "Gyesanhae juseyo." }] },
    { "id": "ko_fd_019", "levels": [{ "front": "One portion / one serving", "back": "일 인분", "romanized": "il inbun", "grammarNote": "Korean menus list dishes per portion (인분, inbun). You order by number of servings: 삼겹살 이 인분 주세요 (two servings of pork belly, please). Most grilled meat dishes require a minimum of two servings." }, { "front": "Two servings of pork belly, please.", "back": "삼겹살 이 인분 주세요.", "romanized": "Samgyeopsal i inbun juseyo." }] },
    { "id": "ko_fd_020", "levels": [{ "front": "I'm hungry", "back": "배고프다", "romanized": "baegopuda" }, { "front": "I'm starving!", "back": "너무 배고파요!", "romanized": "Neomu baegopayo!" }] },
    { "id": "ko_fd_021", "levels": [{ "front": "I'm full", "back": "배부르다", "romanized": "baeburuda" }, { "front": "I'm full. It was delicious.", "back": "배불러요. 맛있었어요.", "romanized": "Baebulleoyo. Masisseoyo." }] },
    { "id": "ko_fd_022", "levels": [{ "front": "To order", "back": "주문하다", "romanized": "jumunhada" }, { "front": "I'd like to order.", "back": "주문할게요.", "romanized": "Jumunhalgeyo." }] },
    { "id": "ko_fd_023", "levels": [{ "front": "Excuse me (getting attention)", "back": "저기요!", "romanized": "Jeogiyo!" }, { "front": "Excuse me! Over here please.", "back": "저기요! 여기요.", "romanized": "Jeogiyo! Yeogiyo." }] },
    { "id": "ko_fd_024", "levels": [{ "front": "Refill (free side dishes)", "back": "리필 / 더 주세요", "romanized": "ripil / deo juseyo", "grammarNote": "A wonderful feature of Korean dining: 반찬 (banchan), the small side dishes served with every meal, are usually free and refillable. Just ask '김치 더 주세요' (more kimchi please) or point and say '이거 더 주세요'." }, { "front": "More kimchi please.", "back": "김치 더 주세요.", "romanized": "Gimchi deo juseyo." }] },
    { "id": "ko_fd_025", "levels": [{ "front": "Takeout", "back": "포장", "romanized": "pojang" }, { "front": "Is this for here or takeout?", "back": "드시고 가세요, 가져가세요?", "romanized": "Deusigo gaseyo, gajyeogaseyo?" }] }
  ]
}
