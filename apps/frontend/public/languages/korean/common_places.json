    {"id": "ko_cp_001", "levels": [{"front": "Home", "back": "집 / 가정", "romanized": "jip / gajeong", "grammarNote": "'Jip' (집) is the physical house or home. '집에 가다' (jibe gada) means to go home. In Korean, location particles are: '에' (e) for direction/existence and '에서' (eseo) for actions at a place."}, {"front": "I'm going home.", "back": "집에 가요.", "romanized": "jibe gayo", "literal": "Home to go."}]},
    {"id": "ko_cp_002", "levels": [{"front": "Apartment", "back": "아파트", "romanized": "apateu", "grammarNote": "Korea has some of the world's highest rates of apartment living. '아파트' (apateu) refers to large high-rise apartment complexes (different from the Western sense of 'apartment'). Complexes are often called '단지' (danji)."}, {"front": "I live in an apartment.", "back": "아파트에 살아요.", "romanized": "apateue sarayo", "literal": "Apartment at live."}]},
