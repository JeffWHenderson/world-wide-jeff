{
  "id": "everyday_phrases",
  "name": "Everyday Phrases",
  "language": "korean",
  "stories": ["morning_routine", "meeting_a_friend", "making_plans"],
  "cards": [
    { "id": "ko_ep_001", "levels": [{ "front": "I (polite)", "back": "저", "romanized": "jeo" }, { "front": "I am a student.", "back": "저는 학생이에요.", "romanized": "Jeoneun haksaengieyo." }] },
    { "id": "ko_ep_002", "levels": [{ "front": "You (informal)", "back": "너", "romanized": "neo" }, { "front": "You speak Korean well.", "back": "너는 한국어를 잘 해.", "romanized": "Neoneun hangugeo-reul jal hae." }] },
    { "id": "ko_ep_003", "levels": [{ "front": "He", "back": "그", "romanized": "geu", "grammarNote": "Korean doesn't use pronouns as frequently as English. It's more natural to repeat the person's name or use their title (선생님, 친구 etc.) than to say 그 (he) or 그녀 (she), which can sound unnatural in speech." }, { "front": "He is my friend.", "back": "그는 제 친구예요.", "romanized": "Geuneun je chin-guye-yo." }] },
    { "id": "ko_ep_004", "levels": [{ "front": "She", "back": "그녀", "romanized": "geunyeo" }, { "front": "She works here.", "back": "그녀는 여기서 일해요.", "romanized": "Geunyeoneun yeogiseo ilhaeyo." }] },
    { "id": "ko_ep_005", "levels": [{ "front": "We", "back": "우리", "romanized": "uri", "grammarNote": "우리 (uri) means both 'we' and 'our'. Koreans often say 우리 where English uses 'my': 우리 집 (our house = my house), 우리 엄마 (our mom = my mom). This reflects Korea's collectivist culture." }, { "front": "We live here.", "back": "우리는 여기 살아요.", "romanized": "Urineun yeogi sarayo." }] },
    { "id": "ko_ep_006", "levels": [{ "front": "They", "back": "그들", "romanized": "geudeul" }, { "front": "They eat together.", "back": "그들은 같이 먹어요.", "romanized": "Geudeureun gachi meogeoyo." }] },
    { "id": "ko_ep_007", "levels": [{ "front": "My (polite)", "back": "제", "romanized": "je" }, { "front": "My name is Minjun.", "back": "제 이름은 민준이에요.", "romanized": "Je ireumeun Minjunieyo." }] },
    { "id": "ko_ep_008", "levels": [{ "front": "Your (informal)", "back": "네/니", "romanized": "ne/ni" }, { "front": "What is your name?", "back": "이름이 뭐예요?", "romanized": "Ireumi mwoyeyo?" }] },
    { "id": "ko_ep_009", "levels": [{ "front": "His / Her", "back": "그의 / 그녀의", "romanized": "geuui / geunyeoui" }, { "front": "Her bag is big.", "back": "그녀의 가방이 커요.", "romanized": "Geunyeoui gabangi keoyo." }] },
    { "id": "ko_ep_010", "levels": [{ "front": "Who", "back": "누구", "romanized": "nugu" }, { "front": "Who is that person?", "back": "저 사람이 누구예요?", "romanized": "Jeo sarami nuguyeyo?" }] },
    { "id": "ko_ep_011", "levels": [{ "front": "What", "back": "뭐 / 무엇", "romanized": "mwo / mueot" }, { "front": "What do you want?", "back": "뭐 원해요?", "romanized": "Mwo wonhaeyo?" }] },
    { "id": "ko_ep_012", "levels": [{ "front": "To be (descriptive)", "back": "이다", "romanized": "ida", "grammarNote": "Korean has two 'to be' verbs: 이다 (ida) = to be (identity/definition), and 있다 (itda) = to exist/be located. After a consonant: 이에요. After a vowel: 예요. '저는 학생이에요' = I am a student. '여기 있어요' = It is here." }, { "front": "I am a teacher.", "back": "저는 선생님이에요.", "romanized": "Jeoneun seonsaengnim-ieyo." }] },
    { "id": "ko_ep_013", "levels": [{ "front": "To have / to exist", "back": "있다", "romanized": "itda", "grammarNote": "있다 (itda) means both 'to have' and 'to exist/be located'. 없다 (eopda) is its opposite (to not have / to not exist). '돈이 있어요' = I have money. '돈이 없어요' = I don't have money." }, { "front": "I have money.", "back": "돈이 있어요.", "romanized": "Doni isseoyo." }] },
    { "id": "ko_ep_014", "levels": [{ "front": "To do", "back": "하다", "romanized": "hada", "grammarNote": "하다 (hada) is one of the most common verbs. It attaches to nouns to form compound verbs: 공부하다 (study), 일하다 (work), 전화하다 (call), 요리하다 (cook). 해요 is the polite present tense form." }, { "front": "What are you doing?", "back": "뭐 해요?", "romanized": "Mwo haeyo?" }] },
    { "id": "ko_ep_015", "levels": [{ "front": "To go", "back": "가다", "romanized": "gada", "grammarNote": "Korean verbs conjugate based on speech level, not subject. Polite/informal: 가요 (gayo). Formal: 갑니다 (gamnida). Past polite: 갔어요 (gasseoyo). Future/intention: 갈 거예요 (gal geoyeyo)." }, { "front": "I'm going to the store.", "back": "가게에 가요.", "romanized": "Gage-e gayo." }] },
    { "id": "ko_ep_016", "levels": [{ "front": "To come", "back": "오다", "romanized": "oda" }, { "front": "Where are you coming from?", "back": "어디서 와요?", "romanized": "Eodiseo wayo?" }] },
    { "id": "ko_ep_017", "levels": [{ "front": "To want", "back": "-고 싶다", "romanized": "-go sipda", "grammarNote": "Korean expresses 'want to do' with verb stem + 고 싶다: 먹고 싶어요 (I want to eat), 가고 싶어요 (I want to go). To want a noun/object, use 원하다 (wonhada) or 을/를 원해요." }, { "front": "I want to eat ramen.", "back": "라면 먹고 싶어요.", "romanized": "Ramyeon meokgo sipeoyo." }] },
    { "id": "ko_ep_018", "levels": [{ "front": "To need", "back": "필요하다", "romanized": "piryohada" }, { "front": "I need help.", "back": "도움이 필요해요.", "romanized": "Doumi piryohaeyo." }] },
    { "id": "ko_ep_019", "levels": [{ "front": "Can (to be able to)", "back": "-(으)ㄹ 수 있다", "romanized": "-(eu)l su itda", "grammarNote": "Ability: verb stem + (으)ㄹ 수 있다. 먹을 수 있어요 (can eat), 갈 수 있어요 (can go). The negative is 없다: 갈 수 없어요 (cannot go). This construction is very common in Korean." }, { "front": "Can you help me?", "back": "도와줄 수 있어요?", "romanized": "Dowajul su isseoyo?" }] },
    { "id": "ko_ep_020", "levels": [{ "front": "To know (a fact)", "back": "알다", "romanized": "alda", "grammarNote": "알다 conjugates irregularly when followed by consonant endings: 알아요 (know), 알았어요 (knew). Negation: 몰라요 (don't know) — not 안 알아요. '몰라요' is the go-to response for 'I don't know'." }, { "front": "I don't know.", "back": "몰라요.", "romanized": "Mollayo." }] },
    { "id": "ko_ep_021", "levels": [{ "front": "To think", "back": "생각하다", "romanized": "saenggakhada" }, { "front": "I think it's a good idea.", "back": "좋은 생각인 것 같아요.", "romanized": "Joeun saenggang-in geot gatayo." }] },
    { "id": "ko_ep_022", "levels": [{ "front": "To like", "back": "좋아하다", "romanized": "joahada" }, { "front": "I like coffee.", "back": "커피를 좋아해요.", "romanized": "Keopi-reul joahaeyo." }] },
    { "id": "ko_ep_023", "levels": [{ "front": "To love", "back": "사랑하다", "romanized": "saranghada" }, { "front": "I love you.", "back": "사랑해요.", "romanized": "Saranghaeyo." }] },
    { "id": "ko_ep_024", "levels": [{ "front": "To eat", "back": "먹다", "romanized": "meokda" }, { "front": "I eat rice every day.", "back": "매일 밥을 먹어요.", "romanized": "Maeil babeul meogeoyo." }] },
    { "id": "ko_ep_025", "levels": [{ "front": "To drink", "back": "마시다", "romanized": "masida" }, { "front": "I drink water every morning.", "back": "매일 아침 물을 마셔요.", "romanized": "Maeil achim mureul masyeoyo." }] },
    { "id": "ko_ep_026", "levels": [{ "front": "To sleep", "back": "자다", "romanized": "jada" }, { "front": "I sleep eight hours a night.", "back": "하루에 여덟 시간 자요.", "romanized": "Harue yeodeol sigan jayo." }] },
    { "id": "ko_ep_027", "levels": [{ "front": "To see / watch", "back": "보다", "romanized": "boda" }, { "front": "I can't see anything.", "back": "아무것도 안 보여요.", "romanized": "Amugeotdo an boyeoyo." }] },
    { "id": "ko_ep_028", "levels": [{ "front": "To hear", "back": "듣다", "romanized": "deutda" }, { "front": "I can't hear you.", "back": "안 들려요.", "romanized": "An deullyeoyo." }] },
    { "id": "ko_ep_029", "levels": [{ "front": "To speak", "back": "말하다", "romanized": "malhada" }, { "front": "Do you speak Korean?", "back": "한국어 할 줄 알아요?", "romanized": "Hangugeo hal jul arayo?" }] },
    { "id": "ko_ep_030", "levels": [{ "front": "To give", "back": "주다", "romanized": "juda" }, { "front": "Give me the menu, please.", "back": "메뉴 주세요.", "romanized": "Menyu juseyo." }] },
    { "id": "ko_ep_031", "levels": [{ "front": "In / at (location)", "back": "에 / 에서", "romanized": "e / eseo", "grammarNote": "에 (e) marks location of existence or destination: 집에 있어요 (I'm at home), 학교에 가요 (go to school). 에서 (eseo) marks where an action takes place: 학교에서 공부해요 (study at school). This distinction is essential." }, { "front": "I'm studying at school.", "back": "학교에서 공부해요.", "romanized": "Hakgyoeseo gongbuhaeyo." }] },
    { "id": "ko_ep_032", "levels": [{ "front": "To (towards)", "back": "에 / (으)로", "romanized": "e / (eu)ro" }, { "front": "I'm going to the park.", "back": "공원에 가요.", "romanized": "Gongwon-e gayo." }] },
    { "id": "ko_ep_033", "levels": [{ "front": "From", "back": "에서 / 부터", "romanized": "eseo / buteo" }, { "front": "I'm from Korea.", "back": "한국에서 왔어요.", "romanized": "Hangugeso wasseoyo." }] },
    { "id": "ko_ep_034", "levels": [{ "front": "With", "back": "와/과 함께, 하고", "romanized": "wa/gwa hamkke, hago" }, { "front": "I came with my friend.", "back": "친구하고 왔어요.", "romanized": "Chin-guhago wasseoyo." }] },
    { "id": "ko_ep_035", "levels": [{ "front": "Without", "back": "없이", "romanized": "eobsi" }, { "front": "Coffee without sugar, please.", "back": "설탕 없이 커피 주세요.", "romanized": "Seoltang eobsi keopi juseyo." }] },
    { "id": "ko_ep_036", "levels": [{ "front": "For", "back": "을/를 위해서", "romanized": "eul/reul wihaeseo" }, { "front": "This is for you.", "back": "이거 당신을 위한 거예요.", "romanized": "Igeo dangsin-eul wihan geoyeyo." }] },
    { "id": "ko_ep_037", "levels": [{ "front": "Here", "back": "여기", "romanized": "yeogi" }, { "front": "Come here!", "back": "여기 와요!", "romanized": "Yeogi wayo!" }] },
    { "id": "ko_ep_038", "levels": [{ "front": "There (near you)", "back": "거기", "romanized": "geogi" }, { "front": "It's over there.", "back": "저기 있어요.", "romanized": "Jeogi isseoyo." }] },
    { "id": "ko_ep_039", "levels": [{ "front": "Where", "back": "어디", "romanized": "eodi" }, { "front": "Where is the bathroom?", "back": "화장실이 어디예요?", "romanized": "Hwajangsiri eodiyeyo?" }] },
    { "id": "ko_ep_040", "levels": [{ "front": "When", "back": "언제", "romanized": "eonje" }, { "front": "When does the store open?", "back": "가게가 언제 열어요?", "romanized": "Gagega eonje yeoreoyo?" }] },
    { "id": "ko_ep_041", "levels": [{ "front": "Why", "back": "왜", "romanized": "wae" }, { "front": "Why are you late?", "back": "왜 늦었어요?", "romanized": "Wae neujeosseoyo?" }] },
    { "id": "ko_ep_042", "levels": [{ "front": "How", "back": "어떻게", "romanized": "eotteoke" }, { "front": "How are you?", "back": "어떻게 지내요?", "romanized": "Eotteoke jinaeyo?" }] },
    { "id": "ko_ep_043", "levels": [{ "front": "And", "back": "그리고 / -하고", "romanized": "geurigo / -hago" }, { "front": "Rice and kimchi.", "back": "밥하고 김치.", "romanized": "Baphago gimchi." }] },
    { "id": "ko_ep_044", "levels": [{ "front": "But", "back": "하지만 / 그런데", "romanized": "hajiman / geureonde" }, { "front": "I want to go, but I can't.", "back": "가고 싶지만 못 가요.", "romanized": "Gago sipjiman mot gayo." }] },
    { "id": "ko_ep_045", "levels": [{ "front": "Because", "back": "-아서/어서 / 왜냐하면", "romanized": "-aseo/-eoseo / waenyahamyeon", "grammarNote": "The most common causal connector is verb stem + 아서/어서: 피곤해서 (because I'm tired), 배고파서 (because I'm hungry). 왜냐하면...기 때문이에요 is more formal. 아서/어서 cannot be used with past tense verbs." }, { "front": "I can't come because I'm tired.", "back": "피곤해서 못 와요.", "romanized": "Pigonhaeseo mot wayo." }] },
    { "id": "ko_ep_046", "levels": [{ "front": "If", "back": "만약 / -(으)면", "romanized": "manyak / -(eu)myeon", "grammarNote": "The most natural conditional uses verb stem + (으)면: 시간이 있으면 (if you have time), 비가 오면 (if it rains). 만약 (if/in case) can be added at the start for emphasis: 만약 비가 오면..." }, { "front": "If you want, let's go.", "back": "원하면 가요.", "romanized": "Wonhamyeon gayo." }] },
    { "id": "ko_ep_047", "levels": [{ "front": "This", "back": "이 / 이것", "romanized": "i / igeot", "grammarNote": "Korean has a three-way distance system: 이 (this, near speaker), 그 (that, near listener), 저 (that over there, away from both). As pronouns: 이것/이거 (this thing), 그것/그거 (that thing), 저것/저거 (that thing over there)." }, { "front": "This book is interesting.", "back": "이 책이 재미있어요.", "romanized": "I chaegi jaemiisseoyo." }] },
    { "id": "ko_ep_048", "levels": [{ "front": "All / everything", "back": "다 / 모두", "romanized": "da / modu" }, { "front": "I ate everything.", "back": "다 먹었어요.", "romanized": "Da meogeosseoyo." }] },
    { "id": "ko_ep_049", "levels": [{ "front": "Nothing", "back": "아무것도 없다", "romanized": "amugeotdo eopda", "grammarNote": "Korean negative indefinites require double negation: 아무것도 안 먹었어요 (I didn't eat anything — lit. 'anything also not ate'). This is standard grammar, not emphasis." }, { "front": "I have nothing.", "back": "아무것도 없어요.", "romanized": "Amugeotdo eopseoyo." }] },
    { "id": "ko_ep_050", "levels": [{ "front": "Much / many", "back": "많다 / 많이", "romanized": "manta / mani" }, { "front": "I have a lot of work.", "back": "할 일이 많아요.", "romanized": "Hal iri manayo." }] },
    { "id": "ko_ep_051", "levels": [{ "front": "A little", "back": "조금", "romanized": "jogeum" }, { "front": "A little water, please.", "back": "물 조금 주세요.", "romanized": "Mul jogeum juseyo." }] },
    { "id": "ko_ep_052", "levels": [{ "front": "More", "back": "더", "romanized": "deo" }, { "front": "More water, please.", "back": "물 더 주세요.", "romanized": "Mul deo juseyo." }] },
    { "id": "ko_ep_053", "levels": [{ "front": "Very", "back": "매우 / 아주 / 너무", "romanized": "maeu / aju / neomu", "grammarNote": "너무 (neomu) literally means 'too much/excessively' but in casual speech is used like 'very': 너무 맛있어요 (it's so delicious). 아주 is neutral, 매우 is slightly more formal/written." }, { "front": "It's very delicious.", "back": "너무 맛있어요.", "romanized": "Neomu masisseoyo." }] },
    { "id": "ko_ep_054", "levels": [{ "front": "Also / too", "back": "도", "romanized": "do", "grammarNote": "도 (do) replaces topic/subject/object markers to mean 'also/too': 저도 (me too), 이것도 (this too), 밥도 먹어요 (I also eat rice). Very useful and flexible particle." }, { "front": "Me too.", "back": "저도요.", "romanized": "Jeodoyo." }] },
    { "id": "ko_ep_055", "levels": [{ "front": "Now", "back": "지금", "romanized": "jigeum" }, { "front": "I'm eating now.", "back": "지금 먹고 있어요.", "romanized": "Jigeum meokgo isseoyo." }] },
    { "id": "ko_ep_056", "levels": [{ "front": "Later", "back": "나중에", "romanized": "najunge" }, { "front": "See you later.", "back": "나중에 봐요.", "romanized": "Najunge bwayo." }] },
    { "id": "ko_ep_057", "levels": [{ "front": "Always", "back": "항상 / 언제나", "romanized": "hangsang / eonjena" }, { "front": "I always drink coffee in the morning.", "back": "항상 아침에 커피를 마셔요.", "romanized": "Hangsang achime keopi-reul masyeoyo." }] },
    { "id": "ko_ep_058", "levels": [{ "front": "Never", "back": "절대 (-지 않다)", "romanized": "jeoldae (-ji anta)" }, { "front": "I never eat meat.", "back": "고기는 절대 안 먹어요.", "romanized": "Gogineun jeoldae an meogeoyo." }] },
    { "id": "ko_ep_059", "levels": [{ "front": "The person", "back": "사람", "romanized": "saram" }, { "front": "That person is my teacher.", "back": "저 사람이 제 선생님이에요.", "romanized": "Jeo sarami je seonsaengnim-ieyo." }] },
    { "id": "ko_ep_060", "levels": [{ "front": "The day", "back": "날 / 하루", "romanized": "nal / haru", "grammarNote": "하루 (haru) = one day / the whole day. 날 (nal) = a day (more general). 오늘 (oneul) = today. 어제 (eonje) = yesterday. 내일 (naeil) = tomorrow." }, { "front": "Good morning!", "back": "안녕하세요!", "romanized": "Annyeonghaseyo!" }] },
    { "id": "ko_ep_061", "levels": [{ "front": "The night", "back": "밤", "romanized": "bam" }, { "front": "Good night!", "back": "잘 자요!", "romanized": "Jal jayo!" }] },
    { "id": "ko_ep_062", "levels": [{ "front": "Water", "back": "물", "romanized": "mul" }, { "front": "The water is cold.", "back": "물이 차가워요.", "romanized": "Muri chagawoyo." }] },
    { "id": "ko_ep_063", "levels": [{ "front": "Food", "back": "음식", "romanized": "eumsik" }, { "front": "The food is delicious.", "back": "음식이 맛있어요.", "romanized": "Eumshigi masisseoyo." }] },
    { "id": "ko_ep_064", "levels": [{ "front": "House / home", "back": "집", "romanized": "jip" }, { "front": "My house is nearby.", "back": "우리 집이 가까워요.", "romanized": "Uri jibi gakkawoyo." }] },
    { "id": "ko_ep_065", "levels": [{ "front": "Money", "back": "돈", "romanized": "don" }, { "front": "I don't have money.", "back": "돈이 없어요.", "romanized": "Doni eopseoyo." }] },
    { "id": "ko_ep_066", "levels": [{ "front": "Name", "back": "이름", "romanized": "ireum" }, { "front": "What is your name?", "back": "이름이 뭐예요?", "romanized": "Ireumi mwoyeyo?" }] },
    { "id": "ko_ep_067", "levels": [{ "front": "Language", "back": "언어 / 말", "romanized": "eoneo / mal" }, { "front": "What language do you speak?", "back": "무슨 언어를 해요?", "romanized": "Museun eoneoreul haeyo?" }] },
    { "id": "ko_ep_068", "levels": [{ "front": "Help", "back": "도움", "romanized": "doum" }, { "front": "I need your help.", "back": "도움이 필요해요.", "romanized": "Doumi piryohaeyo." }] },
    { "id": "ko_ep_069", "levels": [{ "front": "Problem", "back": "문제", "romanized": "munje" }, { "front": "No problem.", "back": "괜찮아요.", "romanized": "Gwaenchanayo." }] },
    { "id": "ko_ep_070", "levels": [{ "front": "Bathroom / toilet", "back": "화장실", "romanized": "hwajangsil" }, { "front": "Where is the bathroom?", "back": "화장실이 어디예요?", "romanized": "Hwajangsiri eodiyeyo?" }] }
  ]
}
