    { "id": "ko_me_021", "levels": [{ "front": "relief", "back": "안도 / 안심", "romanized": "ando / ansim" }, { "front": "What a relief!", "back": "정말 다행이에요!", "romanized": "jeongmal dahaengieyo" }] },
    { "id": "ko_me_022", "levels": [{ "front": "comfort", "back": "위로 / 안위", "romanized": "wiro / anwi" }, { "front": "Her words were a comfort.", "back": "그녀의 말이 위로가 됐어요.", "romanized": "geunyeoui mari wiroga dwaesseoyo" }] },
    { "id": "ko_me_023", "levels": [{ "front": "feel (to feel)", "back": "느끼다 / 기분이 ~하다", "romanized": "neukkida / gibuni ~hada", "grammarNote": "'느끼다' (neukkida) = to feel/sense something. '기분이 좋아요' (gibuni joayo) = I feel good (literally 'my mood is good'). Korean often expresses emotional states as noun+adjective rather than a verb: '기분' (gibun, mood/feeling) + state adjective." }, { "front": "I feel good today.", "back": "오늘 기분이 좋아요.", "romanized": "oneul gibuni joayo" }] },
    { "id": "ko_me_024", "levels": [{ "front": "love (to love)", "back": "사랑하다 / 좋아하다", "romanized": "saranghada / joahada" }, { "front": "I love you very much.", "back": "당신을 많이 사랑해요.", "romanized": "dangsineul manhi saranghaeyo" }] },
    { "id": "ko_me_025", "levels": [{ "front": "hate (to hate)", "back": "싫어하다 / 증오하다", "romanized": "sireohada / jeungohada" }, { "front": "I hate waiting.", "back": "기다리는 걸 싫어해요.", "romanized": "gidarineun geol sireohaeyo" }] },
    { "id": "ko_me_026", "levels": [{ "front": "like (to like)", "back": "좋아하다", "romanized": "joahada" }, { "front": "I like music.", "back": "음악을 좋아해요.", "romanized": "eumag-eul joahaeyo" }] },
    { "id": "ko_me_027", "levels": [{ "front": "enjoy", "back": "즐기다 / 즐거워하다", "romanized": "jeulgida / jeulgeowohada" }, { "front": "I enjoy the weekend.", "back": "주말을 즐겨요.", "romanized": "jumal-eul jeulgyeoyo" }] },
    { "id": "ko_me_028", "levels": [{ "front": "fear / dread (to fear)", "back": "두려워하다 / 무서워하다", "romanized": "duryeowohada / museowohada" }, { "front": "I fear the worst.", "back": "최악의 상황을 두려워해요.", "romanized": "choeag-ui sanghwang-eul duryeowohaeyo" }] },
    { "id": "ko_me_029", "levels": [{ "front": "hope (to hope)", "back": "바라다 / 희망하다", "romanized": "barada / huimanghada" }, { "front": "I hope everything goes well.", "back": "모든 게 잘 되길 바라요.", "romanized": "modeun ge jal doegil barayo" }] },
    { "id": "ko_me_030", "levels": [{ "front": "worry (to worry)", "back": "걱정하다", "romanized": "geokjeonghada" }, { "front": "Don't worry about it.", "back": "그것에 대해 걱정하지 마세요.", "romanized": "geugeose daehae geokjeongji maseyo" }] },
