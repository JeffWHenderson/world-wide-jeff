    { "id": "ko_me_009", "levels": [{ "front": "Worried", "back": "걱정되다", "romanized": "geokjeongdoeda" }, { "front": "I'm worried about you.", "back": "걱정돼요.", "romanized": "Geokjeongdwaeyo." }] },
