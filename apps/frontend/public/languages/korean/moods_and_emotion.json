    { "id": "ko_me_032", "levels": [{ "front": "comfort (to comfort)", "back": "위로하다 / 달래다", "romanized": "wirohada / dallaeda" }, { "front": "She comforted her friend.", "back": "그녀는 친구를 위로했어요.", "romanized": "geunyeoneun chingureul wirohaesseoyo" }] },
    { "id": "ko_me_033", "levels": [{ "front": "excite / thrill", "back": "흥분시키다 / 설레게 하다", "romanized": "heungbunssikida / seollege hada" }, { "front": "The trip excites me.", "back": "여행을 생각하면 설레요.", "romanized": "yeohaeng-eul saenggakamyeon seolleoyo" }] },
    { "id": "ko_me_034", "levels": [{ "front": "annoy", "back": "짜증나게 하다 / 귀찮게 하다", "romanized": "jjajeungnage hada / gwichankge hada" }, { "front": "That noise annoys me.", "back": "그 소음이 짜증 나요.", "romanized": "geu soeumi jjajeung nayo" }] },
    { "id": "ko_me_035", "levels": [{ "front": "irritate", "back": "짜증나게 하다 / 신경 쓰이게 하다", "romanized": "jjajeungnage hada / singyeong sseuige hada" }, { "front": "Waiting irritates me.", "back": "기다리는 게 짜증 나요.", "romanized": "gidarineun ge jjajeung nayo" }] },
    { "id": "ko_me_036", "levels": [{ "front": "anger (to anger)", "back": "화나게 하다 / 분노하게 만들다", "romanized": "hwanage hada / bunnoage mandeulda" }, { "front": "That comment angered me.", "back": "그 말이 화나게 했어요.", "romanized": "geu mari hwanage haesseoyo" }] },
    { "id": "ko_me_037", "levels": [{ "front": "delight", "back": "기쁘게 하다 / 즐겁게 하다", "romanized": "gippeuge hada / jeulgeobge hada" }, { "front": "The music delighted everyone.", "back": "음악이 모두를 기쁘게 했어요.", "romanized": "eumagi modureul gippeuge haesseoyo" }] },
    { "id": "ko_me_038", "levels": [{ "front": "smile", "back": "미소 짓다 / 웃다", "romanized": "miso jitda / utda" }, { "front": "She always smiles.", "back": "그녀는 항상 미소 지어요.", "romanized": "geunyeoneun hangsang miso jieoyo" }] },
    { "id": "ko_me_039", "levels": [{ "front": "laugh", "back": "웃다 / 크게 웃다", "romanized": "utda / keuge utda" }, { "front": "We laughed a lot.", "back": "우리는 많이 웃었어요.", "romanized": "urineun manhi uteosseoyo" }] },
