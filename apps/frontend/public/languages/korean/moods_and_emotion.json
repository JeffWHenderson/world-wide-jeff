  "cards": [
    { "id": "ko_me_001", "levels": [{ "front": "happy", "back": "행복한 / 기쁜", "romanized": "haengbokhan / gippeun", "grammarNote": "'행복하다' (haengbokhada) = to be happy (deep, lasting happiness). '기쁘다' (gippeuda) = to be glad/delighted (in the moment). Korean emotions are adjectives that become predicates: '행복해요' (haengbokhaeyo, I'm happy), '기뻐요' (gippeoyo, I'm glad)." }, { "front": "I'm very happy today.", "back": "오늘 너무 행복해요.", "romanized": "oneul neomu haengbokhaeyo" }] },
    { "id": "ko_me_002", "levels": [{ "front": "sad", "back": "슬픈", "romanized": "seulpeun" }, { "front": "Why are you sad?", "back": "왜 슬퍼요?", "romanized": "wae seulpeoyo" }] },
    { "id": "ko_me_003", "levels": [{ "front": "love", "back": "사랑", "romanized": "sarang" }, { "front": "I feel a lot of love for my family.", "back": "가족에게 많은 사랑을 느껴요.", "romanized": "gajogege manheun sarang-eul neukkeyeoyo" }] },
    { "id": "ko_me_004", "levels": [{ "front": "anger", "back": "화 / 분노", "romanized": "hwa / bunno" }, { "front": "I felt anger when they lied to me.", "back": "거짓말했을 때 화가 났어요.", "romanized": "geojitmalhaesseul ttae hwa-ga nasseoyo" }] },
    { "id": "ko_me_005", "levels": [{ "front": "fear", "back": "두려움 / 공포", "romanized": "duryeoum / gongpo" }, { "front": "I'm afraid of the dark.", "back": "어둠이 무서워요.", "romanized": "eodumi museowoyo" }] },
    { "id": "ko_me_006", "levels": [{ "front": "hope", "back": "희망", "romanized": "huimang" }, { "front": "I have hope for the future.", "back": "미래에 대한 희망이 있어요.", "romanized": "mirae-e daehan huimangi isseoyo" }] },
    { "id": "ko_me_007", "levels": [{ "front": "stress", "back": "스트레스", "romanized": "seuteurese" }, { "front": "I have a lot of stress at work.", "back": "일에서 스트레스가 많아요.", "romanized": "ireseo seuteurese-ga manayo" }] },
    { "id": "ko_me_008", "levels": [{ "front": "mood", "back": "기분", "romanized": "gibun" }, { "front": "I'm in a good mood today.", "back": "오늘 기분이 좋아요.", "romanized": "oneul gibuni joayo" }] },
    { "id": "ko_me_009", "levels": [{ "front": "feeling", "back": "감정 / 느낌", "romanized": "gamjeong / neukkkim" }, { "front": "That feeling is normal.", "back": "그 감정은 자연스러워요.", "romanized": "geu gamjeong-eun jayeonseuleowoyo" }] },
    { "id": "ko_me_010", "levels": [{ "front": "emotion / excitement", "back": "감정 / 감동 / 흥분", "romanized": "gamjeong / gamdong / heungbun" }, { "front": "I couldn't hide my emotion.", "back": "감동을 숨길 수 없었어요.", "romanized": "gamdong-eul sumgil su eopseosseoyo" }] },
    { "id": "ko_me_011", "levels": [{ "front": "calm", "back": "침착함 / 평온함", "romanized": "chimchakam / pyeong-onham" }, { "front": "Try to maintain your calm.", "back": "침착함을 유지하도록 하세요.", "romanized": "chimchakameul yujihadorok haseyo" }] },
    { "id": "ko_me_012", "levels": [{ "front": "peace", "back": "평화 / 평온", "romanized": "pyeonghwa / pyeong-on" }, { "front": "I need peace and quiet.", "back": "평화와 고요함이 필요해요.", "romanized": "pyeonghwawa goyoami piryohaeyo" }] },
    { "id": "ko_me_013", "levels": [{ "front": "worry", "back": "걱정 / 불안", "romanized": "geokjeong / buran" }, { "front": "Don't let worry stop you.", "back": "걱정 때문에 멈추지 마세요.", "romanized": "geokjeong ttaemune meomchuji maseyo" }] },
    { "id": "ko_me_014", "levels": [{ "front": "surprise", "back": "놀라움 / 서프라이즈", "romanized": "nollaum / seopeuraiжeu" }, { "front": "What a surprise!", "back": "정말 놀랐어요!", "romanized": "jeongmal nollaisseoyo" }] },
    { "id": "ko_me_015", "levels": [{ "front": "passion", "back": "열정", "romanized": "yeoljeong" }, { "front": "She teaches with passion.", "back": "그녀는 열정을 가지고 가르쳐요.", "romanized": "geunyeoneun yeoljeong-eul gajigo gareuсhyeoyo" }] },
    { "id": "ko_me_016", "levels": [{ "front": "desire", "back": "욕망 / 바람", "romanized": "yokmang / baram" }, { "front": "I have a strong desire to travel.", "back": "여행하고 싶은 강한 욕구가 있어요.", "romanized": "yeohaenghago sipeon ganghan yokguga isseoyo" }] },
    { "id": "ko_me_017", "levels": [{ "front": "hate", "back": "증오 / 혐오", "romanized": "jeungo / hyeomo" }, { "front": "Hate is a strong feeling.", "back": "증오는 강한 감정이에요.", "romanized": "jeungoneun ganghan gamjeongieyo" }] },
    { "id": "ko_me_018", "levels": [{ "front": "pleasure", "back": "기쁨 / 즐거움", "romanized": "gippeum / jeulgeоum" }, { "front": "It's a pleasure to meet you.", "back": "만나서 반갑습니다.", "romanized": "mannaseo bangapseumnida" }] },
    { "id": "ko_me_019", "levels": [{ "front": "pain", "back": "고통 / 아픔", "romanized": "gotong / apeum" }, { "front": "I feel pain in my leg.", "back": "다리에 통증이 느껴져요.", "romanized": "darie tongjeungi neukkkyeojyeoyo" }] },
