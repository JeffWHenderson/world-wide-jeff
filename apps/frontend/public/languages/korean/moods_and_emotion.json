    { "id": "ko_me_045", "levels": [{ "front": "angry", "back": "화가 난 / 성난", "romanized": "hwa-ga nan / seongnan" }, { "front": "I'm angry with you.", "back": "당신에게 화가 났어요.", "romanized": "dangsинеge hwa-ga nasseoyo" }] },
    { "id": "ko_me_046", "levels": [{ "front": "mad", "back": "매우 화난 / 격분한", "romanized": "maeu hwanan / gyeokbunhan" }, { "front": "Why are you so mad?", "back": "왜 그렇게 화가 났어요?", "romanized": "wae geureoke hwa-ga nasseoyo" }] },
