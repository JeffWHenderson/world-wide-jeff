{
  "id": "human_body",
  "name": "Human Body",
  "language": "korean",
  "stories": ["at_the_doctor", "getting_ready"],
  "cards": [
    { "id": "ko_hb_001", "levels": [{ "front": "Head", "back": "머리", "romanized": "meori" }, { "front": "I have a headache.", "back": "머리가 아파요.", "romanized": "Meoriga apayo." }] },
    { "id": "ko_hb_002", "levels": [{ "front": "Face", "back": "얼굴", "romanized": "eolgul" }, { "front": "Your face looks pale.", "back": "얼굴이 창백해 보여요.", "romanized": "Eolguri changbaekhae boyeoyo." }] },
    { "id": "ko_hb_003", "levels": [{ "front": "Eyes", "back": "눈", "romanized": "nun" }, { "front": "My eyes are tired.", "back": "눈이 피곤해요.", "romanized": "Nuni pigonhaeyo." }] },
    { "id": "ko_hb_004", "levels": [{ "front": "Nose", "back": "코", "romanized": "ko" }, { "front": "My nose is runny.", "back": "콧물이 나요.", "romanized": "Konmuri nayo." }] },
    { "id": "ko_hb_005", "levels": [{ "front": "Mouth", "back": "입", "romanized": "ip" }, { "front": "Open your mouth.", "back": "입을 벌려 주세요.", "romanized": "Ibeul beollyeo juseyo." }] },
    { "id": "ko_hb_006", "levels": [{ "front": "Ear", "back": "귀", "romanized": "gwi" }, { "front": "My ear hurts.", "back": "귀가 아파요.", "romanized": "Gwiga apayo." }] },
    { "id": "ko_hb_007", "levels": [{ "front": "Throat", "back": "목", "romanized": "mok" }, { "front": "My throat hurts.", "back": "목이 아파요.", "romanized": "Mogi apayo." }] },
    { "id": "ko_hb_008", "levels": [{ "front": "Teeth", "back": "이 / 치아", "romanized": "i / chia" }, { "front": "I have a toothache.", "back": "이가 아파요.", "romanized": "Iga apayo." }] },
    { "id": "ko_hb_009", "levels": [{ "front": "Shoulder", "back": "어깨", "romanized": "eokkae" }, { "front": "My shoulders are stiff.", "back": "어깨가 뻐근해요.", "romanized": "Eokkae-ga ppeogeunhaeyo." }] },
    { "id": "ko_hb_010", "levels": [{ "front": "Arm", "back": "팔", "romanized": "pal" }, { "front": "I hurt my arm.", "back": "팔을 다쳤어요.", "romanized": "Paleul dachyeosseoyo." }] },
    { "id": "ko_hb_011", "levels": [{ "front": "Hand", "back": "손", "romanized": "son" }, { "front": "Please wash your hands.", "back": "손을 씻어 주세요.", "romanized": "Soneul ssiseo juseyo." }] },
    { "id": "ko_hb_012", "levels": [{ "front": "Stomach", "back": "배", "romanized": "bae" }, { "front": "I have a stomach ache.", "back": "배가 아파요.", "romanized": "Baega apayo." }] },
    { "id": "ko_hb_013", "levels": [{ "front": "Back", "back": "등 / 허리", "romanized": "deung / heori", "grammarNote": "등 (deung) = upper back. 허리 (heori) = lower back/waist. Koreans commonly say 허리가 아파요 (my lower back hurts), which is one of the most common complaints in Korean healthcare." }, { "front": "My lower back hurts.", "back": "허리가 아파요.", "romanized": "Heoriga apayo." }] },
    { "id": "ko_hb_014", "levels": [{ "front": "Leg", "back": "다리", "romanized": "dari" }, { "front": "My legs are sore.", "back": "다리가 아파요.", "romanized": "Dariga apayo." }] },
    { "id": "ko_hb_015", "levels": [{ "front": "Foot", "back": "발", "romanized": "bal" }, { "front": "I have a blister on my foot.", "back": "발에 물집이 생겼어요.", "romanized": "Bare muljbi saenggyeosseoyo." }] },
    { "id": "ko_hb_016", "levels": [{ "front": "It hurts / aches", "back": "아프다", "romanized": "apeuda", "grammarNote": "아프다 (apeuda) = to be in pain / to hurt / to be sick. Body part + 가/이 아파요: 머리가 아파요 (head hurts), 배가 아파요 (stomach hurts). It's also used to say you're sick in general: 아파요 = I'm sick / in pain." }, { "front": "Where does it hurt?", "back": "어디가 아파요?", "romanized": "Eodiga apayo?" }] },
    { "id": "ko_hb_017", "levels": [{ "front": "I'm sick", "back": "아프다 / 몸이 안 좋다", "romanized": "apeuda / momi an jota" }, { "front": "I've been sick since yesterday.", "back": "어제부터 아팠어요.", "romanized": "Eojebuteo apasso." }] },
    { "id": "ko_hb_018", "levels": [{ "front": "Fever", "back": "열", "romanized": "yeol" }, { "front": "I have a fever.", "back": "열이 있어요.", "romanized": "Yeori isseoyo." }] },
    { "id": "ko_hb_019", "levels": [{ "front": "Cough", "back": "기침", "romanized": "gichim" }, { "front": "I have a bad cough.", "back": "기침이 심해요.", "romanized": "Gichimi simhaeyo." }] },
    { "id": "ko_hb_020", "levels": [{ "front": "Medicine", "back": "약", "romanized": "yak" }, { "front": "I'll buy medicine at the pharmacy.", "back": "약국에서 약을 살 거예요.", "romanized": "Yakgukeseo yageul sal geoyeyo." }] },
    { "id": "ko_hb_021", "levels": [{ "front": "Appointment", "back": "예약", "romanized": "yeyak" }, { "front": "I have a doctor's appointment.", "back": "병원 예약이 있어요.", "romanized": "Byeongwon yeyagi isseoyo." }] },
    { "id": "ko_hb_022", "levels": [{ "front": "To wash (oneself)", "back": "씻다", "romanized": "ssitda" }, { "front": "I wash my hands before eating.", "back": "밥 먹기 전에 손을 씻어요.", "romanized": "Bap meokgi jeone soneul ssiseoyo." }] },
    { "id": "ko_hb_023", "levels": [{ "front": "Hair", "back": "머리카락 / 머리", "romanized": "meorikarak / meori" }, { "front": "I'm going to get my hair cut.", "back": "머리를 자를 거예요.", "romanized": "Meoireul jareul geoyeyo." }] },
    { "id": "ko_hb_024", "levels": [{ "front": "Skin", "back": "피부", "romanized": "pibu" }, { "front": "Korean skincare is famous worldwide.", "back": "한국 피부 관리는 세계적으로 유명해요.", "romanized": "Hanguk pibu gwallireun segyejeogeuro yumyeonghaeyo." }] },
    { "id": "ko_hb_025", "levels": [{ "front": "Get dressed", "back": "옷을 입다", "romanized": "oseul ipda" }, { "front": "I get dressed quickly in the morning.", "back": "아침에 빨리 옷을 입어요.", "romanized": "Achime ppalli oseul ibeoyo." }] }
  ]
}
