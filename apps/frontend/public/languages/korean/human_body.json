  "cards": [
    { "id": "ko_hb_001", "levels": [{ "front": "head", "back": "머리", "romanized": "meori", "grammarNote": "In Korean, pain is expressed as '아프다' (apeuda, to hurt/be sick): '머리가 아파요' (meoriga apayo) = my head hurts. The body part takes subject particle 이/가 (i/ga). This construction is used for all body pain." }, { "front": "My head hurts.", "back": "머리가 아파요.", "romanized": "meoriga apayo" }] },
    { "id": "ko_hb_002", "levels": [{ "front": "hair", "back": "머리카락 / 머리", "romanized": "meorikaraк / meori" }, { "front": "She has long hair.", "back": "그녀는 머리카락이 길어요.", "romanized": "geunyeoneun meorikaragi gireoyo" }] },
    { "id": "ko_hb_003", "levels": [{ "front": "face", "back": "얼굴", "romanized": "eolgul" }, { "front": "Wash your face.", "back": "얼굴을 씻으세요.", "romanized": "eolgureul ssiseuseyo" }] },
    { "id": "ko_hb_004", "levels": [{ "front": "eye", "back": "눈", "romanized": "nun" }, { "front": "He has blue eyes.", "back": "그는 파란 눈을 가졌어요.", "romanized": "geuneun paran nuneul gajyeosseoyo" }] },
    { "id": "ko_hb_005", "levels": [{ "front": "ear", "back": "귀", "romanized": "gwi" }, { "front": "My ear hurts.", "back": "귀가 아파요.", "romanized": "gwiga apayo" }] },
    { "id": "ko_hb_006", "levels": [{ "front": "nose", "back": "코", "romanized": "ko" }, { "front": "My nose is cold.", "back": "코가 차가워요.", "romanized": "koga chagawoyo" }] },
