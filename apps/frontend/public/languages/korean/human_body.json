    { "id": "ko_hb_008", "levels": [{ "front": "lip", "back": "입술", "romanized": "ipsul" }, { "front": "She has red lips.", "back": "그녀는 입술이 빨개요.", "romanized": "geunyeoneun ipsuri ppalg aeyo" }] },
