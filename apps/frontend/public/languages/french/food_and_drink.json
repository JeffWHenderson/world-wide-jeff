    { "id": "fr_fd_110", "levels": [{ "front": "homemade", "back": "fait maison" }, { "front": "I love homemade bread.", "back": "J'adore le pain fait maison." }] },
    { "id": "fr_fd_112", "levels": [{ "front": "daily", "back": "quotidien / tous les jours" }, { "front": "I eat fruit daily.", "back": "Je mange des fruits tous les jours." }] },
    { "id": "fr_fd_113", "levels": [{ "front": "almost", "back": "presque" }, { "front": "Lunch is almost ready.", "back": "Le déjeuner est presque prêt." }] },
    { "id": "fr_fd_114", "levels": [{ "front": "too (too much)", "back": "trop" }, { "front": "There is too much salt.", "back": "Il y a trop de sel." }] }
