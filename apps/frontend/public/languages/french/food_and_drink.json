    { "id": "fr_fd_077", "levels": [{ "front": "pour", "back": "verser" }, { "front": "Pour the water into the glass.", "back": "Versez l'eau dans le verre." }] },
    { "id": "fr_fd_078", "levels": [{ "front": "serve", "back": "servir" }, { "front": "The waiter served the food.", "back": "Le serveur a servi la nourriture." }] },
    { "id": "fr_fd_080", "levels": [{ "front": "feed", "back": "nourrir / donner à manger" }, { "front": "She feeds the baby.", "back": "Elle donne à manger au bébé." }] },
    { "id": "fr_fd_081", "levels": [{ "front": "dine", "back": "dîner / déjeuner" }, { "front": "We dined at a nice restaurant.", "back": "On a dîné dans un beau restaurant." }] },
    { "id": "fr_fd_082", "levels": [{ "front": "chew", "back": "mâcher" }, { "front": "Chew your food slowly.", "back": "Mâche ta nourriture lentement." }] },
