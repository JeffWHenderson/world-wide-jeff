    { "id": "fr_fd_024", "levels": [{ "front": "The menu", "back": "la carte / le menu", "grammarNote": "'La carte' = the full menu. 'Le menu' in France usually means a set-price meal (starter + main + dessert). Always ask for 'la carte' if you want to order freely." }, { "front": "Can I see the menu?", "back": "Je peux voir la carte ?" }] },
