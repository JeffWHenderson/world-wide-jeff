    { "id": "fr_fd_105", "levels": [{ "front": "unhealthy", "back": "mauvais pour la santé / malsain" }, { "front": "Fast food is unhealthy.", "back": "La restauration rapide est mauvaise pour la santé." }] },
    { "id": "fr_fd_106", "levels": [{ "front": "vegetarian", "back": "végétarien / végétarienne" }, { "front": "I am vegetarian.", "back": "Je suis végétarien(ne)." }] },
    { "id": "fr_fd_107", "levels": [{ "front": "vegan", "back": "vegan / végétalien(ne)" }, { "front": "She is vegan.", "back": "Elle est vegan." }] },
