{
  "id": "food_and_drink",
  "name": "Food & Drink",
  "language": "french",
  "stories": ["at_the_restaurant", "at_the_market", "cooking_at_home"],
  "cards": [
    { "id": "fr_fd_001", "levels": [{ "front": "water", "back": "l'eau (fem.)", "grammarNote": "L'eau is feminine. Use the partitive 'de l'eau' when talking about an unspecified amount: 'Je bois de l'eau.' A definite quantity uses 'un verre d'eau' (a glass of water). The partitive (du/de la/de l') is essential with food and drink in French." }, { "front": "The water is cold.", "back": "L'eau est froide." }] },
    { "id": "fr_fd_002", "levels": [{ "front": "bread", "back": "le pain" }, { "front": "I'd like some bread.", "back": "Je voudrais du pain." }] },
    { "id": "fr_fd_003", "levels": [{ "front": "rice", "back": "le riz" }, { "front": "I like rice with vegetables.", "back": "J'aime le riz avec des légumes." }] },
    { "id": "fr_fd_004", "levels": [{ "front": "milk", "back": "le lait" }, { "front": "Do you want milk?", "back": "Tu veux du lait ?" }] },
    { "id": "fr_fd_005", "levels": [{ "front": "egg", "back": "l'œuf (masc.)", "grammarNote": "Singular: l'œuf (the f is pronounced). Plural: les œufs — the f goes silent! 'leh-ZUH'. This is a classic French pronunciation trap that catches everyone at first." }, { "front": "I eat two eggs for breakfast.", "back": "Je mange deux œufs au petit-déjeuner." }] },
    { "id": "fr_fd_006", "levels": [{ "front": "cheese", "back": "le fromage" }, { "front": "The sandwich has cheese.", "back": "Le sandwich a du fromage." }] },
    { "id": "fr_fd_007", "levels": [{ "front": "chicken", "back": "le poulet" }, { "front": "The chicken is delicious.", "back": "Le poulet est délicieux." }] },
    { "id": "fr_fd_008", "levels": [{ "front": "meat", "back": "la viande" }, { "front": "He doesn't eat meat.", "back": "Il ne mange pas de viande." }] },
    { "id": "fr_fd_009", "levels": [{ "front": "fish", "back": "le poisson" }, { "front": "I like fish.", "back": "J'aime le poisson." }] },
    { "id": "fr_fd_011", "levels": [{ "front": "pork", "back": "le porc" }, { "front": "I don't eat pork.", "back": "Je ne mange pas de porc." }] },
    { "id": "fr_fd_012", "levels": [{ "front": "fruit", "back": "le fruit" }, { "front": "I eat fruit every day.", "back": "Je mange des fruits tous les jours." }] },
    { "id": "fr_fd_013", "levels": [{ "front": "apple", "back": "la pomme" }, { "front": "An apple a day is healthy.", "back": "Une pomme par jour, c'est bon pour la santé." }] },
    { "id": "fr_fd_014", "levels": [{ "front": "banana", "back": "la banane" }, { "front": "The bananas are ripe.", "back": "Les bananes sont mûres." }] },
    { "id": "fr_fd_015", "levels": [{ "front": "orange", "back": "l'orange (fem.)" }, { "front": "I want an orange juice.", "back": "Je veux un jus d'orange." }] },
    { "id": "fr_fd_016", "levels": [{ "front": "vegetable", "back": "le légume" }, { "front": "Eat your vegetables!", "back": "Mange tes légumes !" }] },
    { "id": "fr_fd_017", "levels": [{ "front": "potato", "back": "la pomme de terre" }, { "front": "I want mashed potatoes.", "back": "Je veux de la purée de pommes de terre." }] },
    { "id": "fr_fd_018", "levels": [{ "front": "tomato", "back": "la tomate" }, { "front": "The salad has tomatoes.", "back": "La salade a des tomates." }] },
    { "id": "fr_fd_019", "levels": [{ "front": "onion", "back": "l'oignon (masc.)" }, { "front": "I don't like onions.", "back": "Je n'aime pas les oignons." }] },
    { "id": "fr_fd_020", "levels": [{ "front": "salad", "back": "la salade" }, { "front": "I'll have a salad.", "back": "Je vais prendre une salade." }] },
    { "id": "fr_fd_021", "levels": [{ "front": "soup", "back": "la soupe" }, { "front": "The soup is hot.", "back": "La soupe est chaude." }] },
    { "id": "fr_fd_024", "levels": [{ "front": "sandwich", "back": "le sandwich" }, { "front": "I made a sandwich for lunch.", "back": "J'ai fait un sandwich pour le déjeuner." }] },
    { "id": "fr_fd_025", "levels": [{ "front": "cake", "back": "le gâteau" }, { "front": "Do you want cake?", "back": "Tu veux du gâteau ?" }] },
    { "id": "fr_fd_026", "levels": [{ "front": "cookie", "back": "le biscuit / le cookie" }, { "front": "These cookies are delicious.", "back": "Ces biscuits sont délicieux." }] },
    { "id": "fr_fd_027", "levels": [{ "front": "chocolate", "back": "le chocolat" }, { "front": "I love chocolate.", "back": "J'adore le chocolat." }] },
    { "id": "fr_fd_028", "levels": [{ "front": "sugar", "back": "le sucre" }, { "front": "No sugar, please.", "back": "Sans sucre, s'il vous plaît." }] },
    { "id": "fr_fd_029", "levels": [{ "front": "salt", "back": "le sel" }, { "front": "Can you pass the salt?", "back": "Tu peux me passer le sel ?" }] },
    { "id": "fr_fd_030", "levels": [{ "front": "pepper", "back": "le poivre" }, { "front": "Can you pass the pepper?", "back": "Tu peux me passer le poivre ?" }] },
    { "id": "fr_fd_031", "levels": [{ "front": "butter", "back": "le beurre" }, { "front": "I put butter on my bread.", "back": "Je mets du beurre sur mon pain." }] },
    { "id": "fr_fd_032", "levels": [{ "front": "oil", "back": "l'huile (fem.)" }, { "front": "Cook with olive oil.", "back": "Cuisinez avec de l'huile d'olive." }] },
    { "id": "fr_fd_033", "levels": [{ "front": "coffee", "back": "le café" }, { "front": "I like coffee in the morning.", "back": "J'aime le café le matin." }] },
    { "id": "fr_fd_034", "levels": [{ "front": "tea", "back": "le thé" }, { "front": "Would you like some tea?", "back": "Tu veux du thé ?" }] },
    { "id": "fr_fd_035", "levels": [{ "front": "wine", "back": "le vin" }, { "front": "A glass of red wine, please.", "back": "Un verre de vin rouge, s'il vous plaît." }] },
    { "id": "fr_fd_036", "levels": [{ "front": "beer", "back": "la bière" }, { "front": "Two beers, please.", "back": "Deux bières, s'il vous plaît." }] },
    { "id": "fr_fd_037", "levels": [{ "front": "juice", "back": "le jus" }, { "front": "I want orange juice.", "back": "Je veux du jus d'orange." }] },
    { "id": "fr_fd_038", "levels": [{ "front": "breakfast", "back": "le petit-déjeuner" }, { "front": "I have breakfast at seven.", "back": "Je prends le petit-déjeuner à sept heures." }] },
    { "id": "fr_fd_039", "levels": [{ "front": "lunch", "back": "le déjeuner" }, { "front": "We have lunch at two.", "back": "On déjeune à deux heures." }] },
    { "id": "fr_fd_040", "levels": [{ "front": "dinner", "back": "le dîner" }, { "front": "Dinner is ready.", "back": "Le dîner est prêt." }] },
    { "id": "fr_fd_041", "levels": [{ "front": "snack", "back": "le goûter / le snack", "grammarNote": "Le goûter specifically refers to the afternoon snack (around 4pm), a French institution especially for children. For a general snack at any time, un snack or un encas is more common among adults." }, { "front": "I have a snack in the afternoon.", "back": "Je prends un goûter l'après-midi." }] },
    { "id": "fr_fd_042", "levels": [{ "front": "meal", "back": "le repas" }, { "front": "This is a delicious meal.", "back": "C'est un repas délicieux." }] },
    { "id": "fr_fd_043", "levels": [{ "front": "recipe", "back": "la recette" }, { "front": "Do you have a good recipe?", "back": "Tu as une bonne recette ?" }] },
    { "id": "fr_fd_044", "levels": [{ "front": "flavor", "back": "la saveur / le goût" }, { "front": "What flavor do you want?", "back": "Quel goût tu veux ?" }] },
    { "id": "fr_fd_046", "levels": [{ "front": "ingredient", "back": "l'ingrédient (masc.)" }, { "front": "What ingredients do you need?", "back": "De quels ingrédients tu as besoin ?" }] },
    { "id": "fr_fd_047", "levels": [{ "front": "menu", "back": "la carte / le menu", "grammarNote": "La carte = the full menu with all choices. Le menu in France usually means a set-price meal (entrée + plat + dessert). Always ask for 'la carte' if you want to order freely from individual dishes." }, { "front": "Can I see the menu?", "back": "Je peux voir la carte ?" }] },
    { "id": "fr_fd_048", "levels": [{ "front": "restaurant", "back": "le restaurant" }, { "front": "This restaurant is good.", "back": "Ce restaurant est bien." }] },
    { "id": "fr_fd_049", "levels": [{ "front": "kitchen", "back": "la cuisine" }, { "front": "The kitchen is clean.", "back": "La cuisine est propre." }] },
    { "id": "fr_fd_050", "levels": [{ "front": "oven", "back": "le four" }, { "front": "The oven is hot.", "back": "Le four est chaud." }] },
    { "id": "fr_fd_051", "levels": [{ "front": "stove", "back": "la cuisinière / les plaques" }, { "front": "Cook it on the stove.", "back": "Faites-le cuire sur les plaques." }] },
    { "id": "fr_fd_052", "levels": [{ "front": "knife", "back": "le couteau" }, { "front": "I need a sharp knife.", "back": "J'ai besoin d'un couteau bien aiguisé." }] },
    { "id": "fr_fd_053", "levels": [{ "front": "fork", "back": "la fourchette" }, { "front": "Can I have a fork?", "back": "Je peux avoir une fourchette ?" }] },
    { "id": "fr_fd_054", "levels": [{ "front": "spoon", "back": "la cuillère" }, { "front": "I need a spoon.", "back": "J'ai besoin d'une cuillère." }] },
    { "id": "fr_fd_055", "levels": [{ "front": "plate", "back": "l'assiette (fem.)" }, { "front": "The plate is dirty.", "back": "L'assiette est sale." }] },
    { "id": "fr_fd_056", "levels": [{ "front": "bowl", "back": "le bol" }, { "front": "Fill the bowl with soup.", "back": "Remplis le bol de soupe." }] },
    { "id": "fr_fd_058", "levels": [{ "front": "glass", "back": "le verre" }, { "front": "A glass of water, please.", "back": "Un verre d'eau, s'il vous plaît." }] },
    { "id": "fr_fd_059", "levels": [{ "front": "bottle", "back": "la bouteille" }, { "front": "A bottle of wine, please.", "back": "Une bouteille de vin, s'il vous plaît." }] },
    { "id": "fr_fd_060", "levels": [{ "front": "table", "back": "la table" }, { "front": "Our table is ready.", "back": "Notre table est prête." }] },
    { "id": "fr_fd_061", "levels": [{ "front": "waiter", "back": "le serveur / la serveuse" }, { "front": "Waiter, the bill please.", "back": "Monsieur, l'addition s'il vous plaît." }] },
    { "id": "fr_fd_062", "levels": [{ "front": "hungry", "back": "avoir faim", "grammarNote": "French uses avoir (to have) for hunger and thirst: avoir faim = to be hungry, avoir soif = to be thirsty. Also: avoir froid/chaud (to be cold/hot), avoir peur (to be afraid). These sensations are expressed as 'having' something, not 'being' something — never 'être faim'." }, { "front": "I'm hungry. Are you thirsty?", "back": "J'ai faim. Tu as soif ?" }] },
    { "id": "fr_fd_063", "levels": [{ "front": "thirsty", "back": "avoir soif" }, { "front": "I'm thirsty.", "back": "J'ai soif." }] },
    { "id": "fr_fd_064", "levels": [{ "front": "eat", "back": "manger" }, { "front": "Let's eat!", "back": "On mange !" }] },
    { "id": "fr_fd_065", "levels": [{ "front": "drink", "back": "boire" }, { "front": "Would you like something to drink?", "back": "Tu veux quelque chose à boire ?" }] },
    { "id": "fr_fd_066", "levels": [{ "front": "cook", "back": "cuisiner / faire la cuisine" }, { "front": "She cooks very well.", "back": "Elle cuisine très bien." }] },
    { "id": "fr_fd_067", "levels": [{ "front": "bake", "back": "faire cuire au four" }, { "front": "I bake bread on Sundays.", "back": "Je fais cuire du pain au four le dimanche." }] },
    { "id": "fr_fd_069", "levels": [{ "front": "fry", "back": "frire / faire revenir" }, { "front": "Fry the onions in oil.", "back": "Faites revenir les oignons dans l'huile." }] },
    { "id": "fr_fd_070", "levels": [{ "front": "roast", "back": "rôtir / faire rôtir" }, { "front": "Roast the chicken for one hour.", "back": "Faites rôtir le poulet pendant une heure." }] },
    { "id": "fr_fd_072", "levels": [{ "front": "chop", "back": "couper / hacher" }, { "front": "Chop the onions.", "back": "Hachez les oignons." }] },
    { "id": "fr_fd_073", "levels": [{ "front": "slice", "back": "couper en tranches / trancher" }, { "front": "Slice the bread.", "back": "Tranchez le pain." }] },
    { "id": "fr_fd_074", "levels": [{ "front": "mix", "back": "mélanger" }, { "front": "Mix all the ingredients.", "back": "Mélangez tous les ingrédients." }] },
    { "id": "fr_fd_075", "levels": [{ "front": "stir", "back": "remuer / mélanger" }, { "front": "Stir the soup.", "back": "Remuez la soupe." }] },
