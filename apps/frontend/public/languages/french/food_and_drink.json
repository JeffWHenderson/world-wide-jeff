    { "id": "fr_fd_087", "levels": [{ "front": "ripe", "back": "mûr / mûre" }, { "front": "The tomatoes are ripe.", "back": "Les tomates sont mûres." }] },
    { "id": "fr_fd_089", "levels": [{ "front": "cooked", "back": "cuit / cuite" }, { "front": "Is the chicken cooked?", "back": "Le poulet est cuit ?" }] },
    { "id": "fr_fd_090", "levels": [{ "front": "hot", "back": "chaud / chaude" }, { "front": "Be careful, the soup is hot.", "back": "Attention, la soupe est chaude." }] },
    { "id": "fr_fd_091", "levels": [{ "front": "cold", "back": "froid / froide" }, { "front": "My coffee is cold.", "back": "Mon café est froid." }] },
    { "id": "fr_fd_092", "levels": [{ "front": "sweet", "back": "sucré / sucrée" }, { "front": "This cake is very sweet.", "back": "Ce gâteau est très sucré." }] },
    { "id": "fr_fd_093", "levels": [{ "front": "sour", "back": "aigre / acide" }, { "front": "This lemon is sour.", "back": "Ce citron est acide." }] },
    { "id": "fr_fd_095", "levels": [{ "front": "bitter", "back": "amer / amère" }, { "front": "This coffee is bitter.", "back": "Ce café est amer." }] },
    { "id": "fr_fd_096", "levels": [{ "front": "spicy", "back": "épicé / épicée / piquant" }, { "front": "Mexican food is often spicy.", "back": "La cuisine mexicaine est souvent épicée." }] },
    { "id": "fr_fd_099", "levels": [{ "front": "tender", "back": "tendre" }, { "front": "The meat is tender.", "back": "La viande est tendre." }] },
    { "id": "fr_fd_101", "levels": [{ "front": "delicious", "back": "délicieux / délicieuse" }, { "front": "This is delicious!", "back": "C'est délicieux !" }] },
    { "id": "fr_fd_102", "levels": [{ "front": "tasty", "back": "savoureux / savoureuse" }, { "front": "The soup is very tasty.", "back": "La soupe est très savoureuse." }] },
    { "id": "fr_fd_103", "levels": [{ "front": "bland", "back": "fade / sans goût" }, { "front": "The rice is bland.", "back": "Le riz est fade." }] },
