    { "id": "fr_jh_076", "levels": [{ "front": "Meeting", "back": "La réunion" }, { "front": "We have a meeting at ten.", "back": "On a une réunion à dix heures." }] },
    { "id": "fr_jh_077", "levels": [{ "front": "Free time", "back": "Le temps libre" }, { "front": "What do you do in your free time?", "back": "Qu'est-ce que tu fais pendant ton temps libre ?" }] }
  ]
}
