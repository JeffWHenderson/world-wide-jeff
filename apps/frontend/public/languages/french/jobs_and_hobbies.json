    { "id": "fr_jh_072", "levels": [{ "front": "Colleague", "back": "Le/La collègue" }, { "front": "My coworkers are friendly.", "back": "Mes collègues sont sympas." }] },
    { "id": "fr_jh_073", "levels": [{ "front": "Customer", "back": "Le client / La cliente" }, { "front": "The client is happy.", "back": "Le client est content." }] },
    { "id": "fr_jh_074", "levels": [{ "front": "Team", "back": "L'équipe (fem.)" }, { "front": "I work in a great team.", "back": "Je travaille dans une super équipe." }] },
