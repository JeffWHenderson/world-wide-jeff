    { "id": "fr_jh_053", "levels": [{ "front": "To help", "back": "Aider" }, { "front": "Can I help you?", "back": "Je peux t'aider ?" }] },
    { "id": "fr_jh_054", "levels": [{ "front": "To manage", "back": "Diriger / Gérer" }, { "front": "She manages the team.", "back": "Elle dirige l'équipe." }] },
    { "id": "fr_jh_055", "levels": [{ "front": "To meet", "back": "Se réunir / Se retrouver" }, { "front": "We meet every Monday.", "back": "On se réunit chaque lundi." }] },
    { "id": "fr_jh_056", "levels": [{ "front": "To start", "back": "Commencer / Démarrer" }, { "front": "I start work at eight.", "back": "Je commence à travailler à huit heures." }] },
    { "id": "fr_jh_057", "levels": [{ "front": "To finish", "back": "Finir / Terminer" }, { "front": "I finish work at five.", "back": "Je termine le travail à cinq heures." }] },
    { "id": "fr_jh_058", "levels": [{ "front": "To like / To enjoy", "back": "Aimer / Apprécier", "grammarNote": "Aimer + infinitive = to like doing something: 'J'aime lire' (I like reading). Aimer bien softens aimer when talking about things (vs people): 'J'aime bien ce film'. Adorer is stronger: 'J'adore la musique'. For activities with faire, add 'de': 'J'aime faire du sport'." }, { "front": "I like reading. She likes singing.", "back": "J'aime lire. Elle aime chanter." }] },
    { "id": "fr_jh_059", "levels": [{ "front": "To relax", "back": "Se détendre / Se relaxer" }, { "front": "I relax on weekends.", "back": "Je me détends le week-end." }] },
    { "id": "fr_jh_060", "levels": [{ "front": "To spend time (on)", "back": "Passer du temps (à)" }, { "front": "I spend a lot of time reading.", "back": "Je passe beaucoup de temps à lire." }] },
    { "id": "fr_jh_061", "levels": [{ "front": "Creative", "back": "Créatif / Créative" }, { "front": "She is very creative.", "back": "Elle est très créative." }] },
    { "id": "fr_jh_062", "levels": [{ "front": "Interesting", "back": "Intéressant / Intéressante" }, { "front": "My job is interesting.", "back": "Mon travail est intéressant." }] },
    { "id": "fr_jh_063", "levels": [{ "front": "Stressful", "back": "Stressant / Stressante" }, { "front": "My job is stressful.", "back": "Mon travail est stressant." }] },
    { "id": "fr_jh_064", "levels": [{ "front": "Boring", "back": "Ennuyeux / Ennuyeuse" }, { "front": "The meeting was boring.", "back": "La réunion était ennuyeuse." }] },
    { "id": "fr_jh_065", "levels": [{ "front": "Salary", "back": "Le salaire" }, { "front": "What is the salary?", "back": "Quel est le salaire ?" }] },
    { "id": "fr_jh_066", "levels": [{ "front": "Schedule", "back": "L'emploi du temps / L'horaire" }, { "front": "My schedule is flexible.", "back": "Mon emploi du temps est flexible." }] },
    { "id": "fr_jh_067", "levels": [{ "front": "Vacation", "back": "Les vacances (fem. pl.)" }, { "front": "I'm going on vacation next week.", "back": "Je pars en vacances la semaine prochaine." }] },
    { "id": "fr_jh_068", "levels": [{ "front": "Break", "back": "La pause" }, { "front": "Let's take a break.", "back": "Prenons une pause." }] },
