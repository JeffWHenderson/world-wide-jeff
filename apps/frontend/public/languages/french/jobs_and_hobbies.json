    { "id": "fr_jh_037", "levels": [{ "front": "Board games", "back": "Les jeux de société" }, { "front": "We play board games on weekends.", "back": "On joue aux jeux de société le week-end." }] },
    { "id": "fr_jh_038", "levels": [{ "front": "To work (in/for/as)", "back": "Travailler (dans/pour/comme)" }, { "front": "I work in a hospital.", "back": "Je travaille dans un hôpital." }] },
    { "id": "fr_jh_039", "levels": [{ "front": "To earn (a salary)", "back": "Gagner (un salaire)" }, { "front": "He earns a good salary.", "back": "Il gagne un bon salaire." }] },
    { "id": "fr_jh_040", "levels": [{ "front": "To retire", "back": "Prendre sa retraite / Partir à la retraite" }, { "front": "She retired last year.", "back": "Elle a pris sa retraite l'année dernière." }] },
    { "id": "fr_jh_041", "levels": [{ "front": "To have a job", "back": "Avoir un travail / un emploi" }, { "front": "I have a good job.", "back": "J'ai un bon travail." }] },
