  "cards": [
    { "id": "fr_jh_001", "levels": [{ "front": "Doctor", "back": "Le médecin / Le docteur", "grammarNote": "In French, omit the article with professions after être: 'Je suis médecin' (not 'un médecin') — unless the noun is modified: 'Je suis un bon médecin'. This differs from English but is standard for all professions: 'Elle est avocate', 'Il est ingénieur'." }, { "front": "He is a doctor.", "back": "Il est médecin." }] },
    { "id": "fr_jh_002", "levels": [{ "front": "Nurse", "back": "L'infirmier / L'infirmière" }, { "front": "She is a nurse.", "back": "Elle est infirmière." }] },
    { "id": "fr_jh_003", "levels": [{ "front": "Engineer", "back": "L'ingénieur (masc.)" }, { "front": "My brother is an engineer.", "back": "Mon frère est ingénieur." }] },
    { "id": "fr_jh_004", "levels": [{ "front": "Programmer", "back": "Le programmeur / Le développeur" }, { "front": "I work as a programmer.", "back": "Je travaille comme développeur." }] },
    { "id": "fr_jh_005", "levels": [{ "front": "Cook", "back": "Le cuisinier / La cuisinière" }, { "front": "The cook works in the kitchen.", "back": "Le cuisinier travaille en cuisine." }] },
    { "id": "fr_jh_006", "levels": [{ "front": "Waiter (Waitress)", "back": "Le serveur (La serveuse)" }, { "front": "The waiter brought the menu.", "back": "Le serveur a apporté la carte." }] },
    { "id": "fr_jh_007", "levels": [{ "front": "Manager", "back": "Le directeur / Le manager" }, { "front": "She is a manager.", "back": "Elle est directrice." }] },
