  "cards": [
    { "id": "fr_jh_001", "levels": [{ "front": "Work / job", "back": "le travail / le boulot", "grammarNote": "'Le boulot' is informal/colloquial for 'le travail' (work/job). Very common in everyday speech." }, { "front": "I love my work.", "back": "J'adore mon travail." }] },
    { "id": "fr_jh_002", "levels": [{ "front": "To work", "back": "travailler" }, { "front": "I work from home.", "back": "Je travaille à la maison." }] },
    { "id": "fr_jh_003", "levels": [{ "front": "The office", "back": "le bureau" }, { "front": "I go to the office on Mondays.", "back": "Je vais au bureau le lundi." }] },
    { "id": "fr_jh_004", "levels": [{ "front": "The meeting", "back": "la réunion" }, { "front": "I have a meeting at three o'clock.", "back": "J'ai une réunion à trois heures." }] },
    { "id": "fr_jh_005", "levels": [{ "front": "The colleague", "back": "le/la collègue" }, { "front": "My colleagues are very nice.", "back": "Mes collègues sont très sympas." }] },
    { "id": "fr_jh_006", "levels": [{ "front": "The boss", "back": "le patron / la patronne" }, { "front": "My boss is quite demanding.", "back": "Mon patron est assez exigeant." }] },
    { "id": "fr_jh_007", "levels": [{ "front": "The salary", "back": "le salaire" }, { "front": "I'd like a raise.", "back": "J'aimerais une augmentation de salaire." }] },
    { "id": "fr_jh_008", "levels": [{ "front": "The job interview", "back": "l'entretien (d'embauche)" }, { "front": "I have a job interview tomorrow.", "back": "J'ai un entretien demain." }] },
    { "id": "fr_jh_009", "levels": [{ "front": "Unemployed", "back": "au chômage" }, { "front": "He's been unemployed for three months.", "back": "Il est au chômage depuis trois mois." }] },
    { "id": "fr_jh_010", "levels": [{ "front": "Doctor", "back": "le médecin / le docteur" }, { "front": "I want to become a doctor.", "back": "Je veux devenir médecin." }] },
    { "id": "fr_jh_011", "levels": [{ "front": "Teacher", "back": "le professeur / l'instituteur" }, { "front": "She's a primary school teacher.", "back": "Elle est institutrice à l'école primaire." }] },
    { "id": "fr_jh_012", "levels": [{ "front": "Engineer", "back": "l'ingénieur (masc.)" }, { "front": "He works as a software engineer.", "back": "Il travaille comme ingénieur informatique." }] },
    { "id": "fr_jh_013", "levels": [{ "front": "Chef / cook", "back": "le chef / le cuisinier" }, { "front": "She's a chef in a starred restaurant.", "back": "Elle est chef dans un restaurant étoilé." }] },
    { "id": "fr_jh_014", "levels": [{ "front": "Student", "back": "l'étudiant / l'étudiante" }, { "front": "I'm a student at the university.", "back": "Je suis étudiant(e) à l'université." }] },
    { "id": "fr_jh_015", "levels": [{ "front": "Nurse", "back": "l'infirmier / l'infirmière" }, { "front": "My mother is a nurse.", "back": "Ma mère est infirmière." }] },
    { "id": "fr_jh_016", "levels": [{ "front": "What do you do for work?", "back": "Tu fais quoi dans la vie ?" }, { "front": "What do you do? — I'm an accountant.", "back": "Tu fais quoi dans la vie ? — Je suis comptable." }] },
    { "id": "fr_jh_017", "levels": [{ "front": "Hobby / pastime", "back": "le passe-temps / le loisir" }, { "front": "What are your hobbies?", "back": "Quels sont tes loisirs ?" }] },
    { "id": "fr_jh_018", "levels": [{ "front": "To read", "back": "lire" }, { "front": "I like to read in the evenings.", "back": "J'aime lire le soir." }] },
    { "id": "fr_jh_019", "levels": [{ "front": "To write", "back": "écrire" }, { "front": "She writes poetry.", "back": "Elle écrit de la poésie." }] },
    { "id": "fr_jh_020", "levels": [{ "front": "To cook", "back": "cuisiner / faire la cuisine" }, { "front": "I love cooking on weekends.", "back": "J'adore cuisiner le week-end." }] },
    { "id": "fr_jh_021", "levels": [{ "front": "To play (sport)", "back": "jouer à" }, { "front": "I play tennis on Saturdays.", "back": "Je joue au tennis le samedi." }] },
    { "id": "fr_jh_022", "levels": [{ "front": "To play (music)", "back": "jouer de", "grammarNote": "Jouer à = to play a sport or game. Jouer de = to play a musical instrument. 'Je joue au foot' vs 'Je joue du piano'." }, { "front": "She plays the piano.", "back": "Elle joue du piano." }] },
    { "id": "fr_jh_023", "levels": [{ "front": "To listen to music", "back": "écouter de la musique" }, { "front": "I listen to music while I work.", "back": "J'écoute de la musique en travaillant." }] },
    { "id": "fr_jh_024", "levels": [{ "front": "To watch TV / movies", "back": "regarder la télé / des films" }, { "front": "I watch a movie on Friday evenings.", "back": "Je regarde un film le vendredi soir." }] },
    { "id": "fr_jh_025", "levels": [{ "front": "To travel", "back": "voyager" }, { "front": "I love to travel.", "back": "J'adore voyager." }] },
    { "id": "fr_jh_026", "levels": [{ "front": "To run / jog", "back": "courir / faire du jogging" }, { "front": "I run three times a week.", "back": "Je cours trois fois par semaine." }] },
    { "id": "fr_jh_027", "levels": [{ "front": "To swim", "back": "nager" }, { "front": "I swim in the summer.", "back": "Je nage en été." }] },
    { "id": "fr_jh_028", "levels": [{ "front": "To paint / draw", "back": "peindre / dessiner" }, { "front": "My daughter likes to draw.", "back": "Ma fille aime dessiner." }] },
    { "id": "fr_jh_029", "levels": [{ "front": "Free time", "back": "le temps libre" }, { "front": "I don't have much free time.", "back": "Je n'ai pas beaucoup de temps libre." }] },
    { "id": "fr_jh_030", "levels": [{ "front": "The weekend", "back": "le week-end" }, { "front": "What are you doing this weekend?", "back": "Tu fais quoi ce week-end ?" }] }
