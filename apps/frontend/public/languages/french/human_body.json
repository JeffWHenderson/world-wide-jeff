    { "id": "fr_hb_038", "levels": [{ "front": "stretch", "back": "s'étirer / étirer" }, { "front": "Stretch your arms.", "back": "Étire les bras." }] },
    { "id": "fr_hb_039", "levels": [{ "front": "flex", "back": "contracter / fléchir" }, { "front": "Flex your muscles.", "back": "Contracte tes muscles." }] },
    { "id": "fr_hb_040", "levels": [{ "front": "blink", "back": "cligner des yeux" }, { "front": "Don't blink.", "back": "Ne cligne pas des yeux." }] },
    { "id": "fr_hb_041", "levels": [{ "front": "sweat", "back": "transpirer / suer" }, { "front": "I sweat when I run.", "back": "Je transpire quand je cours." }] },
    { "id": "fr_hb_042", "levels": [{ "front": "bleed", "back": "saigner" }, { "front": "The wound is bleeding.", "back": "La blessure saigne." }] },
    { "id": "fr_hb_043", "levels": [{ "front": "feel", "back": "se sentir / ressentir" }, { "front": "How do you feel?", "back": "Comment tu te sens ?" }] },
    { "id": "fr_hb_044", "levels": [{ "front": "think", "back": "penser / réfléchir" }, { "front": "What are you thinking about?", "back": "À quoi tu penses ?" }] },
    { "id": "fr_hb_045", "levels": [{ "front": "move", "back": "bouger / se déplacer" }, { "front": "I can't move my arm.", "back": "Je ne peux pas bouger le bras." }] },
    { "id": "fr_hb_046", "levels": [{ "front": "bony", "back": "osseux / maigre" }, { "front": "His hands are bony.", "back": "Il a les mains osseuses." }] },
    { "id": "fr_hb_047", "levels": [{ "front": "hairy", "back": "poilu / velu" }, { "front": "He has hairy arms.", "back": "Il a les bras poilus." }] },
    { "id": "fr_hb_048", "levels": [{ "front": "soft", "back": "doux / douce" }, { "front": "The tissue is soft.", "back": "Le tissu est doux." }] },
    { "id": "fr_hb_049", "levels": [{ "front": "sore", "back": "douloureux / endolori" }, { "front": "My muscles are sore.", "back": "Mes muscles sont endoloris." }] },
    { "id": "fr_hb_050", "levels": [{ "front": "left", "back": "gauche" }, { "front": "I hurt my left knee.", "back": "Je me suis blessé(e) au genou gauche." }] },
