{
  "id": "moods_and_emotion",
  "name": "Moods & Emotion",
  "language": "french",
  "stories": ["a_bad_day", "good_news"],
  "cards": [
    { "id": "fr_me_001", "levels": [{ "front": "happy", "back": "heureux / heureuse" }, { "front": "I'm very happy today.", "back": "Je suis très heureux/heureuse aujourd'hui." }] },
    { "id": "fr_me_002", "levels": [{ "front": "sad", "back": "triste" }, { "front": "Why are you sad?", "back": "Pourquoi tu es triste ?" }] },
    { "id": "fr_me_003", "levels": [{ "front": "love", "back": "l'amour (masc.)" }, { "front": "I feel a lot of love for my family.", "back": "Je ressens beaucoup d'amour pour ma famille." }] },
    { "id": "fr_me_004", "levels": [{ "front": "anger", "back": "la colère" }, { "front": "I felt anger when they lied to me.", "back": "J'ai ressenti de la colère quand ils m'ont menti." }] },
    { "id": "fr_me_005", "levels": [{ "front": "fear", "back": "la peur" }, { "front": "I'm afraid of the dark.", "back": "J'ai peur du noir." }] },
    { "id": "fr_me_006", "levels": [{ "front": "hope", "back": "l'espoir (masc.)" }, { "front": "I have hope for the future.", "back": "J'ai de l'espoir pour l'avenir." }] },
    { "id": "fr_me_007", "levels": [{ "front": "stress", "back": "le stress" }, { "front": "I have a lot of stress at work.", "back": "J'ai beaucoup de stress au travail." }] },
    { "id": "fr_me_008", "levels": [{ "front": "mood", "back": "l'humeur (fem.)" }, { "front": "I'm in a good mood today.", "back": "Je suis de bonne humeur aujourd'hui." }] },
    { "id": "fr_me_009", "levels": [{ "front": "feeling", "back": "le sentiment / la sensation" }, { "front": "That feeling is normal.", "back": "Ce sentiment est normal." }] },
    { "id": "fr_me_010", "levels": [{ "front": "emotion / excitement", "back": "l'émotion (fem.)" }, { "front": "I couldn't hide my emotion.", "back": "Je n'ai pas pu cacher mon émotion." }] },
    { "id": "fr_me_011", "levels": [{ "front": "calm", "back": "le calme" }, { "front": "Try to maintain your calm.", "back": "Essaie de garder ton calme." }] },
    { "id": "fr_me_012", "levels": [{ "front": "peace", "back": "la paix" }, { "front": "I need peace and quiet.", "back": "J'ai besoin de paix et de tranquillité." }] },
    { "id": "fr_me_013", "levels": [{ "front": "worry", "back": "l'inquiétude (fem.) / le souci" }, { "front": "Don't let worry stop you.", "back": "Ne laisse pas l'inquiétude t'arrêter." }] },
    { "id": "fr_me_014", "levels": [{ "front": "surprise", "back": "la surprise" }, { "front": "What a surprise!", "back": "Quelle surprise !" }] },
    { "id": "fr_me_015", "levels": [{ "front": "passion", "back": "la passion" }, { "front": "She teaches with passion.", "back": "Elle enseigne avec passion." }] },
    { "id": "fr_me_016", "levels": [{ "front": "desire", "back": "le désir / l'envie (fem.)" }, { "front": "I have a strong desire to travel.", "back": "J'ai une grande envie de voyager." }] },
    { "id": "fr_me_017", "levels": [{ "front": "hate", "back": "la haine" }, { "front": "Hate is a strong feeling.", "back": "La haine est un sentiment fort." }] },
    { "id": "fr_me_018", "levels": [{ "front": "pleasure", "back": "le plaisir" }, { "front": "It's a pleasure to meet you.", "back": "C'est un plaisir de vous rencontrer." }] },
    { "id": "fr_me_019", "levels": [{ "front": "pain", "back": "la douleur" }, { "front": "I feel pain in my leg.", "back": "Je ressens une douleur dans la jambe." }] },
    { "id": "fr_me_020", "levels": [{ "front": "energy", "back": "l'énergie (fem.)" }, { "front": "I have a lot of energy today.", "back": "J'ai beaucoup d'énergie aujourd'hui." }] },
    { "id": "fr_me_021", "levels": [{ "front": "relief", "back": "le soulagement" }, { "front": "What a relief!", "back": "Quel soulagement !" }] },
    { "id": "fr_me_022", "levels": [{ "front": "comfort", "back": "le réconfort / le confort" }, { "front": "Her words were a comfort.", "back": "Ses mots étaient un réconfort." }] },
    { "id": "fr_me_023", "levels": [{ "front": "feel (to feel)", "back": "se sentir / ressentir", "grammarNote": "Se sentir = to feel a certain way (état): 'Je me sens bien' (I feel good). Ressentir = to feel/experience an emotion: 'Je ressens de la joie' (I feel joy). Both are common but used in slightly different contexts." }, { "front": "I feel good today.", "back": "Je me sens bien aujourd'hui." }] },
    { "id": "fr_me_024", "levels": [{ "front": "love (to love)", "back": "aimer / adorer" }, { "front": "I love you very much.", "back": "Je t'aime beaucoup." }] },
    { "id": "fr_me_025", "levels": [{ "front": "hate (to hate)", "back": "détester / haïr" }, { "front": "I hate waiting.", "back": "Je déteste attendre." }] },
    { "id": "fr_me_026", "levels": [{ "front": "like (to like)", "back": "aimer / aimer bien" }, { "front": "I like music.", "back": "J'aime bien la musique." }] },
    { "id": "fr_me_027", "levels": [{ "front": "enjoy", "back": "apprécier / profiter de" }, { "front": "I enjoy the weekend.", "back": "Je profite du week-end." }] },
    { "id": "fr_me_028", "levels": [{ "front": "fear / dread (to fear)", "back": "craindre / avoir peur de" }, { "front": "I fear the worst.", "back": "Je crains le pire." }] },
    { "id": "fr_me_029", "levels": [{ "front": "hope (to hope)", "back": "espérer" }, { "front": "I hope everything goes well.", "back": "J'espère que tout se passe bien." }] },
    { "id": "fr_me_030", "levels": [{ "front": "worry (to worry)", "back": "s'inquiéter" }, { "front": "Don't worry about it.", "back": "Ne t'inquiète pas pour ça." }] },
    { "id": "fr_me_031", "levels": [{ "front": "calm / soothe (to calm)", "back": "calmer / se calmer" }, { "front": "Calm down, please.", "back": "Calme-toi, s'il te plaît." }] },
    { "id": "fr_me_032", "levels": [{ "front": "comfort (to comfort)", "back": "réconforter / consoler" }, { "front": "She comforted her friend.", "back": "Elle a réconforté son amie." }] },
    { "id": "fr_me_033", "levels": [{ "front": "excite / thrill", "back": "enthousiasmer / exciter" }, { "front": "The trip excites me.", "back": "Le voyage m'enthousiasme." }] },
    { "id": "fr_me_034", "levels": [{ "front": "annoy", "back": "agacer / énerver" }, { "front": "That noise annoys me.", "back": "Ce bruit m'agace." }] },
    { "id": "fr_me_035", "levels": [{ "front": "irritate", "back": "irriter / énerver" }, { "front": "Waiting irritates me.", "back": "Attendre m'irrite." }] },
    { "id": "fr_me_036", "levels": [{ "front": "anger (to anger)", "back": "mettre en colère / fâcher" }, { "front": "That comment angered me.", "back": "Ce commentaire m'a mis en colère." }] },
    { "id": "fr_me_037", "levels": [{ "front": "delight", "back": "ravir / enchanter / régaler" }, { "front": "The music delighted everyone.", "back": "La musique a ravi tout le monde." }] },
    { "id": "fr_me_038", "levels": [{ "front": "smile", "back": "sourire" }, { "front": "She always smiles.", "back": "Elle sourit toujours." }] },
    { "id": "fr_me_039", "levels": [{ "front": "laugh", "back": "rire" }, { "front": "We laughed a lot.", "back": "On a beaucoup ri." }] },
    { "id": "fr_me_040", "levels": [{ "front": "cry / weep / mourn", "back": "pleurer" }, { "front": "The baby is crying.", "back": "Le bébé pleure." }] },
    { "id": "fr_me_041", "levels": [{ "front": "sigh", "back": "soupirer" }, { "front": "She sighed with relief.", "back": "Elle a soupiré de soulagement." }] },
    { "id": "fr_me_042", "levels": [{ "front": "frown", "back": "froncer les sourcils" }, { "front": "He frowned when he heard the news.", "back": "Il a froncé les sourcils en entendant la nouvelle." }] },
    { "id": "fr_me_043", "levels": [{ "front": "scream / shout", "back": "crier / hurler" }, { "front": "Don't shout, please.", "back": "Ne crie pas, s'il te plaît." }] },
    { "id": "fr_me_044", "levels": [{ "front": "relax", "back": "se détendre / se relaxer" }, { "front": "Relax, there's no rush.", "back": "Détends-toi, il n'y a pas d'urgence." }] },
    { "id": "fr_me_045", "levels": [{ "front": "angry", "back": "en colère / fâché(e)" }, { "front": "I'm angry with you.", "back": "Je suis en colère contre toi." }] },
    { "id": "fr_me_046", "levels": [{ "front": "mad", "back": "furieux / furieuse / très fâché(e)" }, { "front": "Why are you so mad?", "back": "Pourquoi tu es si furieux/furieuse ?" }] },
    { "id": "fr_me_047", "levels": [{ "front": "afraid / scared", "back": "effrayé(e) / apeuré(e)" }, { "front": "The child was scared.", "back": "L'enfant était effrayé." }] },
    { "id": "fr_me_048", "levels": [{ "front": "anxious", "back": "anxieux / anxieuse / angoissé(e)" }, { "front": "I'm anxious about the exam.", "back": "Je suis anxieux/anxieuse pour l'examen." }] },
    { "id": "fr_me_049", "levels": [{ "front": "nervous", "back": "nerveux / nerveuse" }, { "front": "I'm nervous today.", "back": "Je suis nerveux/nerveuse aujourd'hui." }] },
    { "id": "fr_me_050", "levels": [{ "front": "excited", "back": "enthousiaste / excité(e)" }, { "front": "I'm excited about the trip.", "back": "Je suis enthousiaste pour le voyage." }] },
    { "id": "fr_me_051", "levels": [{ "front": "joyful / cheerful", "back": "joyeux / joyeuse / enjoué(e)" }, { "front": "She is always cheerful.", "back": "Elle est toujours joyeuse." }] },
    { "id": "fr_me_052", "levels": [{ "front": "proud", "back": "fier / fière" }, { "front": "I'm proud of you.", "back": "Je suis fier/fière de toi." }] },
    { "id": "fr_me_053", "levels": [{ "front": "content / contented", "back": "content(e) / satisfait(e)" }, { "front": "I'm content with my life.", "back": "Je suis content(e) de ma vie." }] },
    { "id": "fr_me_054", "levels": [{ "front": "calm", "back": "calme / tranquille" }, { "front": "Stay calm, everything is fine.", "back": "Reste calme, tout va bien." }] },
    { "id": "fr_me_055", "levels": [{ "front": "stressed", "back": "stressé(e)" }, { "front": "I'm very stressed this week.", "back": "Je suis très stressé(e) cette semaine." }] },
    { "id": "fr_me_056", "levels": [{ "front": "overwhelmed", "back": "dépassé(e) / submergé(e) / débordé(e)" }, { "front": "I feel overwhelmed by the work.", "back": "Je me sens dépassé(e) par le travail." }] },
    { "id": "fr_me_057", "levels": [{ "front": "energetic", "back": "énergique / plein(e) d'énergie" }, { "front": "She is very energetic.", "back": "Elle est très énergique." }] },
    { "id": "fr_me_058", "levels": [{ "front": "tired", "back": "fatigué(e)" }, { "front": "I'm very tired today.", "back": "Je suis très fatigué(e) aujourd'hui." }] },
    { "id": "fr_me_059", "levels": [{ "front": "exhausted", "back": "épuisé(e) / crevé(e)" }, { "front": "I'm exhausted after the run.", "back": "Je suis épuisé(e) après la course." }] },
    { "id": "fr_me_060", "levels": [{ "front": "curious", "back": "curieux / curieuse" }, { "front": "I'm curious about that.", "back": "Je suis curieux/curieuse à ce sujet." }] }
  ]
