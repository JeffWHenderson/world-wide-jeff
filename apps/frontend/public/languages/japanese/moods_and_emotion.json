{
  "id": "moods_and_emotion",
  "name": "Moods & Emotions",
  "language": "japanese",
  "stories": ["sean", "a_bad_day", "friendship", "good_news"],
  "pictureLessons": ["moodsAndEmotion", "moodsAndEmotion2"],
  "cards": [
    { "id": "ja_me_001", "levels": [{ "front": "happy", "back": "嬉しい / 幸せな", "romanized": "ureshii / shiawase na", "grammarNote": "Japanese has two words for happy: 'ureshii' (嬉しい) expresses a momentary feeling of happiness or joy (something made you happy). 'Shiawase' (幸せ) refers to a deeper, more lasting sense of happiness or contentment. Both are i-adjectives." }, { "front": "I'm very happy today.", "back": "今日はとても嬉しいです。", "romanized": "kyō wa totemo ureshii desu" }] },
    { "id": "ja_me_002", "levels": [{ "front": "sad", "back": "悲しい", "romanized": "kanashii" }, { "front": "Why are you sad?", "back": "なぜ悲しいのですか？", "romanized": "naze kanashii no desu ka" }] },
    { "id": "ja_me_003", "levels": [{ "front": "love", "back": "愛 / 愛情", "romanized": "ai / aijō" }, { "front": "I feel a lot of love for my family.", "back": "家族への愛をたくさん感じます。", "romanized": "kazoku e no ai wo takusan kanjimasu" }] },
    { "id": "ja_me_004", "levels": [{ "front": "anger", "back": "怒り", "romanized": "ikari" }, { "front": "I felt anger when they lied to me.", "back": "嘘をつかれたとき、怒りを感じました。", "romanized": "uso wo tsukareta toki, ikari wo kanjimashita" }] },
    { "id": "ja_me_005", "levels": [{ "front": "fear", "back": "恐怖 / 恐れ", "romanized": "kyōfu / osore" }, { "front": "I'm afraid of the dark.", "back": "暗いのが怖いです。", "romanized": "kurai no ga kowai desu" }] },
    { "id": "ja_me_006", "levels": [{ "front": "hope", "back": "希望 / 望み", "romanized": "kibō / nozomi" }, { "front": "I have hope for the future.", "back": "将来への希望があります。", "romanized": "shōrai e no kibō ga arimasu" }] },
    { "id": "ja_me_007", "levels": [{ "front": "stress", "back": "ストレス", "romanized": "sutoresu" }, { "front": "I have a lot of stress at work.", "back": "仕事でストレスがたくさんあります。", "romanized": "shigoto de sutoresu ga takusan arimasu" }] },
    { "id": "ja_me_008", "levels": [{ "front": "mood", "back": "気分 / 気持ち", "romanized": "kibun / kimochi" }, { "front": "I'm in a good mood today.", "back": "今日は気分がいいです。", "romanized": "kyō wa kibun ga ii desu" }] },
    { "id": "ja_me_009", "levels": [{ "front": "feeling", "back": "感情 / 気持ち", "romanized": "kanjō / kimochi" }, { "front": "That feeling is normal.", "back": "その気持ちは普通です。", "romanized": "sono kimochi wa futsū desu" }] },
    { "id": "ja_me_010", "levels": [{ "front": "emotion / excitement", "back": "感情 / 感動 / 興奮", "romanized": "kanjō / kandō / kōfun" }, { "front": "I couldn't hide my emotion.", "back": "感動を隠せませんでした。", "romanized": "kandō wo kakusemasen deshita" }] },
    { "id": "ja_me_011", "levels": [{ "front": "calm", "back": "落ち着き / 穏やかさ", "romanized": "ochitsuki / odayakasa" }, { "front": "Try to maintain your calm.", "back": "落ち着きを保つようにしてください。", "romanized": "ochitsuki wo tamotsu yō ni shite kudasai" }] },
    { "id": "ja_me_012", "levels": [{ "front": "peace", "back": "平和 / 平静", "romanized": "heiwa / heisei" }, { "front": "I need peace and quiet.", "back": "静けさと平穏が必要です。", "romanized": "shizukesa to heion ga hitsuyō desu" }] },
    { "id": "ja_me_013", "levels": [{ "front": "worry", "back": "心配 / 不安", "romanized": "shinpai / fuan" }, { "front": "Don't let worry stop you.", "back": "心配で立ち止まらないでください。", "romanized": "shinpai de tachidomaranaide kudasai" }] },
    { "id": "ja_me_014", "levels": [{ "front": "surprise", "back": "驚き / サプライズ", "romanized": "odoroki / sapuraizu" }, { "front": "What a surprise!", "back": "なんと驚いた！", "romanized": "nanto odoroita" }] },
    { "id": "ja_me_015", "levels": [{ "front": "passion", "back": "情熱 / パッション", "romanized": "jōnetsu / passhon" }, { "front": "She teaches with passion.", "back": "彼女は情熱を持って教えています。", "romanized": "kanojo wa jōnetsu wo motte oshiete imasu" }] },
    { "id": "ja_me_016", "levels": [{ "front": "desire", "back": "欲望 / 願望", "romanized": "yokubō / ganbō" }, { "front": "I have a strong desire to travel.", "back": "旅行したいという強い願望があります。", "romanized": "ryokō shitai to iu tsuyoi ganbō ga arimasu" }] },
    { "id": "ja_me_017", "levels": [{ "front": "hate", "back": "憎しみ / 嫌悪", "romanized": "nikushimi / ken'o" }, { "front": "Hate is a strong feeling.", "back": "憎しみは強い感情です。", "romanized": "nikushimi wa tsuyoi kanjō desu" }] },
    { "id": "ja_me_018", "levels": [{ "front": "pleasure", "back": "喜び / 楽しみ", "romanized": "yorokobi / tanoshimi" }, { "front": "It's a pleasure to meet you.", "back": "はじめまして、お会いできて光栄です。", "romanized": "hajimemashite, oai dekite kōei desu" }] },
    { "id": "ja_me_019", "levels": [{ "front": "pain", "back": "痛み / 苦痛", "romanized": "itami / kutsū" }, { "front": "I feel pain in my leg.", "back": "足に痛みを感じます。", "romanized": "ashi ni itami wo kanjimasu" }] },
    { "id": "ja_me_020", "levels": [{ "front": "energy", "back": "エネルギー / 元気", "romanized": "enerugī / genki" }, { "front": "I have a lot of energy today.", "back": "今日はとても元気です。", "romanized": "kyō wa totemo genki desu" }] },
    { "id": "ja_me_021", "levels": [{ "front": "relief", "back": "安堵 / ホッとすること", "romanized": "ando / hotto suru koto" }, { "front": "What a relief!", "back": "ホッとしました！", "romanized": "hotto shimashita" }] },
    { "id": "ja_me_022", "levels": [{ "front": "comfort", "back": "慰め / 安心", "romanized": "nagusame / anshin" }, { "front": "Her words were a comfort.", "back": "彼女の言葉は慰めになりました。", "romanized": "kanojo no kotoba wa nagusame ni narimashita" }] },
    { "id": "ja_me_023", "levels": [{ "front": "feel (to feel)", "back": "感じる / 気分がする", "romanized": "kanjiru / kibun ga suru", "grammarNote": "Two ways to express 'feel' in Japanese: 'kanjiru' (感じる) means to physically or emotionally sense something ('pain wo kanjiru' = feel pain). 'Kibun ga suru' or 'ki ga suru' (気がする) means to have a feeling/hunch. For emotional state, use 'X na kibun' or 'X desu'." }, { "front": "I feel good today.", "back": "今日は気分がいいです。", "romanized": "kyō wa kibun ga ii desu" }] },
    { "id": "ja_me_024", "levels": [{ "front": "love (to love)", "back": "愛する / 大好き", "romanized": "aisuru / daisuki" }, { "front": "I love you very much.", "back": "あなたのことが大好きです。", "romanized": "anata no koto ga daisuki desu" }] },
    { "id": "ja_me_025", "levels": [{ "front": "hate (to hate)", "back": "嫌う / 大嫌い", "romanized": "kirau / daikirai" }, { "front": "I hate waiting.", "back": "待つのが大嫌いです。", "romanized": "matsu no ga daikirai desu" }] },
    { "id": "ja_me_026", "levels": [{ "front": "like (to like)", "back": "好きな / 好む", "romanized": "suki na / konomu" }, { "front": "I like music.", "back": "音楽が好きです。", "romanized": "ongaku ga suki desu" }] },
    { "id": "ja_me_027", "levels": [{ "front": "enjoy", "back": "楽しむ / 楽しい", "romanized": "tanoshimu / tanoshii" }, { "front": "I enjoy the weekend.", "back": "週末を楽しんでいます。", "romanized": "shūmatsu wo tanoshinde imasu" }] },
    { "id": "ja_me_028", "levels": [{ "front": "fear / dread (to fear)", "back": "恐れる / 怖がる", "romanized": "osoreru / kowagaru" }, { "front": "I fear the worst.", "back": "最悪の事態を恐れています。", "romanized": "saiaku no jitai wo osorete imasu" }] },
    { "id": "ja_me_029", "levels": [{ "front": "hope (to hope)", "back": "望む / 期待する", "romanized": "nozomu / kitai suru" }, { "front": "I hope everything goes well.", "back": "すべてうまくいくことを望んでいます。", "romanized": "subete umaku iku koto wo nozonde imasu" }] },
    { "id": "ja_me_030", "levels": [{ "front": "worry (to worry)", "back": "心配する", "romanized": "shinpai suru" }, { "front": "Don't worry about it.", "back": "それについて心配しないでください。", "romanized": "sore ni tsuite shinpai shinaide kudasai" }] },
    { "id": "ja_me_031", "levels": [{ "front": "calm / soothe (to calm)", "back": "落ち着かせる / 穏やかにする", "romanized": "ochitsukaseru / odayaka ni suru" }, { "front": "Calm down, please.", "back": "落ち着いてください。", "romanized": "ochitsuite kudasai" }] },
    { "id": "ja_me_032", "levels": [{ "front": "comfort (to comfort)", "back": "慰める / 励ます", "romanized": "nagusameru / hagemasu" }, { "front": "She comforted her friend.", "back": "彼女は友人を慰めました。", "romanized": "kanojo wa yūjin wo nagusamemashita" }] },
    { "id": "ja_me_033", "levels": [{ "front": "excite / thrill", "back": "興奮させる / ワクワクさせる", "romanized": "kōfun saseru / wakuwaku saseru" }, { "front": "The trip excites me.", "back": "旅行がワクワクします。", "romanized": "ryokō ga wakuwaku shimasu" }] },
    { "id": "ja_me_034", "levels": [{ "front": "annoy", "back": "イライラさせる / 悩ます", "romanized": "iraira saseru / nayamasu" }, { "front": "That noise annoys me.", "back": "その音にイライラします。", "romanized": "sono oto ni iraira shimasu" }] },
    { "id": "ja_me_035", "levels": [{ "front": "irritate", "back": "苛立たせる / 不快にする", "romanized": "iradataseru / fukai ni suru" }, { "front": "Waiting irritates me.", "back": "待つことが苛立たしいです。", "romanized": "matsu koto ga iradatashii desu" }] },
    { "id": "ja_me_036", "levels": [{ "front": "anger (to anger)", "back": "怒らせる / 腹を立てさせる", "romanized": "okoraseru / hara wo tatasesaseru" }, { "front": "That comment angered me.", "back": "そのコメントに腹が立ちました。", "romanized": "sono komento ni hara ga tachimashita" }] },
    { "id": "ja_me_037", "levels": [{ "front": "delight", "back": "喜ばせる / 楽しませる", "romanized": "yorokobaseru / tanoshimaseru" }, { "front": "The music delighted everyone.", "back": "音楽はみんなを喜ばせました。", "romanized": "ongaku wa min'na wo yorokobasemashita" }] },
    { "id": "ja_me_038", "levels": [{ "front": "smile", "back": "微笑む / 笑顔になる", "romanized": "hohoemu / egao ni naru" }, { "front": "She always smiles.", "back": "彼女はいつも微笑んでいます。", "romanized": "kanojo wa itsumo hohoende imasu" }] },
    { "id": "ja_me_039", "levels": [{ "front": "laugh", "back": "笑う", "romanized": "warau" }, { "front": "We laughed a lot.", "back": "私たちはたくさん笑いました。", "romanized": "watashitachi wa takusan waraimashita" }] },
    { "id": "ja_me_040", "levels": [{ "front": "cry / weep / mourn", "back": "泣く", "romanized": "naku" }, { "front": "The baby is crying.", "back": "赤ちゃんが泣いています。", "romanized": "akachan ga naite imasu" }] },
    { "id": "ja_me_041", "levels": [{ "front": "sigh", "back": "ため息をつく", "romanized": "tameiki wo tsuku" }, { "front": "She sighed with relief.", "back": "彼女は安堵してため息をつきました。", "romanized": "kanojo wa ando shite tameiki wo tsukimashita" }] },
    { "id": "ja_me_042", "levels": [{ "front": "frown", "back": "眉をひそめる / しかめっ面をする", "romanized": "mayu wo hisomeru / shikamettsurao wo suru" }, { "front": "He frowned when he heard the news.", "back": "彼はそのニュースを聞いて眉をひそめました。", "romanized": "kare wa sono nyūsu wo kiite mayu wo hisomemashita" }] },
    { "id": "ja_me_043", "levels": [{ "front": "scream / shout", "back": "叫ぶ / 怒鳴る", "romanized": "sakebu / donaru" }, { "front": "Don't shout, please.", "back": "叫ばないでください。", "romanized": "sakabanaide kudasai" }] },
    { "id": "ja_me_044", "levels": [{ "front": "relax", "back": "リラックスする / くつろぐ", "romanized": "rirakkusu suru / kutsurogu" }, { "front": "Relax, there's no rush.", "back": "リラックスして、急がなくていいです。", "romanized": "rirakkusu shite, isoganakute ii desu" }] },
    { "id": "ja_me_045", "levels": [{ "front": "angry", "back": "怒っている / 腹を立てた", "romanized": "okotte iru / hara wo tateta" }, { "front": "I'm angry with you.", "back": "あなたに怒っています。", "romanized": "anata ni okotte imasu" }] },
    { "id": "ja_me_046", "levels": [{ "front": "mad", "back": "激怒した / かんかんに怒った", "romanized": "gekido shita / kankan ni okotta" }, { "front": "Why are you so mad?", "back": "なぜそんなに怒っているのですか？", "romanized": "naze son'na ni okotte iru no desu ka" }] },
    { "id": "ja_me_047", "levels": [{ "front": "afraid / scared", "back": "怖い / 恐怖を感じた", "romanized": "kowai / kyōfu wo kanjita" }, { "front": "The child was scared.", "back": "子どもは怖がっていました。", "romanized": "kodomo wa kowagatte imashita" }] },
    { "id": "ja_me_048", "levels": [{ "front": "anxious", "back": "不安な / 心配している", "romanized": "fuan na / shinpai shite iru" }, { "front": "I'm anxious about the exam.", "back": "試験が不安です。", "romanized": "shiken ga fuan desu" }] },
    { "id": "ja_me_049", "levels": [{ "front": "nervous", "back": "緊張した / ナーバスな", "romanized": "kinchō shita / nābasu na" }, { "front": "I'm nervous today.", "back": "今日は緊張しています。", "romanized": "kyō wa kinchō shite imasu" }] },
    { "id": "ja_me_050", "levels": [{ "front": "excited", "back": "興奮した / ワクワクした", "romanized": "kōfun shita / wakuwaku shita" }, { "front": "I'm excited about the trip.", "back": "旅行がとても楽しみです。", "romanized": "ryokō ga totemo tanoshimi desu" }] },
    { "id": "ja_me_051", "levels": [{ "front": "joyful / cheerful", "back": "嬉しそうな / 明るい", "romanized": "ureshisō na / akarui" }, { "front": "She is always cheerful.", "back": "彼女はいつも明るいです。", "romanized": "kanojo wa itsumo akarui desu" }] },
    { "id": "ja_me_052", "levels": [{ "front": "proud", "back": "誇りに思う / 自慢の", "romanized": "hokori ni omou / jiman no" }, { "front": "I'm proud of you.", "back": "あなたのことを誇りに思います。", "romanized": "anata no koto wo hokori ni omoimasu" }] },
    { "id": "ja_me_053", "levels": [{ "front": "content / contented", "back": "満足した / 充実した", "romanized": "manzoku shita / jūjitsu shita" }, { "front": "I'm content with my life.", "back": "自分の人生に満足しています。", "romanized": "jibun no jinsei ni manzoku shite imasu" }] },
    { "id": "ja_me_054", "levels": [{ "front": "calm", "back": "穏やかな / 落ち着いた", "romanized": "odayaka na / ochitsuita" }, { "front": "Stay calm, everything is fine.", "back": "落ち着いてください、大丈夫です。", "romanized": "ochitsuite kudasai, daijōbu desu" }] },
    { "id": "ja_me_055", "levels": [{ "front": "stressed", "back": "ストレスを感じている / 追い詰められた", "romanized": "sutoresu wo kanjite iru / oitsumareta" }, { "front": "I'm very stressed this week.", "back": "今週はとてもストレスを感じています。", "romanized": "konshū wa totemo sutoresu wo kanjite imasu" }] },
    { "id": "ja_me_056", "levels": [{ "front": "overwhelmed", "back": "圧倒された / 手に負えない", "romanized": "attō sareta / te ni oenai" }, { "front": "I feel overwhelmed by the work.", "back": "仕事に圧倒されています。", "romanized": "shigoto ni attō sarete imasu" }] },
    { "id": "ja_me_057", "levels": [{ "front": "energetic", "back": "元気な / 活気のある", "romanized": "genki na / kakki no aru" }, { "front": "She is very energetic.", "back": "彼女はとても元気です。", "romanized": "kanojo wa totemo genki desu" }] },
    { "id": "ja_me_058", "levels": [{ "front": "tired", "back": "疲れた / 眠い", "romanized": "tsukareta / nemui" }, { "front": "I'm very tired today.", "back": "今日はとても疲れています。", "romanized": "kyō wa totemo tsukarete imasu" }] },
    { "id": "ja_me_059", "levels": [{ "front": "exhausted", "back": "くたくたに疲れた / 消耗した", "romanized": "kutakuta ni tsukareta / shōmō shita" }, { "front": "I'm exhausted after the run.", "back": "走った後でくたくたです。", "romanized": "hashitta ato de kutakuta desu" }] },
    { "id": "ja_me_060", "levels": [{ "front": "curious", "back": "好奇心旺盛な / 気になる", "romanized": "kōkishin ōsei na / ki ni naru" }, { "front": "I'm curious about that.", "back": "それがとても気になります。", "romanized": "sore ga totemo ki ni narimasu" }] }
  ]
