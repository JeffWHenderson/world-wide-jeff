    { "id": "es_fd_068", "levels": [{ "front": "boil", "back": "hervir", "grammarNote": "Hervir is an e→ie stem-changing verb: hiervo, hierves, hierve, hervimos, hervís, hierven. The stem changes in all forms except nosotros/vosotros. Other e→ie verbs: querer (quiero), empezar (empiezo), entender (entiendo)." }, { "front": "Boil the water first.", "back": "Hierve el agua primero." }] },
    { "id": "es_fd_069", "levels": [{ "front": "fry", "back": "freír" }, { "front": "Fry the onions in oil.", "back": "Fríe las cebollas en aceite." }] },
