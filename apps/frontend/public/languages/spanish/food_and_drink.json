    { "id": "es_fd_062", "levels": [{ "front": "hungry", "back": "hambre", "grammarNote": "Use 'tener' (to have) for hunger and thirst: 'tener hambre' = to be hungry, 'tener sed' = to be thirsty. Also: tener frío/calor (to be cold/hot), tener miedo (to be afraid), tener sueño (to be sleepy). These are physical states expressed with tener, not estar." }, { "front": "I'm hungry. Are you thirsty?", "back": "Tengo hambre. ¿Tienes sed?" }] },
    { "id": "es_fd_063", "levels": [{ "front": "thirsty", "back": "sed" }, { "front": "I'm thirsty.", "back": "Tengo sed." }] },
