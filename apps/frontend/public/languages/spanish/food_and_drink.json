    { "id": "es_fd_090", "levels": [{ "front": "hot", "back": "caliente", "grammarNote": "Use 'estar' for food and drink temperatures — they are temporary states. 'La sopa está caliente' (the soup is hot), 'El café está frío' (the coffee is cold). Compare with 'ser' for inherent qualities: 'El chile es picante' (chili is spicy — it's always that way)." }, { "front": "Be careful, the soup is hot.", "back": "Cuidado, la sopa está caliente." }] },
