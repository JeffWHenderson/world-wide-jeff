    { "id": "es_fd_079", "levels": [{ "front": "taste (to try)", "back": "probar", "grammarNote": "Probar is an o→ue stem-changing verb: pruebo, pruebas, prueba, probamos, probáis, prueban. The stem changes in all forms except nosotros/vosotros. Other o→ue verbs: poder (puedo), volver (vuelvo), dormir (duermo)." }, { "front": "Try the soup!", "back": "¡Prueba la sopa!" }] },
