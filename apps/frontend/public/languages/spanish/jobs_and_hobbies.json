    { "id": "es_jh_058", "levels": [{ "front": "To like / To enjoy", "back": "Gustar / Disfrutar", "grammarNote": "Gustar + infinitive = to like doing something. 'Me gusta leer' = I like reading. 'A ella le gusta cantar' = She likes singing. For third-person subjects, add 'a + person' for clarity: 'A mi padre le gusta pescar'. The verb gustar agrees with what is liked, not the person doing the liking." }, { "front": "I like reading. She likes singing.", "back": "Me gusta leer. A ella le gusta cantar.", "literal": "To-me pleases reading. To her to-her pleases singing." }] },
