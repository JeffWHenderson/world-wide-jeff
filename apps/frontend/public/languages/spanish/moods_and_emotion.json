{
  "id": "moods_and_emotion",
  "name": "Moods & Emotion",
  "language": "spanish",
  "stories": ["a_bad_day", "good_news", "friendship", "sean"],
  "pictureLessons": ["moodsAndEmotion", "moodsAndEmotion2"],
  "cards": [
    { "id": "es_me_001", "levels": [{ "front": "happy", "back": "feliz", "grammarNote": "Adverb form: felizmente (happily). Spanish adverbs are made by adding -mente to the feminine adjective. Feliz has no gender change: feliz + mente → felizmente. E.g., 'Ella sonrió felizmente.' (She smiled happily.)" }, { "front": "I'm very happy today.", "back": "Estoy muy feliz hoy." }] },
    { "id": "es_me_002", "levels": [{ "front": "sad", "back": "triste", "grammarNote": "Adverb form: tristemente (sadly). Triste has no gender change: triste + mente → tristemente. E.g., 'Habló tristemente.' (He spoke sadly.)" }, { "front": "Why are you sad?", "back": "¿Por qué estás triste?" }] },
    { "id": "es_me_003", "levels": [{ "front": "love", "back": "amor" }, { "front": "I feel a lot of love for my family.", "back": "Siento mucho amor por mi familia." }] },
    { "id": "es_me_004", "levels": [{ "front": "anger", "back": "ira" }, { "front": "I felt anger when they lied to me.", "back": "Sentí ira cuando me mintieron." }] },
    { "id": "es_me_005", "levels": [{ "front": "fear", "back": "miedo" }, { "front": "I'm afraid of the dark.", "back": "Tengo miedo de la oscuridad." }] },
    { "id": "es_me_006", "levels": [{ "front": "hope", "back": "esperanza" }, { "front": "I have hope for the future.", "back": "Tengo esperanza en el futuro." }] },
    { "id": "es_me_007", "levels": [{ "front": "stress", "back": "estrés" }, { "front": "I have a lot of stress at work.", "back": "Tengo mucho estrés en el trabajo." }] },
    { "id": "es_me_008", "levels": [{ "front": "mood", "back": "estado de ánimo" }, { "front": "I'm in a good mood today.", "back": "Hoy estoy de buen estado de ánimo." }] },
    { "id": "es_me_009", "levels": [{ "front": "feeling", "back": "sentimiento" }, { "front": "That feeling is normal.", "back": "Ese sentimiento es normal." }] },
    { "id": "es_me_010", "levels": [{ "front": "emotion / excitement", "back": "emoción" }, { "front": "I couldn't hide my emotion.", "back": "No pude ocultar mi emoción." }] },
    { "id": "es_me_011", "levels": [{ "front": "calm", "back": "calma" }, { "front": "Try to maintain your calm.", "back": "Intenta mantener la calma." }] },
    { "id": "es_me_012", "levels": [{ "front": "peace", "back": "paz" }, { "front": "I need peace and quiet.", "back": "Necesito paz y tranquilidad." }] },
    { "id": "es_me_013", "levels": [{ "front": "worry", "back": "preocupación" }, { "front": "Don't let worry stop you.", "back": "No dejes que la preocupación te detenga." }] },
    { "id": "es_me_014", "levels": [{ "front": "surprise", "back": "sorpresa" }, { "front": "What a surprise!", "back": "¡Qué sorpresa!" }] },
    { "id": "es_me_015", "levels": [{ "front": "passion", "back": "pasión" }, { "front": "She teaches with passion.", "back": "Ella enseña con pasión." }] },
    { "id": "es_me_016", "levels": [{ "front": "desire", "back": "deseo" }, { "front": "I have a strong desire to travel.", "back": "Tengo un gran deseo de viajar." }] },
    { "id": "es_me_017", "levels": [{ "front": "hate", "back": "odio" }, { "front": "Hate is a strong feeling.", "back": "El odio es un sentimiento fuerte." }] },
    { "id": "es_me_018", "levels": [{ "front": "pleasure", "back": "placer" }, { "front": "It's a pleasure to meet you.", "back": "Es un placer conocerte." }] },
    { "id": "es_me_019", "levels": [{ "front": "pain", "back": "dolor" }, { "front": "I feel pain in my leg.", "back": "Siento dolor en la pierna." }] },
    { "id": "es_me_020", "levels": [{ "front": "energy", "back": "energía" }, { "front": "I have a lot of energy today.", "back": "Hoy tengo mucha energía." }] },
    { "id": "es_me_021", "levels": [{ "front": "relief", "back": "alivio" }, { "front": "What a relief!", "back": "¡Qué alivio!" }] },
    { "id": "es_me_022", "levels": [{ "front": "comfort", "back": "consuelo" }, { "front": "Her words were a comfort.", "back": "Sus palabras fueron un consuelo." }] },
    { "id": "es_me_023", "levels": [{ "front": "feel (to feel)", "back": "sentir", "grammarNote": "Sentir = to feel/perceive something. Sentirse (reflexive) = to feel a certain way. 'Me siento bien' (I feel good) vs 'Siento dolor' (I feel pain)." }, { "front": "I feel good today.", "back": "Me siento bien hoy." }] },
    { "id": "es_me_024", "levels": [{ "front": "love (to love)", "back": "amar" }, { "front": "I love you very much.", "back": "Te amo mucho." }] },
    { "id": "es_me_025", "levels": [{ "front": "hate (to hate)", "back": "odiar" }, { "front": "I hate waiting.", "back": "Odio esperar." }] },
    { "id": "es_me_026", "levels": [{ "front": "like (to like)", "back": "gustar" }, { "front": "I like music.", "back": "Me gusta la música." }] },
    { "id": "es_me_027", "levels": [{ "front": "enjoy", "back": "disfrutar" }, { "front": "I enjoy the weekend.", "back": "Disfruto el fin de semana." }] },
    { "id": "es_me_028", "levels": [{ "front": "fear / dread (to fear)", "back": "temer" }, { "front": "I fear the worst.", "back": "Temo lo peor." }] },
    { "id": "es_me_029", "levels": [{ "front": "hope (to hope)", "back": "esperar" }, { "front": "I hope everything goes well.", "back": "Espero que todo salga bien." }] },
    { "id": "es_me_030", "levels": [{ "front": "worry (to worry)", "back": "preocuparse" }, { "front": "Don't worry about it.", "back": "No te preocupes por eso." }] },
    { "id": "es_me_031", "levels": [{ "front": "calm / soothe (to calm)", "back": "calmar" }, { "front": "Calm down, please.", "back": "Cálmate, por favor." }] },
    { "id": "es_me_032", "levels": [{ "front": "comfort (to comfort)", "back": "consolar" }, { "front": "She comforted her friend.", "back": "Ella consoló a su amiga." }] },
    { "id": "es_me_033", "levels": [{ "front": "excite / thrill", "back": "emocionar" }, { "front": "The trip excites me.", "back": "El viaje me emociona." }] },
    { "id": "es_me_034", "levels": [{ "front": "annoy", "back": "molestar" }, { "front": "That noise annoys me.", "back": "Ese ruido me molesta." }] },
    { "id": "es_me_035", "levels": [{ "front": "irritate", "back": "irritar" }, { "front": "Waiting irritates me.", "back": "Esperar me irrita." }] },
    { "id": "es_me_036", "levels": [{ "front": "anger (to anger)", "back": "enojar" }, { "front": "That comment angered me.", "back": "Ese comentario me enojó." }] },
    { "id": "es_me_037", "levels": [{ "front": "delight", "back": "deleitar" }, { "front": "The music delighted everyone.", "back": "La música deleitó a todos." }] },
    { "id": "es_me_038", "levels": [{ "front": "smile", "back": "sonreír" }, { "front": "She always smiles.", "back": "Ella siempre sonríe." }] },
    { "id": "es_me_039", "levels": [{ "front": "laugh", "back": "reír" }, { "front": "We laughed a lot.", "back": "Nos reímos mucho." }] },
    { "id": "es_me_040", "levels": [{ "front": "cry / weep / mourn", "back": "llorar" }, { "front": "The baby is crying.", "back": "El bebé está llorando." }] },
    { "id": "es_me_041", "levels": [{ "front": "sigh", "back": "suspirar" }, { "front": "She sighed with relief.", "back": "Ella suspiró de alivio." }] },
    { "id": "es_me_042", "levels": [{ "front": "frown", "back": "fruncir el ceño" }, { "front": "He frowned when he heard the news.", "back": "Frunció el ceño cuando escuchó la noticia." }] },
    { "id": "es_me_043", "levels": [{ "front": "scream / shout", "back": "gritar" }, { "front": "Don't shout, please.", "back": "No grites, por favor." }] },
    { "id": "es_me_044", "levels": [{ "front": "relax", "back": "relajarse" }, { "front": "Relax, there's no rush.", "back": "Relájate, no hay prisa." }] },
    { "id": "es_me_045", "levels": [{ "front": "angry", "back": "enojado", "grammarNote": "Adverb form: enojadamente (angrily). Use the feminine: enojada + mente → enojadamente. E.g., 'Respondió enojadamente.' (She answered angrily.)" }, { "front": "I'm angry with you.", "back": "Estoy enojado contigo." }] },
    { "id": "es_me_046", "levels": [{ "front": "mad", "back": "enfadado" }, { "front": "Why are you so mad?", "back": "¿Por qué estás tan enfadado?" }] },
    { "id": "es_me_047", "levels": [{ "front": "afraid / scared", "back": "asustado" }, { "front": "The child was scared.", "back": "El niño estaba asustado." }] },
    { "id": "es_me_048", "levels": [{ "front": "anxious", "back": "ansioso", "grammarNote": "Adverb form: ansiosamente (anxiously). Feminine: ansiosa + mente → ansiosamente. E.g., 'Esperaba ansiosamente.' (She was waiting anxiously.)" }, { "front": "I'm anxious about the exam.", "back": "Estoy ansioso por el examen." }] },
    { "id": "es_me_049", "levels": [{ "front": "nervous", "back": "nervioso", "grammarNote": "Adverb form: nerviosamente (nervously). Feminine: nerviosa + mente → nerviosamente. E.g., 'Habló nerviosamente.' (He spoke nervously.)" }, { "front": "I'm nervous today.", "back": "Estoy nervioso hoy." }] },
    { "id": "es_me_050", "levels": [{ "front": "excited", "back": "emocionado", "grammarNote": "Adverb form: emocionadamente (excitedly). Feminine: emocionada + mente → emocionadamente. E.g., 'Gritó emocionadamente.' (She shouted excitedly.)" }, { "front": "I'm excited about the trip.", "back": "Estoy emocionado por el viaje." }] },
    { "id": "es_me_051", "levels": [{ "front": "joyful / cheerful", "back": "alegre" }, { "front": "She is always cheerful.", "back": "Ella siempre está alegre." }] },
    { "id": "es_me_052", "levels": [{ "front": "proud", "back": "orgulloso", "grammarNote": "Adverb form: orgullosamente (proudly). Feminine: orgullosa + mente → orgullosamente. E.g., 'Sonrió orgullosamente.' (She smiled proudly.)" }, { "front": "I'm proud of you.", "back": "Estoy orgulloso de ti." }] },
    { "id": "es_me_053", "levels": [{ "front": "content / contented", "back": "contento" }, { "front": "I'm content with my life.", "back": "Estoy contento con mi vida." }] },
    { "id": "es_me_054", "levels": [{ "front": "calm", "back": "tranquilo", "grammarNote": "Adverb form: tranquilamente (calmly). Feminine: tranquila + mente → tranquilamente. E.g., 'Respondió tranquilamente.' (She answered calmly.)" }, { "front": "Stay calm, everything is fine.", "back": "Mantente tranquilo, todo está bien." }] },
    { "id": "es_me_055", "levels": [{ "front": "stressed", "back": "estresado" }, { "front": "I'm very stressed this week.", "back": "Estoy muy estresado esta semana." }] },
    { "id": "es_me_056", "levels": [{ "front": "overwhelmed", "back": "abrumado" }, { "front": "I feel overwhelmed by the work.", "back": "Me siento abrumado por el trabajo." }] },
    { "id": "es_me_057", "levels": [{ "front": "energetic", "back": "energético" }, { "front": "She is very energetic.", "back": "Ella es muy energética." }] },
    { "id": "es_me_058", "levels": [{ "front": "tired", "back": "cansado", "grammarNote": "Adverb form: cansadamente (tiredly / wearily). Feminine: cansada + mente → cansadamente. E.g., 'Arrastró los pies cansadamente.' (He dragged his feet wearily.)" }, { "front": "I'm very tired today.", "back": "Estoy muy cansado hoy." }] },
    { "id": "es_me_059", "levels": [{ "front": "exhausted", "back": "agotado" }, { "front": "I'm exhausted after the run.", "back": "Estoy agotado después de correr." }] },
    { "id": "es_me_060", "levels": [{ "front": "curious", "back": "curioso" }, { "front": "I'm curious about that.", "back": "Estoy curioso por eso." }] }
  ]
}
