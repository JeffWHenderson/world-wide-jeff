{
  "id": "human_body",
  "name": "Human Body",
  "language": "spanish",
  "stories": ["at_the_doctor", "after_exercise", "getting_ready"],
  "pictureLessons": ["humanBody"],
  "cards": [
    { "id": "es_hb_001", "levels": [{ "front": "head", "back": "la cabeza", "grammarNote": "Doler (to hurt/ache) works like gustar — the body part is the grammatical subject. 'Me duele la cabeza' = my head hurts (literally: the head pains me). For plural body parts: 'Me duelen los pies' = my feet hurt. The indirect object pronoun (me/te/le) indicates who is hurting." }, { "front": "My head hurts.", "back": "Me duele la cabeza.", "literal": "To-me hurts the head." }] },
    { "id": "es_hb_002", "levels": [{ "front": "hair", "back": "el pelo / el cabello" }, { "front": "She has long hair.", "back": "Ella tiene el pelo largo.", "literal": "[She] has the hair long." }] },
    { "id": "es_hb_003", "levels": [{ "front": "face", "back": "la cara / el rostro" }, { "front": "Wash your face.", "back": "Lávate la cara.", "literal": "Wash-yourself the face [command]." }] },
    { "id": "es_hb_004", "levels": [{ "front": "eye", "back": "el ojo" }, { "front": "He has blue eyes.", "back": "Él tiene los ojos azules.", "literal": "[He] has the eyes blue." }] },
    { "id": "es_hb_005", "levels": [{ "front": "ear", "back": "la oreja (outer) / el oído (inner)" }, { "front": "My ear hurts.", "back": "Me duele la oreja.", "literal": "To-me hurts the ear." }] },
    { "id": "es_hb_006", "levels": [{ "front": "nose", "back": "la nariz" }, { "front": "My nose is cold.", "back": "Tengo la nariz fría.", "literal": "[I] have the nose cold." }] },
    { "id": "es_hb_007", "levels": [{ "front": "mouth", "back": "la boca" }, { "front": "Open your mouth.", "back": "Abre la boca.", "literal": "Open the mouth [command]." }] },
    { "id": "es_hb_008", "levels": [{ "front": "lip", "back": "el labio" }, { "front": "She has red lips.", "back": "Tiene los labios rojos.", "literal": "[She] has the lips red." }] },
    { "id": "es_hb_009", "levels": [{ "front": "tooth (teeth)", "back": "el diente (los dientes)" }, { "front": "I have a toothache.", "back": "Me duele un diente.", "literal": "To-me hurts a tooth." }] },
    { "id": "es_hb_010", "levels": [{ "front": "tongue", "back": "la lengua" }, { "front": "Stick out your tongue.", "back": "Saca la lengua.", "literal": "Take-out the tongue [command]." }] },
    { "id": "es_hb_011", "levels": [{ "front": "neck", "back": "el cuello" }, { "front": "My neck is stiff.", "back": "Tengo el cuello rígido.", "literal": "[I] have the neck stiff." }] },
    { "id": "es_hb_012", "levels": [{ "front": "arm", "back": "el brazo" }, { "front": "I broke my arm.", "back": "Me rompí el brazo.", "literal": "[I] myself broke the arm." }] },
    { "id": "es_hb_013", "levels": [{ "front": "hand", "back": "la mano", "grammarNote": "With reflexive verbs and body parts, Spanish uses the definite article (la, el, los, las) instead of a possessive. 'Lávate las manos' = Wash your hands (not 'lava tus manos'). 'Me rompí el brazo' = I broke my arm. The reflexive pronoun (me/te/se) makes clear whose body part it is." }, { "front": "Wash your hands.", "back": "Lávate las manos.", "literal": "Wash-yourself the hands [command]." }] },
    { "id": "es_hb_014", "levels": [{ "front": "finger", "back": "el dedo (de la mano)" }, { "front": "He cut his finger.", "back": "Se cortó el dedo.", "literal": "[He] himself cut the finger." }] },
    { "id": "es_hb_015", "levels": [{ "front": "chest", "back": "el pecho" }, { "front": "He has chest pain.", "back": "Él tiene dolor en el pecho.", "literal": "[He] has pain in the chest." }] },
    { "id": "es_hb_016", "levels": [{ "front": "back", "back": "la espalda" }, { "front": "My back hurts.", "back": "Me duele la espalda.", "literal": "To-me hurts the back." }] },
    { "id": "es_hb_017", "levels": [{ "front": "heart", "back": "el corazón" }, { "front": "My heart is beating fast.", "back": "Mi corazón late rápido.", "literal": "My heart beats fast." }] },
    { "id": "es_hb_018", "levels": [{ "front": "stomach", "back": "el estómago" }, { "front": "My stomach hurts.", "back": "Me duele el estómago.", "literal": "To-me hurts the stomach." }] },
    { "id": "es_hb_019", "levels": [{ "front": "muscle", "back": "el músculo" }, { "front": "I pulled a muscle.", "back": "Me jalé un músculo.", "literal": "[I] myself pulled a muscle." }] },
    { "id": "es_hb_020", "levels": [{ "front": "waist", "back": "la cintura" }, { "front": "She has a slim waist.", "back": "Ella tiene la cintura delgada.", "literal": "[She] has the waist slim." }] },
    { "id": "es_hb_021", "levels": [{ "front": "skin", "back": "la piel" }, { "front": "Her skin is soft.", "back": "Ella tiene la piel suave.", "literal": "[She] has the skin soft." }] },
    { "id": "es_hb_022", "levels": [{ "front": "blood", "back": "la sangre" }, { "front": "He donated blood.", "back": "Él donó sangre.", "literal": "[He] donated blood." }] },
    { "id": "es_hb_023", "levels": [{ "front": "brain", "back": "el cerebro" }, { "front": "The brain is complex.", "back": "El cerebro es complejo.", "literal": "The brain is complex." }] },
    { "id": "es_hb_024", "levels": [{ "front": "skull", "back": "el cráneo" }, { "front": "The skull protects the brain.", "back": "El cráneo protege el cerebro.", "literal": "The skull protects the brain." }] },
    { "id": "es_hb_025", "levels": [{ "front": "breast", "back": "el seno / el pecho" }, { "front": "She felt pain in her chest.", "back": "Ella sintió dolor en el pecho.", "literal": "[She] felt pain in the chest." }] },
    { "id": "es_hb_026", "levels": [{ "front": "leg", "back": "la pierna" }, { "front": "My leg is tired.", "back": "Tengo la pierna cansada.", "literal": "[I] have the leg tired." }] },
    { "id": "es_hb_027", "levels": [{ "front": "foot (feet)", "back": "el pie (los pies)" }, { "front": "My feet hurt.", "back": "Me duelen los pies.", "literal": "To-me hurt the feet." }] },
    { "id": "es_hb_028", "levels": [{ "front": "toe", "back": "el dedo (del pie)" }, { "front": "He stubbed his toe.", "back": "Se golpeó el dedo del pie.", "literal": "[He] himself hit the toe of the foot." }] },
    { "id": "es_hb_029", "levels": [{ "front": "joint", "back": "la articulación" }, { "front": "My joints are stiff.", "back": "Tengo las articulaciones rígidas.", "literal": "[I] have the joints stiff." }] },
    { "id": "es_hb_030", "levels": [{ "front": "breath", "back": "el aliento / la respiración" }, { "front": "Hold your breath.", "back": "Aguanta la respiración.", "literal": "Hold the breath [command]." }] },
    { "id": "es_hb_031", "levels": [{ "front": "see", "back": "ver" }, { "front": "I can see clearly.", "back": "Puedo ver con claridad.", "literal": "[I] can see with clarity." }] },
    { "id": "es_hb_032", "levels": [{ "front": "hear", "back": "oír / escuchar" }, { "front": "I can't hear you.", "back": "No te escucho.", "literal": "No [I] you listen-to." }] },
    { "id": "es_hb_033", "levels": [{ "front": "smell", "back": "oler" }, { "front": "I can smell the flowers.", "back": "Puedo oler las flores.", "literal": "[I] can smell the flowers." }] },
    { "id": "es_hb_034", "levels": [{ "front": "taste", "back": "saborear / probar" }, { "front": "Taste this soup.", "back": "Prueba esta sopa.", "literal": "Taste this soup [command]." }] },
    { "id": "es_hb_035", "levels": [{ "front": "touch", "back": "tocar" }, { "front": "Don't touch that!", "back": "¡No toques eso!", "literal": "No touch that [command]!" }] },
    { "id": "es_hb_036", "levels": [{ "front": "breathe", "back": "respirar" }, { "front": "Breathe slowly.", "back": "Respira despacio.", "literal": "Breathe slowly [command]." }] },
    { "id": "es_hb_037", "levels": [{ "front": "bend", "back": "doblar" }, { "front": "Bend your knees.", "back": "Dobla las rodillas.", "literal": "Bend the knees [command]." }] },
    { "id": "es_hb_038", "levels": [{ "front": "stretch", "back": "estirar" }, { "front": "Stretch your arms.", "back": "Estira los brazos.", "literal": "Stretch the arms [command]." }] },
    { "id": "es_hb_039", "levels": [{ "front": "flex", "back": "flexionar" }, { "front": "Flex your muscles.", "back": "Flexiona los músculos.", "literal": "Flex the muscles [command]." }] },
    { "id": "es_hb_040", "levels": [{ "front": "blink", "back": "parpadear" }, { "front": "Don't blink.", "back": "No parpadees.", "literal": "No blink [command]." }] },
    { "id": "es_hb_041", "levels": [{ "front": "sweat", "back": "sudar" }, { "front": "I sweat when I run.", "back": "Sudo cuando corro.", "literal": "[I] sweat when [I] run." }] },
    { "id": "es_hb_042", "levels": [{ "front": "bleed", "back": "sangrar" }, { "front": "The wound is bleeding.", "back": "La herida está sangrando.", "literal": "The wound is bleeding." }] },
    { "id": "es_hb_043", "levels": [{ "front": "feel", "back": "sentir" }, { "front": "How do you feel?", "back": "¿Cómo te sientes?", "literal": "How yourself feel [you]?" }] },
    { "id": "es_hb_044", "levels": [{ "front": "think", "back": "pensar", "grammarNote": "Pensar is an e→ie stem-changing verb: pienso, piensas, piensa, pensamos, pensáis, piensan. The stem changes in all forms except nosotros/vosotros. Other common e→ie verbs: querer (quiero), entender (entiendo), empezar (empiezo), perder (pierdo)." }, { "front": "What are you thinking about?", "back": "¿En qué piensas?", "literal": "In what think [you]?" }] },
    { "id": "es_hb_045", "levels": [{ "front": "move", "back": "mover / moverse" }, { "front": "I can't move my arm.", "back": "No puedo mover el brazo.", "literal": "No [I] can move the arm." }] },
    { "id": "es_hb_046", "levels": [{ "front": "bony", "back": "huesudo" }, { "front": "His hands are bony.", "back": "Tiene las manos huesudas.", "literal": "[He] has the hands bony." }] },
    { "id": "es_hb_047", "levels": [{ "front": "hairy", "back": "peludo" }, { "front": "He has hairy arms.", "back": "Él tiene los brazos peludos.", "literal": "[He] has the arms hairy." }] },
    { "id": "es_hb_048", "levels": [{ "front": "soft", "back": "suave / blando" }, { "front": "The tissue is soft.", "back": "El tejido es suave.", "literal": "The tissue is soft." }] },
    { "id": "es_hb_049", "levels": [{ "front": "sore", "back": "dolorido" }, { "front": "My muscles are sore.", "back": "Tengo los músculos doloridos.", "literal": "[I] have the muscles sore." }] },
    { "id": "es_hb_050", "levels": [{ "front": "left", "back": "izquierdo" }, { "front": "I hurt my left knee.", "back": "Me duele la rodilla izquierda.", "literal": "To-me hurts the knee left." }] },
    { "id": "es_hb_051", "levels": [{ "front": "right", "back": "derecho" }, { "front": "I broke my right arm.", "back": "Me rompí el brazo derecho.", "literal": "[I] myself broke the arm right." }] },
    { "id": "es_hb_052", "levels": [{ "front": "upper", "back": "superior" }, { "front": "The upper body is strong.", "back": "La parte superior del cuerpo es fuerte.", "literal": "The part upper of-the body is strong." }] },
    { "id": "es_hb_053", "levels": [{ "front": "lower", "back": "inferior" }, { "front": "He has lower back pain.", "back": "Él tiene dolor en la parte inferior de la espalda.", "literal": "[He] has pain in the part lower of the back." }] },
    { "id": "es_hb_054", "levels": [{ "front": "body", "back": "el cuerpo" }, { "front": "The human body is amazing.", "back": "El cuerpo humano es asombroso.", "literal": "The body human is amazing." }] },
    { "id": "es_hb_055", "levels": [{ "front": "human (adjective)", "back": "humano" }, { "front": "It's part of human biology.", "back": "Es parte de la biología humana.", "literal": "[It] is part of the biology human." }] }
  ]
}
