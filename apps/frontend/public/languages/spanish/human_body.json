{
  "id": "human_body",
  "name": "Human Body",
  "language": "spanish",
  "stories": ["at_the_doctor", "after_exercise", "getting_ready"],
  "pictureLessons": ["humanBody"],
  "cards": [
    { "id": "es_hb_001", "levels": [{ "front": "head", "back": "la cabeza", "grammarNote": "Doler (to hurt/ache) works like gustar — the body part is the grammatical subject. 'Me duele la cabeza' = my head hurts (literally: the head pains me). For plural body parts: 'Me duelen los pies' = my feet hurt. The indirect object pronoun (me/te/le) indicates who is hurting." }, { "front": "My head hurts.", "back": "Me duele la cabeza." }] },
    { "id": "es_hb_002", "levels": [{ "front": "hair", "back": "el pelo / el cabello" }, { "front": "She has long hair.", "back": "Ella tiene el pelo largo." }] },
    { "id": "es_hb_003", "levels": [{ "front": "face", "back": "la cara / el rostro" }, { "front": "Wash your face.", "back": "Lávate la cara." }] },
    { "id": "es_hb_004", "levels": [{ "front": "eye", "back": "el ojo" }, { "front": "He has blue eyes.", "back": "Él tiene los ojos azules." }] },
    { "id": "es_hb_005", "levels": [{ "front": "ear", "back": "la oreja (outer) / el oído (inner)" }, { "front": "My ear hurts.", "back": "Me duele la oreja." }] },
    { "id": "es_hb_006", "levels": [{ "front": "nose", "back": "la nariz" }, { "front": "My nose is cold.", "back": "Tengo la nariz fría." }] },
    { "id": "es_hb_007", "levels": [{ "front": "mouth", "back": "la boca" }, { "front": "Open your mouth.", "back": "Abre la boca." }] },
    { "id": "es_hb_008", "levels": [{ "front": "lip", "back": "el labio" }, { "front": "She has red lips.", "back": "Tiene los labios rojos." }] },
    { "id": "es_hb_009", "levels": [{ "front": "tooth (teeth)", "back": "el diente (los dientes)" }, { "front": "I have a toothache.", "back": "Me duele un diente." }] },
    { "id": "es_hb_010", "levels": [{ "front": "tongue", "back": "la lengua" }, { "front": "Stick out your tongue.", "back": "Saca la lengua." }] },
    { "id": "es_hb_011", "levels": [{ "front": "neck", "back": "el cuello" }, { "front": "My neck is stiff.", "back": "Tengo el cuello rígido." }] },
    { "id": "es_hb_012", "levels": [{ "front": "arm", "back": "el brazo" }, { "front": "I broke my arm.", "back": "Me rompí el brazo." }] },
    { "id": "es_hb_013", "levels": [{ "front": "hand", "back": "la mano", "grammarNote": "With reflexive verbs and body parts, Spanish uses the definite article (la, el, los, las) instead of a possessive. 'Lávate las manos' = Wash your hands (not 'lava tus manos'). 'Me rompí el brazo' = I broke my arm. The reflexive pronoun (me/te/se) makes clear whose body part it is." }, { "front": "Wash your hands.", "back": "Lávate las manos." }] },
    { "id": "es_hb_014", "levels": [{ "front": "finger", "back": "el dedo (de la mano)" }, { "front": "He cut his finger.", "back": "Se cortó el dedo." }] },
    { "id": "es_hb_015", "levels": [{ "front": "chest", "back": "el pecho" }, { "front": "He has chest pain.", "back": "Él tiene dolor en el pecho." }] },
    { "id": "es_hb_016", "levels": [{ "front": "back", "back": "la espalda" }, { "front": "My back hurts.", "back": "Me duele la espalda." }] },
    { "id": "es_hb_017", "levels": [{ "front": "heart", "back": "el corazón" }, { "front": "My heart is beating fast.", "back": "Mi corazón late rápido." }] },
    { "id": "es_hb_018", "levels": [{ "front": "stomach", "back": "el estómago" }, { "front": "My stomach hurts.", "back": "Me duele el estómago." }] },
    { "id": "es_hb_019", "levels": [{ "front": "muscle", "back": "el músculo" }, { "front": "I pulled a muscle.", "back": "Me jalé un músculo." }] },
    { "id": "es_hb_020", "levels": [{ "front": "waist", "back": "la cintura" }, { "front": "She has a slim waist.", "back": "Ella tiene la cintura delgada." }] },
    { "id": "es_hb_021", "levels": [{ "front": "skin", "back": "la piel" }, { "front": "Her skin is soft.", "back": "Ella tiene la piel suave." }] },
    { "id": "es_hb_022", "levels": [{ "front": "blood", "back": "la sangre" }, { "front": "He donated blood.", "back": "Él donó sangre." }] },
    { "id": "es_hb_023", "levels": [{ "front": "brain", "back": "el cerebro" }, { "front": "The brain is complex.", "back": "El cerebro es complejo." }] },
    { "id": "es_hb_024", "levels": [{ "front": "skull", "back": "el cráneo" }, { "front": "The skull protects the brain.", "back": "El cráneo protege el cerebro." }] },
    { "id": "es_hb_025", "levels": [{ "front": "breast", "back": "el seno / el pecho" }, { "front": "She felt pain in her chest.", "back": "Ella sintió dolor en el pecho." }] },
    { "id": "es_hb_026", "levels": [{ "front": "leg", "back": "la pierna" }, { "front": "My leg is tired.", "back": "Tengo la pierna cansada." }] },
    { "id": "es_hb_027", "levels": [{ "front": "foot (feet)", "back": "el pie (los pies)" }, { "front": "My feet hurt.", "back": "Me duelen los pies." }] },
    { "id": "es_hb_028", "levels": [{ "front": "toe", "back": "el dedo (del pie)" }, { "front": "He stubbed his toe.", "back": "Se golpeó el dedo del pie." }] },
    { "id": "es_hb_029", "levels": [{ "front": "joint", "back": "la articulación" }, { "front": "My joints are stiff.", "back": "Tengo las articulaciones rígidas." }] },
    { "id": "es_hb_030", "levels": [{ "front": "breath", "back": "el aliento / la respiración" }, { "front": "Hold your breath.", "back": "Aguanta la respiración." }] },
    { "id": "es_hb_031", "levels": [{ "front": "see", "back": "ver" }, { "front": "I can see clearly.", "back": "Puedo ver con claridad." }] },
    { "id": "es_hb_032", "levels": [{ "front": "hear", "back": "oír / escuchar" }, { "front": "I can't hear you.", "back": "No te escucho." }] },
    { "id": "es_hb_033", "levels": [{ "front": "smell", "back": "oler" }, { "front": "I can smell the flowers.", "back": "Puedo oler las flores." }] },
    { "id": "es_hb_034", "levels": [{ "front": "taste", "back": "saborear / probar" }, { "front": "Taste this soup.", "back": "Prueba esta sopa." }] },
    { "id": "es_hb_035", "levels": [{ "front": "touch", "back": "tocar" }, { "front": "Don't touch that!", "back": "¡No toques eso!" }] },
    { "id": "es_hb_036", "levels": [{ "front": "breathe", "back": "respirar" }, { "front": "Breathe slowly.", "back": "Respira despacio." }] },
    { "id": "es_hb_037", "levels": [{ "front": "bend", "back": "doblar" }, { "front": "Bend your knees.", "back": "Dobla las rodillas." }] },
    { "id": "es_hb_038", "levels": [{ "front": "stretch", "back": "estirar" }, { "front": "Stretch your arms.", "back": "Estira los brazos." }] },
    { "id": "es_hb_039", "levels": [{ "front": "flex", "back": "flexionar" }, { "front": "Flex your muscles.", "back": "Flexiona los músculos." }] },
    { "id": "es_hb_040", "levels": [{ "front": "blink", "back": "parpadear" }, { "front": "Don't blink.", "back": "No parpadees." }] },
    { "id": "es_hb_041", "levels": [{ "front": "sweat", "back": "sudar" }, { "front": "I sweat when I run.", "back": "Sudo cuando corro." }] },
    { "id": "es_hb_042", "levels": [{ "front": "bleed", "back": "sangrar" }, { "front": "The wound is bleeding.", "back": "La herida está sangrando." }] },
    { "id": "es_hb_043", "levels": [{ "front": "feel", "back": "sentir" }, { "front": "How do you feel?", "back": "¿Cómo te sientes?" }] },
    { "id": "es_hb_044", "levels": [{ "front": "think", "back": "pensar", "grammarNote": "Pensar is an e→ie stem-changing verb: pienso, piensas, piensa, pensamos, pensáis, piensan. The stem changes in all forms except nosotros/vosotros. Other common e→ie verbs: querer (quiero), entender (entiendo), empezar (empiezo), perder (pierdo)." }, { "front": "What are you thinking about?", "back": "¿En qué piensas?" }] },
    { "id": "es_hb_045", "levels": [{ "front": "move", "back": "mover / moverse" }, { "front": "I can't move my arm.", "back": "No puedo mover el brazo." }] },
    { "id": "es_hb_046", "levels": [{ "front": "bony", "back": "huesudo" }, { "front": "His hands are bony.", "back": "Tiene las manos huesudas." }] },
    { "id": "es_hb_047", "levels": [{ "front": "hairy", "back": "peludo" }, { "front": "He has hairy arms.", "back": "Él tiene los brazos peludos." }] },
    { "id": "es_hb_048", "levels": [{ "front": "soft", "back": "suave / blando" }, { "front": "The tissue is soft.", "back": "El tejido es suave." }] },
    { "id": "es_hb_049", "levels": [{ "front": "sore", "back": "dolorido" }, { "front": "My muscles are sore.", "back": "Tengo los músculos doloridos." }] },
    { "id": "es_hb_050", "levels": [{ "front": "left", "back": "izquierdo" }, { "front": "I hurt my left knee.", "back": "Me duele la rodilla izquierda." }] },
    { "id": "es_hb_051", "levels": [{ "front": "right", "back": "derecho" }, { "front": "I broke my right arm.", "back": "Me rompí el brazo derecho." }] },
    { "id": "es_hb_052", "levels": [{ "front": "upper", "back": "superior" }, { "front": "The upper body is strong.", "back": "La parte superior del cuerpo es fuerte." }] },
    { "id": "es_hb_053", "levels": [{ "front": "lower", "back": "inferior" }, { "front": "He has lower back pain.", "back": "Él tiene dolor en la parte inferior de la espalda." }] },
    { "id": "es_hb_054", "levels": [{ "front": "body", "back": "el cuerpo" }, { "front": "The human body is amazing.", "back": "El cuerpo humano es asombroso." }] },
    { "id": "es_hb_055", "levels": [{ "front": "human (adjective)", "back": "humano" }, { "front": "It's part of human biology.", "back": "Es parte de la biología humana." }] }
  ]
}
