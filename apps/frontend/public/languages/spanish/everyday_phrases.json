{
  "id": "everyday_phrases",
  "name": "Everyday Phrases",
  "language": "spanish",
  "stories": ["morning_routine", "meeting_a_friend", "making_plans", "meet_jeff", "meet_seth", "bad_bunny"],
  "pictureLessons": ["everydayPhrases01"],
  "cards": [
    { "id": "es_ep_001", "levels": [{ "front": "Hello", "back": "hola" }, { "front": "Hello! How are you?", "back": "¡Hola! ¿Cómo estás?", "literal": "Hello! How are [you]?" }] },
    { "id": "es_ep_002", "levels": [{ "front": "Please", "back": "por favor" }, { "front": "A coffee, please.", "back": "Un café, por favor.", "literal": "A coffee, please." }] },
    { "id": "es_ep_003", "levels": [{ "front": "Thank you", "back": "gracias" }, { "front": "Thank you very much.", "back": "Muchas gracias.", "literal": "Many thanks." }] },
    { "id": "es_ep_004", "levels": [{ "front": "I want", "back": "quiero", "grammarNote": "querer stem-changes e→ie: yo quiero, tú quieres, él quiere." }, { "front": "I want a coffee.", "back": "Quiero un café.", "literal": "[I] want a coffee." }] },
    { "id": "es_ep_005", "levels": [{ "front": "I need", "back": "necesito" }, { "front": "I need help.", "back": "Necesito ayuda.", "literal": "[I] need help." }] },
    { "id": "es_ep_006", "levels": [{ "front": "My name is", "back": "me llamo", "grammarNote": "Me llamo literally means 'I call myself' — it uses the reflexive verb llamarse. More natural in conversation than 'mi nombre es'." }, { "front": "My name is Ana.", "back": "Me llamo Ana.", "literal": "[I] myself-call Ana." }] },
    { "id": "es_ep_007", "levels": [{ "front": "I", "back": "yo", "grammarNote": "Subject pronouns are often dropped in Spanish because verb endings show who the subject is. 'Soy estudiante' and 'Yo soy estudiante' are both correct — use yo for emphasis." }, { "front": "I am a student.", "back": "Yo soy estudiante.", "literal": "I am student." }] },
    { "id": "es_ep_008", "levels": [{ "front": "You", "back": "tú", "grammarNote": "Spanish has two 'you': tú (informal, one person) and usted (formal). With friends and family use tú. With strangers, elders, or in formal settings use usted, which takes the same verb form as él/ella." }, { "front": "Do you speak Spanish?", "back": "¿Tú hablas español?", "literal": "You speak Spanish?" }] },
    { "id": "es_ep_009", "levels": [{ "front": "He", "back": "él" }, { "front": "He is my friend.", "back": "Él es mi amigo.", "literal": "He is my friend." }] },
    { "id": "es_ep_010", "levels": [{ "front": "She", "back": "ella" }, { "front": "She works here.", "back": "Ella trabaja aquí.", "literal": "She works here." }] },
    { "id": "es_ep_011", "levels": [{ "front": "It", "back": "ello / lo", "grammarNote": "Spanish usually drops 'it' entirely — verb endings and context carry the meaning. 'Es bueno' (it is good), 'Está aquí' (it is here). ello/lo exist but are rarely used in speech." }, { "front": "It's over there.", "back": "Está allá.", "literal": "[It] is there." }] },
    { "id": "es_ep_012", "levels": [{ "front": "We", "back": "nosotros" }, { "front": "We live here.", "back": "Nosotros vivimos aquí.", "literal": "We live here." }] },
    { "id": "es_ep_013", "levels": [{ "front": "They", "back": "ellos / ellas" }, { "front": "They eat together.", "back": "Ellos comen juntos.", "literal": "They eat together." }] },
    { "id": "es_ep_014", "levels": [{ "front": "This", "back": "este / esta", "grammarNote": "este (masc.) / esta (fem.) for 'this'. Neutral form: esto for unknown or abstract things — '¿Qué es esto?' (What is this?)." }, { "front": "This book is good.", "back": "Este libro es bueno.", "literal": "This book is good." }] },
    { "id": "es_ep_015", "levels": [{ "front": "That", "back": "ese / esa" }, { "front": "That person is my friend.", "back": "Esa persona es mi amiga.", "literal": "That person is my friend." }] },
    { "id": "es_ep_016", "levels": [{ "front": "My", "back": "mi" }, { "front": "My name is Carlos.", "back": "Mi nombre es Carlos.", "literal": "My name is Carlos." }] },
    { "id": "es_ep_017", "levels": [{ "front": "Who", "back": "quién" }, { "front": "Who is that person?", "back": "¿Quién es esa persona?", "literal": "Who is that person?" }] },
    { "id": "es_ep_018", "levels": [{ "front": "What", "back": "qué" }, { "front": "What do you want?", "back": "¿Qué quieres?", "literal": "What want [you]?" }] },
    { "id": "es_ep_019", "levels": [{ "front": "When", "back": "cuándo" }, { "front": "When do you arrive?", "back": "¿Cuándo llegas?", "literal": "When arrive [you]?" }] },
    { "id": "es_ep_020", "levels": [{ "front": "Where", "back": "dónde" }, { "front": "Where is the bathroom?", "back": "¿Dónde está el baño?", "literal": "Where is the bathroom?" }] },
    { "id": "es_ep_021", "levels": [{ "front": "Why", "back": "por qué", "grammarNote": "por qué (two words, accents) = why? / porque (one word, no accent) = because. ¿Por qué no vienes? — Porque estoy cansado." }, { "front": "Why can't you come?", "back": "¿Por qué no puedes venir?", "literal": "Why not can [you] come?" }] },
    { "id": "es_ep_022", "levels": [{ "front": "How", "back": "cómo" }, { "front": "How are you?", "back": "¿Cómo estás?", "literal": "How are [you]?" }] },
    { "id": "es_ep_023", "levels": [{ "front": "Good morning", "back": "buenos días", "grammarNote": "Spanish greetings by time: buenos días (morning), buenas tardes (afternoon/evening), buenas noches (night). Casually, just buenas works at any hour." }, { "front": "Good morning! How did you sleep?", "back": "¡Buenos días! ¿Cómo dormiste?", "literal": "Good days! How slept [you]?" }] },
    { "id": "es_ep_024", "levels": [{ "front": "To look for", "back": "buscar" }, { "front": "I'm looking for the exit.", "back": "Busco la salida.", "literal": "[I] search the exit." }] },
    { "id": "es_ep_025", "levels": [{ "front": "Excuse me", "back": "perdón / con permiso", "grammarNote": "perdón = excuse me (apology or getting attention). con permiso = excuse me (when passing someone or leaving). disculpe is also common for getting a stranger's attention." }, { "front": "Excuse me, where is the main street?", "back": "Perdón, ¿dónde está la calle principal?", "literal": "Excuse-me, where is the street main?" }] },
    { "id": "es_ep_026", "levels": [{ "front": "To be able to / can", "back": "poder", "grammarNote": "poder stem-changes o→ue: yo puedo, tú puedes, él puede." }, { "front": "Can you help me?", "back": "¿Puedes ayudarme?", "literal": "Can [you] help-me?" }] },
    { "id": "es_ep_027", "levels": [{ "front": "I don't know", "back": "no sé" }, { "front": "I don't know where it is.", "back": "No sé dónde está.", "literal": "[I] not know where [it] is." }] },
    { "id": "es_ep_028", "levels": [{ "front": "To have", "back": "tener", "grammarNote": "tener is used for physical states: tener hambre (to be hungry), tener sed (to be thirsty), tener frío/calor (to be cold/hot), tener miedo (to be afraid)." }, { "front": "I'm hungry. Do you have water?", "back": "Tengo hambre. ¿Tienes agua?", "literal": "[I] have hunger. Have [you] water?" }] },
    { "id": "es_ep_029", "levels": [{ "front": "To do / make", "back": "hacer" }, { "front": "What are you doing?", "back": "¿Qué haces?", "literal": "What do [you]?" }] },
    { "id": "es_ep_030", "levels": [{ "front": "To eat", "back": "comer" }, { "front": "Where are we eating?", "back": "¿Dónde comemos?", "literal": "Where eat [we]?" }] },
    { "id": "es_ep_031", "levels": [{ "front": "To like", "back": "gustar", "grammarNote": "gustar works in reverse: the thing liked is the grammatical subject. 'Me gusta el café' = coffee pleases me = I like coffee. Singular: me gusta. Plural: me gustan ('Me gustan los libros')." }, { "front": "I like coffee.", "back": "Me gusta el café.", "literal": "To-me pleases the coffee." }] },
    { "id": "es_ep_032", "levels": [{ "front": "But", "back": "pero" }, { "front": "I want to go, but I can't.", "back": "Quiero ir, pero no puedo.", "literal": "[I] want to-go, but not [I] can." }] },
    { "id": "es_ep_033", "levels": [{ "front": "And", "back": "y", "grammarNote": "y changes to e before words starting with i or hi: 'madre e hija' (mother and daughter). o changes to u before o or ho: 'siete u ocho' (seven or eight)." }, { "front": "Water and food.", "back": "Agua y comida.", "literal": "Water and food." }] },
    { "id": "es_ep_034", "levels": [{ "front": "Or", "back": "o" }, { "front": "Tea or coffee?", "back": "¿Té o café?", "literal": "Tea or coffee?" }] },
    { "id": "es_ep_035", "levels": [{ "front": "Hungry", "back": "tengo hambre", "grammarNote": "Spanish uses tener (to have) for hunger, thirst, and temperature: tengo hambre (I'm hungry), tengo sed (I'm thirsty), tengo frío/calor (I'm cold/hot). These are 'having' a feeling, not 'being' one." }, { "front": "I'm very hungry.", "back": "Tengo mucha hambre.", "literal": "[I] have much hunger." }] },
    { "id": "es_ep_036", "levels": [{ "front": "Thirsty", "back": "tengo sed" }, { "front": "I'm very thirsty.", "back": "Tengo mucha sed.", "literal": "[I] have much thirst." }] },
    { "id": "es_ep_037", "levels": [{ "front": "Person", "back": "persona" }, { "front": "Who is that person?", "back": "¿Quién es esa persona?", "literal": "Who is that person?" }] },
    { "id": "es_ep_038", "levels": [{ "front": "Place", "back": "lugar" }, { "front": "Do you know a good place?", "back": "¿Conoces un buen lugar?", "literal": "Know [you] a good place?" }] },
    { "id": "es_ep_039", "levels": [{ "front": "Thing", "back": "cosa" }, { "front": "What is that thing?", "back": "¿Qué es esa cosa?", "literal": "What is that thing?" }] },
    { "id": "es_ep_040", "levels": [{ "front": "Here", "back": "aquí" }, { "front": "Come here!", "back": "¡Ven aquí!", "literal": "Come here!" }] },
    { "id": "es_ep_041", "levels": [{ "front": "There", "back": "allí / allá" }, { "front": "The bathroom is over there.", "back": "El baño está allá.", "literal": "The bathroom is there." }] },
    { "id": "es_ep_042", "levels": [{ "front": "Very", "back": "muy" }, { "front": "It's very good.", "back": "Está muy bien.", "literal": "[It] is very well." }] },
    { "id": "es_ep_043", "levels": [{ "front": "Goodbye", "back": "adiós / hasta luego" }, { "front": "Goodbye! See you tomorrow.", "back": "¡Adiós! Hasta mañana.", "literal": "Goodbye! Until tomorrow." }] },
    { "id": "es_ep_044", "levels": [{ "front": "Water", "back": "agua", "grammarNote": "agua is feminine but uses 'el' in singular because it begins with a stressed 'a'. Adjectives still agree feminine: 'el agua fría'. Plural: las aguas." }, { "front": "A glass of water, please.", "back": "Un vaso de agua, por favor.", "literal": "A glass of water, please." }] },
    { "id": "es_ep_045", "levels": [{ "front": "Food", "back": "comida" }, { "front": "The food is delicious.", "back": "La comida está deliciosa.", "literal": "The food is delicious." }] },
    { "id": "es_ep_046", "levels": [{ "front": "House / home", "back": "casa" }, { "front": "My house is nearby.", "back": "Mi casa está cerca.", "literal": "My house is nearby." }] },
    { "id": "es_ep_047", "levels": [{ "front": "Store / shop", "back": "tienda" }, { "front": "The store is closed.", "back": "La tienda está cerrada.", "literal": "The store is closed." }] },
    { "id": "es_ep_048", "levels": [{ "front": "Cash / credit", "back": "efectivo / tarjeta" }, { "front": "Cash or card?", "back": "¿Efectivo o tarjeta?", "literal": "Cash or card?" }] },
    { "id": "es_ep_049", "levels": [{ "front": "Help", "back": "ayuda" }, { "front": "I need your help.", "back": "Necesito tu ayuda.", "literal": "[I] need your help." }] },
    { "id": "es_ep_050", "levels": [{ "front": "Bathroom", "back": "baño" }, { "front": "Where is the bathroom?", "back": "¿Dónde está el baño?", "literal": "Where is the bathroom?" }] },
    { "id": "es_ep_051", "levels": [{ "front": "Always", "back": "siempre" }, { "front": "I always drink coffee in the morning.", "back": "Siempre tomo café por la mañana.", "literal": "[I] always drink coffee in the morning." }] },
    { "id": "es_ep_052", "levels": [{ "front": "Never", "back": "nunca", "grammarNote": "nunca usually comes before the verb. If placed after, add no before the verb: 'no llego tarde nunca'. Unlike English, double negatives are grammatically correct in Spanish." }, { "front": "I never arrive late.", "back": "Nunca llego tarde.", "literal": "[I] never arrive late." }] },
    { "id": "es_ep_053", "levels": [{ "front": "To go", "back": "ir", "grammarNote": "ir a + infinitive = going to do something: 'voy a comer' (I'm going to eat). Also: a + el contracts to al — 'voy al mercado' (not 'a el mercado')." }, { "front": "I'm going to the store.", "back": "Voy a la tienda.", "literal": "[I] go to the store." }] },
    { "id": "es_ep_054", "levels": [{ "front": "To come", "back": "venir" }, { "front": "Where are you coming from?", "back": "¿De dónde vienes?", "literal": "From where come [you]?" }] },
    { "id": "es_ep_055", "levels": [{ "front": "To understand", "back": "entender", "grammarNote": "entender stem-changes e→ie: entiendo, entiendes, entiende." }, { "front": "I don't understand.", "back": "No entiendo.", "literal": "[I] not understand." }] },
    { "id": "es_ep_056", "levels": [{ "front": "To speak / talk", "back": "hablar" }, { "front": "Do you speak Spanish?", "back": "¿Hablas español?", "literal": "Speak [you] Spanish?" }] },
    { "id": "es_ep_057", "levels": [{ "front": "To give", "back": "dar" }, { "front": "Give me the menu, please.", "back": "Dame el menú, por favor.", "literal": "Give-me the menu, please." }] },
    { "id": "es_ep_058", "levels": [{ "front": "To see", "back": "ver" }, { "front": "I can't see anything.", "back": "No puedo ver nada.", "literal": "[I] not can see nothing." }] },
    { "id": "es_ep_059", "levels": [{ "front": "With", "back": "con" }, { "front": "I came with my friend.", "back": "Vine con mi amigo.", "literal": "[I] came with my friend." }] },
    { "id": "es_ep_060", "levels": [{ "front": "Without", "back": "sin" }, { "front": "Coffee without sugar, please.", "back": "Café sin azúcar, por favor.", "literal": "Coffee without sugar, please." }] },
    { "id": "es_ep_061", "levels": [{ "front": "For", "back": "para / por", "grammarNote": "para = purpose or destination: 'un regalo para ti' (a gift for you). por = cause, exchange, or thanks: 'gracias por tu ayuda' (thanks for your help)." }, { "front": "This is for you. Thanks for everything.", "back": "Esto es para ti. Gracias por todo.", "literal": "This is for you. Thanks for everything." }] },
    { "id": "es_ep_062", "levels": [{ "front": "In / on / at", "back": "en" }, { "front": "The book is on the table.", "back": "El libro está en la mesa.", "literal": "The book is on the table." }] },
    { "id": "es_ep_063", "levels": [{ "front": "From", "back": "de / desde" }, { "front": "I'm from Mexico.", "back": "Soy de México.", "literal": "[I] am from Mexico." }] },
    { "id": "es_ep_064", "levels": [{ "front": "Good", "back": "bueno / buena" }, { "front": "That's a good idea.", "back": "Es una buena idea.", "literal": "[It] is a good idea." }] },
    { "id": "es_ep_065", "levels": [{ "front": "Bad", "back": "malo / mala" }, { "front": "That's bad news.", "back": "Eso son malas noticias.", "literal": "That are news bad." }] },
    { "id": "es_ep_066", "levels": [{ "front": "Big", "back": "grande" }, { "front": "A big coffee, please.", "back": "Un café grande, por favor.", "literal": "A coffee large, please." }] },
    { "id": "es_ep_067", "levels": [{ "front": "Small", "back": "pequeño / pequeña" }, { "front": "A small table, please.", "back": "Una mesa pequeña, por favor.", "literal": "A table small, please." }] },
    { "id": "es_ep_068", "levels": [{ "front": "A lot / much", "back": "mucho" }, { "front": "I have a lot of work.", "back": "Tengo mucho trabajo.", "literal": "[I] have much work." }] },
    { "id": "es_ep_069", "levels": [{ "front": "A little", "back": "un poco" }, { "front": "A little water, please.", "back": "Un poco de agua, por favor.", "literal": "A little of water, please." }] },
    { "id": "es_ep_070", "levels": [{ "front": "How do you say ___?", "back": "¿Cómo se dice ___?" }, { "front": "How do you say 'thank you' in Spanish?", "back": "¿Cómo se dice 'thank you' en español?", "literal": "How itself-says 'thank you' in Spanish?" }] },
    { "id": "es_ep_071", "levels": [{ "front": "Can you help me?", "back": "¿Puedes ayudarme?" }, { "front": "Excuse me, can you help me find the station?", "back": "Perdón, ¿puedes ayudarme a encontrar la estación?", "literal": "Excuse-me, can [you] help-me to find the station?" }] },
    { "id": "es_ep_072", "levels": [{ "front": "How much does it cost?", "back": "¿Cuánto cuesta?" }, { "front": "How much does this shirt cost?", "back": "¿Cuánto cuesta esta camisa?", "literal": "How-much costs this shirt?" }] },
    { "id": "es_ep_073", "levels": [{ "front": "I'm sorry", "back": "lo siento", "grammarNote": "lo siento (I feel it) = I'm sorry. For minor bumps or getting attention, use perdón. lo siento / lo siento mucho is for genuine apologies." }, { "front": "I'm very sorry.", "back": "Lo siento mucho.", "literal": "It [I]-feel much." }] },
    { "id": "es_ep_074", "levels": [{ "front": "No problem", "back": "no hay problema" }, { "front": "No problem, don't worry.", "back": "No hay problema, no te preocupes.", "literal": "Not there-is problem, not yourself worry [you]." }] }
  ]
}
